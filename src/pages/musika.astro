---
import PikutaraLayout from "../layouts/PikutaraLayout.astro";
---

<PikutaraLayout
  title="Baloratu Musika"
  description="Pikutara Konpartsaren txosnako musika baloratu eta proposatu zure gogokoenak."
>
  <div class="pik-container page-layout">
    <!-- Page Header -->
    <div class="page-header">
      <h1>MUSIKA ETA PLAYLISTA</h1>
      <p class="subtitle">
        Herri musika gure txosnarako. Baloratu gure zerrenda eta proposatu
        abesti berriak!
      </p>
    </div>

    <!-- 1. Global Playlist Rating Section (Full Width) -->
    <section class="pik-card playlist-rating-card" id="playlistRatingCard">
      <div class="playlist-grid">
        <!-- Playlist details/mock widget -->
        <div class="playlist-info-block">
          <div class="playlist-badge">PLAYLIST OFIZIALA</div>
          <h2>Pikutara Txosna 2026</h2>
          <p class="playlist-desc">
            Sestaoko txosnetan aurten jarriko dugun musika zerrenda nagusia.
            Punk, Rock, Ska, Reggetoia, Folka, Elektronika, Hip-hop-a eta denetariko musika biltzen dituen
            bilduma.
          </p>
        </div>

        <!-- Rating Form -->
        <div class="playlist-rate-form-block" id="playlistRatingBox">
          <h3>Zer iruditzen zaizu zerrenda?</h3>
          <p class="rate-desc">
            Baloratu gure musika aukeraketa izarrekin (1etik 5era) eta utzi zure
            iruzkina hobetzen laguntzeko.
          </p>

          <form id="playlistRateForm" class="playlist-rate-form">
            <div class="form-group">
              <div class="star-rating" id="playlistStars">
                <button
                  type="button"
                  class="p-star-btn"
                  data-value="1"
                  aria-label="Izartxo 1">★</button
                >
                <button
                  type="button"
                  class="p-star-btn"
                  data-value="2"
                  aria-label="2 Izartxo">★</button
                >
                <button
                  type="button"
                  class="p-star-btn"
                  data-value="3"
                  aria-label="3 Izartxo">★</button
                >
                <button
                  type="button"
                  class="p-star-btn"
                  data-value="4"
                  aria-label="4 Izartxo">★</button
                >
                <button
                  type="button"
                  class="p-star-btn"
                  data-value="5"
                  aria-label="5 Izartxo">★</button
                >
              </div>
              <input type="hidden" id="playlistRatingValue" value="5" />
            </div>

            <div class="form-group">
              <textarea
                id="playlistComment"
                class="pik-input"
                rows="2"
                placeholder="Zerrenda bikaina! Punk gehiago botatzen dut faltan..."
                required></textarea>
            </div>

            <button type="submit" class="pik-btn">Bidali Balorazioa</button>
          </form>

          <div
            id="playlistSuccess"
            class="success-alert"
            style="display: none;"
          >
            <div class="alert-icon">✊</div>
            <div class="alert-body">
              <h4>Mila esker baloratzeagatik!</h4>
              <p>
                Zure iruzkina jaso dugu. Orain abesti berriak proposatu
                ditzakezu behean.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. Dual columns for Song proposals and Chart (only when voted) -->
    <div class="music-portal-grid" id="musicPortalGrid">
      <!-- Submission Form -->
      <section class="pik-card submit-section" id="submitSection">
        <h3>Proposatu Abesti Bat</h3>
        <p class="form-desc">
          Sartu Spotifyko edo Youtubeko abesti baten esteka zuzena gure
          playlist-ean sartzeko.
        </p>

        <form id="songForm" class="song-form">
          <div class="form-group">
            <label for="songUser">Zure Izena</label>
            <input
              type="text"
              id="songUser"
              class="pik-input"
              placeholder="..."
              required
            />
          </div>

          <div class="form-group">
            <label for="songUrl">Abestiaren URL Esteka</label>
            <input
              type="url"
              id="songUrl"
              class="pik-input"
              placeholder="Spotify track edo YouTube video esteka..."
              required
            />
            <div id="urlError" class="error-text" style="display: none;"></div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="songTitle">Abestiaren Izenburua</label>
              <input
                type="text"
                id="songTitle"
                class="pik-input"
                placeholder="..."
                required
              />
            </div>
            <div class="form-group">
              <label for="songArtist">Taldea</label>
              <input
                type="text"
                id="songArtist"
                class="pik-input"
                placeholder="..."
                required
              />
            </div>
          </div>

          <div class="form-group">
            <label for="songComment">Iruzkin Laburra</label>
            <textarea
              id="songComment"
              class="pik-input"
              rows="3"
              placeholder="Zergatik jarri behar dugu abesti hau?"></textarea>
          </div>

          <!-- Privacy Notice Statement -->
          <div class="privacy-notice-box">
            <div class="privacy-icon">⚠️</div>
            <p class="privacy-text">
            <strong>Lege-oharra:</strong> Abestia bidaltzean, zure izena, iruzkina eta proposatutako
              abestia webgunean publikoki erakutsiko direla onartzen duzu.
            </p>
          </div>

          <button type="submit" class="pik-btn submit-btn"
            >Bidali Proposamena</button
          >
        </form>

        <!-- Success Message -->
        <div id="musicSuccess" class="success-alert" style="display: none;">
          <div class="alert-icon">🎵</div>
          <div class="alert-body">
            <h4>Proposamena jaso da!</h4>
            <p>
              Datu-basera bidali da. Balioztatu ostean, zerrendan txertatuko
              dugu.
            </p>
            <button
              id="proposeAnother"
              class="pik-btn-secondary"
              style="margin-top: 1rem; border: 1px solid var(--pik-red); padding: 0.3rem 0.8rem; border-radius: 4px; font-size: 0.9rem;"
              >Beste abesti bat proposatu</button
            >
          </div>
        </div>
      </section>

      <!-- Chart Section -->
      <div class="pik-card chart-card" id="chartCard">
        <div class="section-title-bar chart-title-bar">
          <div class="chart-header-row">
            <h3>Musika Joerak</h3>
            <span class="active-badge">Grafikoa</span>
          </div>
          <div id="chartBreadcrumbContainer">
            <button id="chartBackButton">⬅️ Atzera</button>
            <span id="chartBreadcrumbs"></span>
          </div>
        </div>
        <div style="width: 100%; max-width: 400px; margin: 1rem auto;">
          <canvas id="genreChart"></canvas>
        </div>
        <div class="chart-info-prompt">
          <span class="prompt-icon">💡</span>
          <p class="prompt-text">
            Egin klik grafikoko generoen gainean (adibidez, <strong>Bestelakoak</strong> edo azpigeneroak dituztenak) xehetasunak eta banaketak ikusteko.
          </p>
        </div>
      </div>
    </div>

    <!-- 3. Proposed Songs List (Full Width, only when voted) -->
    <div class="proposed-songs-container" id="proposedSongsContainer">
      <div class="section-title-bar" id="songsTitleBar">
        <h3>Txosnaguneko musika-zerrenda</h3>
        <span class="active-badge">Jasotakoak</span>
      </div>

      <!-- Genre Selector Filter -->
      <div class="songs-filter-bar">
        <div class="filter-group">
          <span class="filter-label">Generoa:</span>
          <div class="custom-select-wrapper" id="customSelectWrapper">
            <button class="pik-select-trigger" id="customSelectTrigger">
              <span id="selectedGenreName">Guztiak (Denak erakutsi)</span>
              <span class="trigger-arrow">▼</span>
            </button>
            <div class="pik-select-dropdown" id="customSelectDropdown" style="display: none;">
              <!-- Hierarchical options will be dynamically loaded here -->
            </div>
          </div>
        </div>
        <div class="songs-count-badge">
          Abestiak: <span id="displayedCount" class="badge-value">0</span> / <span id="totalMatchingCount" class="badge-value">0</span>
        </div>
      </div>

      <div class="songs-list" id="songsList">
        <!-- Dynamically filled by JS -->
        <p style="color: var(--pik-text-muted);">Abestiak kargatzen...</p>
      </div>

      <!-- Pagination / Load More button -->
      <div class="load-more-container" id="loadMoreContainer" style="display: none;">
        <button id="loadMoreBtn" class="pik-btn load-more-btn">
          Ikusi gehiago (Erakutsi 10 gehiago)
        </button>
      </div>
    </div>
  </div>
</PikutaraLayout>

<script>
  import Chart from 'chart.js/auto';

  // Playlist Star rating interactivity
  const pStarBtns = document.querySelectorAll(".p-star-btn");
  const playlistRatingValue = document.getElementById(
    "playlistRatingValue",
  ) as HTMLInputElement;

  function updatePlaylistStars(val: number) {
    pStarBtns.forEach((btn, idx) => {
      if (idx < val) {
        btn.classList.add("selected");
      } else {
        btn.classList.remove("selected");
      }
    });
    if (playlistRatingValue) {
      playlistRatingValue.value = String(val);
    }
  }

  // Initialize with 5 stars
  updatePlaylistStars(5);

  pStarBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const val = Number(btn.getAttribute("data-value"));
      updatePlaylistStars(val);
    });
  });

  // Check if already reviewed on load
  let hasReviewed =
    localStorage.getItem("pikutara_playlist_reviewed") === "true";
  const playlistRateForm = document.getElementById(
    "playlistRateForm",
  ) as HTMLFormElement;
  const playlistSuccess = document.getElementById("playlistSuccess");

  function updateStateVisibility() {
    const playlistRatingCard = document.getElementById("playlistRatingCard");
    const submitSection = document.getElementById("submitSection");
    const proposedSongsContainer = document.getElementById("proposedSongsContainer");
    const portalGrid = document.getElementById("musicPortalGrid");

    if (hasReviewed) {
      if (playlistRatingCard) playlistRatingCard.style.display = "none";
      if (submitSection) submitSection.style.display = "block";
      if (proposedSongsContainer) proposedSongsContainer.style.display = "block";
      if (portalGrid) portalGrid.classList.add("voted-state");
    } else {
      if (playlistRatingCard) playlistRatingCard.style.display = "block";
      if (submitSection) submitSection.style.display = "none";
      if (proposedSongsContainer) proposedSongsContainer.style.display = "none";
      if (portalGrid) portalGrid.classList.remove("voted-state");
    }
  }

  // Initialize visibility state on load
  updateStateVisibility();

  // Async server validation if local storage does not have it yet
  if (!hasReviewed) {
    fetch("/api/playlist/has-voted")
      .then((r) => r.json())
      .then((data) => {
        if (data && data.hasVoted) {
          localStorage.setItem("pikutara_playlist_reviewed", "true");
          hasReviewed = true;
          updateStateVisibility();
        }
      })
      .catch((err) => console.error("Error checking vote status:", err));
  }

  // Playlist rating form submission via API
  if (playlistRateForm && playlistSuccess) {
    playlistRateForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      const ratingValueInput = document.getElementById(
        "playlistRatingValue",
      ) as HTMLInputElement;
      const commentInput = document.getElementById(
        "playlistComment",
      ) as HTMLTextAreaElement;

      const rating = Number(ratingValueInput?.value || 5);
      const comment = commentInput?.value || "";

      try {
        const res = await fetch("/api/playlist/reviews", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ rating, comment }),
        });

        if (res.ok) {
          localStorage.setItem("pikutara_playlist_reviewed", "true");
          hasReviewed = true;
          updateStateVisibility();
          alert("Mila esker baloratzeagatik! Orain zure abesti gogokoenak proposatu ditzakezu.");
        } else {
          const data = await res.json();
          const errorMsg = data.error || "Errorea balorazioa bidaltzean.";
          alert(errorMsg);
          if (errorMsg.includes("Dagoeneko baloratu") || errorMsg.toLowerCase().includes("already rated")) {
            localStorage.setItem("pikutara_playlist_reviewed", "true");
            hasReviewed = true;
            updateStateVisibility();
          }
        }
      } catch (err) {
        alert("Ezin izan da zerbitzariarekin konektatu.");
      }
    });
  }

  // URL Validation & Form Submission
  const songForm = document.getElementById("songForm") as HTMLFormElement;
  const songUrlInput = document.getElementById("songUrl") as HTMLInputElement;
  const songTitleInput = document.getElementById("songTitle") as HTMLInputElement;
  const songArtistInput = document.getElementById("songArtist") as HTMLInputElement;
  const songUserInput = document.getElementById("songUser") as HTMLInputElement;
  const songCommentInput = document.getElementById("songComment") as HTMLTextAreaElement;
  const urlError = document.getElementById("urlError");
  const musicSuccess = document.getElementById("musicSuccess");
  const proposeAnother = document.getElementById("proposeAnother");

  if (songForm && songUrlInput && urlError && musicSuccess) {
    songForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      let url = songUrlInput.value.trim();

      // Clean YouTube watch link with playlist parameters (e.g. from Mix queues)
      if (url.includes("youtube.com/watch") || url.includes("youtu.be/")) {
        try {
          const parsedUrl = new URL(url);
          const hasVideoId = parsedUrl.searchParams.has("v") || (parsedUrl.hostname.includes("youtu.be") && parsedUrl.pathname.length > 1);
          if (hasVideoId) {
            parsedUrl.searchParams.delete("list");
            parsedUrl.searchParams.delete("index");
            url = parsedUrl.toString();
          }
        } catch (err) {
          // Ignore parse errors
        }
      }

      urlError.style.display = "none";

      // 1. Check if playlist or album
      const isPlaylist =
        url.includes("/playlist/") ||
        url.includes("/playlists/") ||
        url.includes("list=") ||
        url.includes("/album/");
      if (isPlaylist) {
        urlError.textContent =
          "Mesedez, sartu abesti baten esteka zuzena, ez erreprodukzio-zerrenda edo album bat.";
        urlError.style.display = "block";
        songUrlInput.focus();
        return;
      }

      // 2. Validate Spotify/YouTube song patterns
      const spotifySongRegex =
        /^(https?:\/\/)?(open\.spotify\.com\/(?:[a-zA-Z0-9_-]+\/)?track\/)[a-zA-Z0-9]+/;

      const youtubeSongRegex =
        /^(https?:\/\/)?(www\.)?(youtube\.com\/watch\?v=|youtu\.be\/)[a-zA-Z0-9_-]{11}/;

      const isSpotify = spotifySongRegex.test(url);
      const isYoutube = youtubeSongRegex.test(url);

      if (!isSpotify && !isYoutube) {
        urlError.textContent =
          "URL ez da baliozkoa. Spotify abesti esteka edo YouTubeko bideo esteka bat izan behar du.";
        urlError.style.display = "block";
        songUrlInput.focus();
        return;
      }

      // 3. API Submission
      const submitBtn = songForm.querySelector("button[type='submit']") as HTMLButtonElement;
      const originalBtnHtml = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" style="animation: spin 1s linear infinite; display: inline-block; width: 1.25rem; height: 1.25rem; vertical-align: middle; margin-right: 8px;">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" style="opacity: 0.25;"></circle>
          <path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" style="opacity: 0.75;"></path>
        </svg>
        Bidaltzen...
      `;

      try {
        const payload = {
          url: url,
          title: songTitleInput.value.trim(),
          artist: songArtistInput.value.trim(),
          submittedBy: songUserInput.value.trim(),
          comment: songCommentInput?.value.trim() || ''
        };

        const res = await fetch("/api/musika/songs", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });

        if (res.ok) {
          songForm.style.display = "none";
          musicSuccess.style.display = "block";
        } else {
          const data = await res.json();
          alert(data.error || "Errorea gertatu da abestia bidaltzean.");
        }
      } catch (err) {
        alert("Ezin izan da zerbitzariarekin konektatu.");
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalBtnHtml;
      }
    });

    if (proposeAnother) {
      proposeAnother.addEventListener("click", () => {
        songForm.reset();
        musicSuccess.style.display = "none";
        songForm.style.display = "flex";
      });
    }
  }

  // Dynamic Songs & Chart
  const songsListContainer = document.getElementById("songsList");
  let genreChartInstance: any = null;
  let hierarchy: Record<string, string> = {};
  let chartPath: string[] = [];
  let allAcceptedSongs: any[] = [];

  let selectedGenre = 'all';
  let displayedSongsLimit = 10;

  const customSelectDropdown = document.getElementById("customSelectDropdown");
  const customSelectTrigger = document.getElementById("customSelectTrigger");
  const selectedGenreNameEl = document.getElementById("selectedGenreName");
  const loadMoreContainer = document.getElementById("loadMoreContainer");
  const loadMoreBtn = document.getElementById("loadMoreBtn");
  const displayedCountEl = document.getElementById("displayedCount");
  const totalMatchingCountEl = document.getElementById("totalMatchingCount");

  function selectGenreOption(value: string, label: string) {
    selectedGenre = value;
    displayedSongsLimit = 10;
    
    if (selectedGenreNameEl) {
      selectedGenreNameEl.textContent = label;
    }
    
    if (customSelectDropdown) {
      customSelectDropdown.style.display = "none";
    }
    
    if (customSelectTrigger) {
      customSelectTrigger.classList.remove("active");
      if (value === 'all') {
        customSelectTrigger.style.removeProperty('--trigger-color');
      } else {
        customSelectTrigger.style.setProperty('--trigger-color', getGenreColorRaw(value));
      }
    }
    
    const allItems = document.querySelectorAll(".dropdown-item");
    allItems.forEach(item => {
      if ((item as HTMLElement).dataset.value === value) {
        item.classList.add("active");
      } else {
        item.classList.remove("active");
      }
    });

    renderSongsList();
  }

  function getGenrePath(genre: string): string[] {
    if (!genre) return [];
    const pathList = [genre.trim()];
    let current = genre.trim();
    const maxDepth = 10;
    let depth = 0;
    while (hierarchy[current.toLowerCase()] && depth < maxDepth) {
      current = hierarchy[current.toLowerCase()].trim();
      pathList.push(current);
      depth++;
    }
    return pathList.reverse(); // returns [root, ..., leaf]
  }

  function hashString(str: string): number {
    let hash = 0;
    for (let i = 0; i < str.length; i++) {
      hash = str.charCodeAt(i) + ((hash << 5) - hash);
    }
    return hash;
  }

  function getGenreColorRaw(genreName: string): string {
    if (!genreName) return '340, 80%, 50%';
    const lowerName = genreName.toLowerCase().trim();
    if (lowerName === 'bestelakoak') {
      return '0, 0%, 55%';
    }
    
    const path = getGenrePath(genreName);
    const root = path.length > 0 ? path[0] : genreName;
    
    const rootHash = hashString(root.toLowerCase().trim());
    let hue = Math.abs(rootHash % 360);
    
    const fullHash = hashString(lowerName);
    if (root.toLowerCase().trim() !== lowerName) {
      const shift = (fullHash % 50) - 25;
      hue = (hue + shift + 360) % 360;
    }
    
    const saturation = 80 - (Math.abs(fullHash) % 15);
    const lightness = 48 + (Math.abs(fullHash) % 10);
    
    return `${hue}, ${saturation}%, ${lightness}%`;
  }

  function songMatchesGenre(song: any, targetGenre: string): boolean {
    if (targetGenre === 'all') return true;
    if (!song.genres || !Array.isArray(song.genres)) return false;

    return song.genres.some((g: string) => {
      const path = getGenrePath(g);
      return path.some(p => p.toLowerCase() === targetGenre.toLowerCase());
    });
  }

  function renderSongsList() {
    if (!songsListContainer) return;

    let filtered = allAcceptedSongs;
    if (selectedGenre !== 'all') {
      filtered = allAcceptedSongs.filter(song => songMatchesGenre(song, selectedGenre));
    }

    const totalMatching = filtered.length;
    const songsToDisplay = filtered.slice(0, displayedSongsLimit);

    if (songsToDisplay.length === 0) {
      songsListContainer.innerHTML = '<p style="color: var(--pik-text-muted);">Ez da abestirik aurkitu genero honekin.</p>';
      if (loadMoreContainer) loadMoreContainer.style.display = "none";
      if (displayedCountEl) displayedCountEl.textContent = "0";
      if (totalMatchingCountEl) totalMatchingCountEl.textContent = "0";
      return;
    }

    songsListContainer.innerHTML = '';

    songsToDisplay.forEach((song: any) => {
      const card = document.createElement("div");
      card.className = "pik-card song-card";

      let chipsHtml = '';
      if (song.genres && Array.isArray(song.genres) && song.genres.length > 0) {
        chipsHtml = '<div class="genre-chips">' + song.genres.map((g: string) => `<span class="genre-chip" style="--chip-color: ${getGenreColorRaw(g)}">${g}</span>`).join('') + '</div>';
      }

      const submittersStr = song.submitters && Array.isArray(song.submitters) ? song.submitters.join(', ') : 'Ezezaguna';
      const commentsHtml = song.comments && Array.isArray(song.comments) && song.comments.length > 0
        ? song.comments.map((c: string) => `<p class="user-comment">"${c}"</p>`).join('')
        : '';

      card.innerHTML = `
        <div class="song-card-inner">
          <div class="song-icon-container">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="song-music-icon"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>
          </div>
          <div class="song-main-details">
            <div class="song-header">
              <span class="submitted-by">Proposatzailea: <strong>${submittersStr}</strong></span>
            </div>
            <h4>${song.real_title || 'Ezezaguna'}</h4>
            <p class="artist-name">${song.real_artist || 'Ezezaguna'}</p>
            ${chipsHtml}
            ${commentsHtml}
          </div>
        </div>
      `;
      songsListContainer.appendChild(card);
    });

    if (displayedCountEl) displayedCountEl.textContent = String(songsToDisplay.length);
    if (totalMatchingCountEl) totalMatchingCountEl.textContent = String(totalMatching);

    if (loadMoreContainer) {
      if (totalMatching > displayedSongsLimit) {
        loadMoreContainer.style.display = "block";
      } else {
        loadMoreContainer.style.display = "none";
      }
    }
  }

  async function fetchAcceptedSongs() {
    if (!songsListContainer) return;
    try {
      // Fetch hierarchy map first
      try {
        const hRes = await fetch("/api/musika/genre-hierarchy");
        if (hRes.ok) {
          hierarchy = await hRes.json();
        }
      } catch (e) {
        console.error("Error fetching genre hierarchy:", e);
      }

      const res = await fetch("/api/musika/songs");
      if (!res.ok) throw new Error("API Error");
      allAcceptedSongs = await res.json();

      if (allAcceptedSongs.length === 0) {
        songsListContainer.innerHTML = '<p style="color: var(--pik-text-muted);">Oraindik ez dago abesti onarturik.</p>';
        return;
      }

      // Group genres by root for hierarchical selection
      const rootGroups: Record<string, Set<string>> = {};
      allAcceptedSongs.forEach((song: any) => {
        if (song.genres && Array.isArray(song.genres)) {
          song.genres.forEach((g: string) => {
            if (g && g.trim()) {
              const path = getGenrePath(g.trim());
              const root = path[0] || g.trim();
              if (!rootGroups[root]) {
                rootGroups[root] = new Set<string>();
              }
              if (g.trim().toLowerCase() !== root.toLowerCase()) {
                rootGroups[root].add(g.trim());
              }
            }
          });
        }
      });

      if (customSelectDropdown) {
        customSelectDropdown.innerHTML = '';
        
        // Add "All" option
        const allOption = document.createElement("div");
        allOption.className = "dropdown-item main-item active";
        allOption.dataset.value = "all";
        allOption.style.setProperty('--item-color', '340, 80%, 50%');
        allOption.innerHTML = `<span>Guztiak (Denak erakutsi)</span> <span class="item-count">(${allAcceptedSongs.length})</span>`;
        allOption.addEventListener("click", () => selectGenreOption("all", "Guztiak (Denak erakutsi) (" + allAcceptedSongs.length + ")"));
        customSelectDropdown.appendChild(allOption);
        
        const sortedRoots = Object.keys(rootGroups).sort((a, b) => a.localeCompare(b));
        sortedRoots.forEach(root => {
          const subSet = rootGroups[root];
          const rootCount = allAcceptedSongs.filter(s => songMatchesGenre(s, root)).length;
          
          const groupContainer = document.createElement("div");
          groupContainer.className = "dropdown-group";
          
          const groupHeader = document.createElement("div");
          groupHeader.className = "dropdown-group-header";
          groupHeader.style.setProperty('--group-color', getGenreColorRaw(root));
          groupHeader.textContent = root.toUpperCase();
          groupContainer.appendChild(groupHeader);
          
          const parentOpt = document.createElement("div");
          parentOpt.className = "dropdown-item parent-item";
          parentOpt.dataset.value = root;
          parentOpt.style.setProperty('--item-color', getGenreColorRaw(root));
          parentOpt.innerHTML = `<span>• Guztiak / Todo ${root}</span> <span class="item-count">(${rootCount})</span>`;
          parentOpt.addEventListener("click", () => selectGenreOption(root, `${root} (${rootCount})`));
          groupContainer.appendChild(parentOpt);
          
          if (subSet.size > 0) {
            const sortedSubs = Array.from(subSet).sort((a, b) => a.localeCompare(b));
            sortedSubs.forEach(sub => {
              const subCount = allAcceptedSongs.filter(s => songMatchesGenre(s, sub)).length;
              const subOpt = document.createElement("div");
              subOpt.className = "dropdown-item sub-item";
              subOpt.dataset.value = sub;
              subOpt.style.setProperty('--item-color', getGenreColorRaw(sub));
              subOpt.innerHTML = `<span>${sub}</span> <span class="item-count">(${subCount})</span>`;
              subOpt.addEventListener("click", () => selectGenreOption(sub, `${sub} (${subCount})`));
              groupContainer.appendChild(subOpt);
            });
          }
          
          customSelectDropdown.appendChild(groupContainer);
        });
      }

      renderSongsList();

      // Initially compute and render the chart at root level []
      chartPath = [];
      updateChartAndTitle();

    } catch (err) {
      console.error(err);
      songsListContainer.innerHTML = '<p style="color: var(--pik-red);">Ezin izan dira abestiak kargatu.</p>';
    }
  }

  // Setup custom select dropdown event listeners
  if (customSelectTrigger && customSelectDropdown) {
    customSelectTrigger.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = customSelectDropdown.style.display === "block";
      customSelectDropdown.style.display = isOpen ? "none" : "block";
      customSelectTrigger.classList.toggle("active", !isOpen);
    });

    document.addEventListener("click", () => {
      customSelectDropdown.style.display = "none";
      customSelectTrigger.classList.remove("active");
    });
  }

  if (loadMoreBtn) {
    loadMoreBtn.addEventListener("click", () => {
      displayedSongsLimit += 10;
      renderSongsList();
    });
  }

  function getRootGenresBreakdown() {
    const counts: Record<string, number> = {};
    allAcceptedSongs.forEach((song: any) => {
      if (song.genres && Array.isArray(song.genres)) {
        song.genres.forEach((g: string) => {
          const gPath = getGenrePath(g);
          const rootGen = gPath.length > 0 ? gPath[0] : null;
          if (rootGen) {
            counts[rootGen] = (counts[rootGen] || 0) + 1;
          }
        });
      }
    });
    const sorted = Object.entries(counts).sort((a, b) => b[1] - a[1]);
    const main = new Set<string>();
    const others = new Set<string>();
    sorted.forEach(([genre, count], idx) => {
      if (idx < 8) {
        main.add(genre.toLowerCase());
      } else {
        others.add(genre.toLowerCase());
      }
    });
    return { main, others };
  }

  function updateChartAndTitle() {
    // Update breadcrumbs UI
    const breadcrumbContainer = document.getElementById("chartBreadcrumbContainer");
    const breadcrumbsSpan = document.getElementById("chartBreadcrumbs");
    if (breadcrumbContainer && breadcrumbsSpan) {
      if (chartPath.length > 0) {
        breadcrumbContainer.style.display = "flex";
        breadcrumbsSpan.innerText = "Nagusia > " + chartPath.join(" > ");
      } else {
        breadcrumbContainer.style.display = "none";
      }
    }

    // Compute counts based on current chartPath
    const rootBreakdown = getRootGenresBreakdown();
    const genreCounts: Record<string, number> = {};
    
    allAcceptedSongs.forEach((song: any) => {
      if (song.genres && Array.isArray(song.genres)) {
        song.genres.forEach((g: string) => {
          const gPath = getGenrePath(g);
          if (gPath.length === 0) return;
          
          let matches = false;
          let category = "";
          
          if (chartPath.length === 0) {
            matches = true;
            const rootGen = gPath[0];
            if (rootBreakdown.main.has(rootGen.toLowerCase())) {
              category = rootGen;
            } else {
              category = "Bestelakoak";
            }
          } else if (chartPath[0] === "Bestelakoak") {
            if (chartPath.length === 1) {
              if (rootBreakdown.others.has(gPath[0].toLowerCase())) {
                matches = true;
                category = gPath[0];
              }
            } else {
              const subPath = chartPath.slice(1);
              let subMatches = true;
              for (let i = 0; i < subPath.length; i++) {
                if (i >= gPath.length || gPath[i].toLowerCase() !== subPath[i].toLowerCase()) {
                  subMatches = false;
                  break;
                }
              }
              if (subMatches) {
                matches = true;
                const nextIndex = subPath.length;
                category = nextIndex < gPath.length ? gPath[nextIndex] : gPath[gPath.length - 1];
              }
            }
          } else {
            let pathMatches = true;
            for (let i = 0; i < chartPath.length; i++) {
              if (i >= gPath.length || gPath[i].toLowerCase() !== chartPath[i].toLowerCase()) {
                pathMatches = false;
                break;
              }
            }
            if (pathMatches) {
              matches = true;
              const nextIndex = chartPath.length;
              category = nextIndex < gPath.length ? gPath[nextIndex] : gPath[gPath.length - 1];
            }
          }
          
          if (matches && category) {
            let finalCategory = category;
            if (chartPath.length > 0) {
              const currentParent = chartPath[chartPath.length - 1];
              if (finalCategory.toLowerCase() === currentParent.toLowerCase()) {
                finalCategory = `${finalCategory} (orokorra)`;
              }
            }
            genreCounts[finalCategory] = (genreCounts[finalCategory] || 0) + 1;
          }
        });
      }
    });

    renderChart(genreCounts);
  }

  // Set up back button listener
  document.getElementById("chartBackButton")?.addEventListener("click", () => {
    if (chartPath.length > 0) {
      chartPath.pop();
      updateChartAndTitle();
    }
  });

  function renderChart(genreCounts: Record<string, number>) {
    const ctx = document.getElementById('genreChart') as HTMLCanvasElement;
    if (!ctx) return;

    let totalOccurrences = 0;
    for (const count of Object.values(genreCounts)) {
      totalOccurrences += count;
    }

    if (totalOccurrences === 0) return;

    const sortedGenres = Object.entries(genreCounts).sort((a, b) => b[1] - a[1]);
    const labels = sortedGenres.map(([g]) => g);
    const data = sortedGenres.map(([_, c]) => c);

    if (genreChartInstance) {
      genreChartInstance.destroy();
    }

    // Generate stable HSL colors for each label based on name and hierarchy
    const colors = labels.map((label: string) => `hsl(${getGenreColorRaw(label)})`);

    genreChartInstance = new Chart(ctx, {
      type: 'doughnut',
      data: {
        labels: labels,
        datasets: [{
          data: data,
          backgroundColor: colors,
          borderColor: '#0c020c',
          borderWidth: 2
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: {
            position: 'bottom',
            labels: { color: '#ffffff' }
          },
          tooltip: {
            callbacks: {
              label: (context: any) => {
                const label = context.label || '';
                const value = context.raw || 0;
                const dataset = context.dataset;
                const total = dataset.data.reduce((acc: number, val: number) => acc + val, 0);
                const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : '0';
                return `${label}: ${percentage}%`;
              },
              afterLabel: (context: any) => {
                const clickedLabel = context.label;
                const lowerLabel = clickedLabel.toLowerCase();
                const isOtros = clickedLabel === "Bestelakoak";
                const hasChildren = Object.values(hierarchy).some(parent => parent.toLowerCase() === lowerLabel);
                return (isOtros || hasChildren) ? ' (Klik egin xehetasunak ikusteko 🔍)' : '';
              }
            }
          }
        },
        onHover: (event: any, chartElements: any) => {
          if (event.native && event.native.target) {
            const target = event.native.target as HTMLElement;
            if (chartElements.length > 0) {
              const index = chartElements[0].index;
              const clickedLabel = genreChartInstance.data.labels[index];
              const isOtros = clickedLabel === "Bestelakoak";
              const lowerLabel = clickedLabel.toLowerCase();
              const hasChildren = Object.values(hierarchy).some(parent => parent.toLowerCase() === lowerLabel);
              if (isOtros || hasChildren) {
                target.style.cursor = 'pointer';
                return;
              }
            }
            target.style.cursor = 'default';
          }
        },
        onClick: (event: any, elements: any) => {
          if (elements.length > 0) {
            const firstElement = elements[0];
            const index = firstElement.index;
            const clickedLabel = genreChartInstance.data.labels[index];
            const isOtros = clickedLabel === "Bestelakoak";
            const lowerLabel = clickedLabel.toLowerCase();
            const hasChildren = Object.values(hierarchy).some(parent => parent.toLowerCase() === lowerLabel);
            
            if (isOtros || hasChildren) {
              chartPath.push(clickedLabel);
              updateChartAndTitle();
            }
          }
        }
      }
    });
  }

  fetchAcceptedSongs();
</script>

