---
import PikutaraLayout from "../layouts/PikutaraLayout.astro";
---

<PikutaraLayout title="Ataria">
  <!-- Hero Section -->
  <section class="pik-hero">
    <div class="pik-container hero-grid">
      <div class="hero-text-content">
        <h1 class="main-title">FAXISMOA</h1>
        <h2 class="sub-title">AIZKORATU!</h2>
        <p class="hero-description">
          Pikutara gazte konpartsa gara! Jai-eredu kapitalistaren aurrean,
          autogestioa eta borroka kolektiboa ditugu ardatz. Herri kultura eta
          elkartasuna baliatuz, faxismoari eta inperialismoari aurre egingo
          diegu, gaur eta bihar herria astintzen jarraitzeko.
        </p>
        <div class="hero-actions">
          <a href="/kartelak" class="pik-btn" data-section="kartelak">
            <span>Ekitaldiak Ikusi</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                points="12 5 19 12 12 19"></polyline></svg
            >
          </a>
          <a href="#ekimenak" class="pik-btn-secondary">Gehiago irakurri ↓</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="visual-badge-wrapper">
          <img
            src="/assets/tentacles.svg"
            class="hero-tentacles-bg"
            alt=""
            loading="eager"
          />
          <img
            src="/assets/konpartsa_piktograma.svg"
            alt="Pikutara Ikurra"
            class="hero-logo-img"
          />
          <div class="star-glow"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Campaign: Txartelari Ez! (Brutalist style) -->
  <section
    id="ekimenak"
    class="pik-container section-container"
    data-section="boikota"
  >
    <div class="section-header">
      <h2>GURE KANPAINAK</h2>
      <p>
        Gazte konpartsa moduan bultzatzen ditugun borroka eta ekimen nagusiak.
      </p>
    </div>

    <div class="featured-campaign-box">
      <!-- Old brutalist theme capsule wrapper -->
      <div class="brutal-capsule">
        <div class="brutal-badge">BOIKOT KANPAINA</div>
        <div class="brutal-body">
          <div class="brutal-text-side">
            <h3 class="brutal-title">HEMEN EZ DUGU TXARTELARIK ONARTZEN!</h3>
            <p class="brutal-desc">
              AEB-ko inperialismoaren eta banku handien kontrol finantzarioaren
              aurka, herriko ekonomia babesteko eskudiruz ordaintzera
              gonbidatzen zaitugu. Gure txosnan txartelari EZ!
            </p>
            <a href="/boikota" class="pik-btn-brutal">
              <span>Kanpainan Sartu →</span>
            </a>
          </div>
          <div class="brutal-image-side">
            <img
              src="/assets/donald_aldrebez.svg"
              alt="Donald Trump"
              class="donald-brutal-img"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</PikutaraLayout>

<style>
  /* Hero Styles */
  .pik-hero {
    padding: 6rem 0;
    position: relative;
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
    align-items: center;
  }

  .theme-tag {
    display: inline-block;
    background-color: var(--pik-red);
    color: #fff;
    font-weight: 800;
    font-size: 0.9rem;
    padding: 0.3rem 0.8rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .main-title {
    font-size: clamp(2.2rem, 5vw, 4.5rem);
    line-height: 1.05;
    margin-bottom: 0.5rem;
    color: #fff;
    text-shadow: 0 0 15px var(--pik-purple-glow);
  }

  .sub-title {
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.95;
    color: var(--pik-red);
    text-shadow:
      4px 4px 0px var(--pik-purple),
      0 0 30px var(--pik-red-glow);
    margin-bottom: 2rem;
    font-weight: 900;
  }

  .hero-description {
    font-size: clamp(1.1rem, 2.5vh, 1.4rem);
    line-height: 1.6;
    color: var(--pik-text-muted);
    margin-bottom: 2.5rem;
    max-width: 650px;
  }

  .hero-actions {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .pik-btn-secondary {
    font-family: var(--pik-font);
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    font-size: 1.1rem;
    transition: color 0.2s ease;
  }

  .pik-btn-secondary:hover {
    color: var(--pik-red);
  }

  /* Hero Visual side */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .visual-badge-wrapper {
    position: relative;
    z-index: 2;
    animation: floatLogo 6s ease-in-out infinite;
  }

  .hero-logo-img {
    width: clamp(200px, 30vw, 350px);
    height: auto;
    filter: drop-shadow(0 0 25px var(--pik-purple-glow));
  }

  .star-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 120%;
    height: 120%;
    background: radial-gradient(
      circle,
      rgba(255, 0, 0, 0.15) 0%,
      rgba(87, 0, 87, 0.05) 50%,
      transparent 70%
    );
    z-index: -1;
  }

  .hero-tentacles-bg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-38.8%, -50.6%) translate(-40px, -50px);
    width: 250%;
    height: auto;
    pointer-events: none;
    z-index: -2;
    max-width: none !important;
  }

  @keyframes floatLogo {
    0%,
    100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-15px) rotate(2deg);
    }
  }

  /* Section Styles */
  .section-container {
    padding: 5rem 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-header h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    color: #fff;
    margin-bottom: 0.8rem;
    position: relative;
    display: inline-block;
  }

  .section-header h2::after {
    content: "";
    position: absolute;
    bottom: -6px;
    left: 20%;
    width: 60%;
    height: 3px;
    background: linear-gradient(90deg, var(--pik-purple), var(--pik-red));
  }

  .section-header p {
    color: var(--pik-text-muted);
    font-size: 1.2rem;
  }

  /* Brutalist Campaign Box */
  .featured-campaign-box {
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
  }

  .brutal-capsule {
    background-color: #111;
    border: 4px solid #f4f4f0;
    box-shadow: 10px 10px 0px var(--pik-purple);
    padding: 2.5rem;
    position: relative;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .brutal-capsule:hover {
    transform: translate(-2px, -2px);
    box-shadow: 12px 12px 0px var(--pik-red);
  }

  .brutal-badge {
    position: absolute;
    top: -18px;
    left: 20px;
    background-color: var(--pik-red);
    color: #fff;
    font-family: "Anton", sans-serif;
    font-size: 1.1rem;
    padding: 0.3rem 1rem;
    border: 3px solid #f4f4f0;
    letter-spacing: 1px;
    transform: rotate(-1.5deg);
  }

  .brutal-body {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: 2rem;
    align-items: center;
  }

  .brutal-title {
    font-family: "Anton", sans-serif;
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    color: #ffff00;
    line-height: 1.1;
    margin-bottom: 1rem;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .brutal-desc {
    font-family: "Space Mono", monospace;
    font-size: 1.1rem;
    color: #f4f4f0;
    margin-bottom: 2rem;
    line-height: 1.5;
  }

  .pik-btn-brutal {
    display: inline-block;
    font-family: "Anton", sans-serif;
    font-size: 1.3rem;
    padding: 0.6rem 1.8rem;
    background-color: #ffff00;
    color: #111;
    border: 3px solid #f4f4f0;
    box-shadow: 5px 5px 0px var(--pik-purple);
    text-decoration: none;
    text-transform: uppercase;
    transition:
      transform 0.1s,
      box-shadow 0.1s;
  }

  .pik-btn-brutal:hover {
    transform: translate(3px, 3px);
    box-shadow: 2px 2px 0px var(--pik-purple);
    background-color: #ff3333;
    color: #fff;
  }

  .donald-brutal-img {
    width: 100%;
    max-height: 250px;
    object-fit: contain;
    filter: drop-shadow(4px 4px 0px var(--pik-purple));
  }

  /* Portal Grid */
  .portal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2.5rem;
  }

  .portal-card {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card-icon {
    font-size: 3rem;
    margin-bottom: 1.5rem;
  }

  .portal-card h3 {
    font-size: 1.6rem;
    color: #fff;
    margin-bottom: 1rem;
  }

  .portal-card p {
    font-size: 1.05rem;
    color: var(--pik-text-muted);
    line-height: 1.5;
    flex-grow: 1;
    margin-bottom: 1.5rem;
  }

  .card-footer {
    border-top: 1px solid rgba(87, 0, 87, 0.3);
    padding-top: 1rem;
  }

  .card-link {
    font-weight: 700;
    color: var(--pik-red);
    text-decoration: none;
    transition:
      color 0.2s ease,
      padding-left 0.2s ease;
    display: inline-block;
  }

  .card-link:hover {
    color: #fff;
    padding-left: 5px;
  }

  /* Responsive styling */
  @media (max-width: 992px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }

    .hero-description {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .brutal-body {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .donald-brutal-img {
      max-height: 180px;
      margin-top: 1.5rem;
    }
  }
</style>
