<section class="cta-section">
  <div class="cta-content brutal-card">
    <h2>BERAZ, EKARRI ESKU-DIRUA!</h2>
    <p>
      Lagundu gure eredua borrokatzen. Kutxazainera pasa lehenago eta etorri
      gurekin txosnan gozatzera.
    </p>
  </div>
</section>

<style>
  .cta-section {
    padding: 6rem 2rem;
    background-color: var(--bg-color);
    display: flex;
    justify-content: center;
    align-items: center;
    border-bottom: var(--brutal-border);
  }

  .cta-content {
    text-align: center;
    max-width: 800px;
    background-color: var(--text-color);
    color: var(--bg-color);
    padding: 3rem 2rem;
    border-color: var(--accent-purple);
    box-shadow: 12px 12px 0px var(--accent-yellow);
    transform: rotate(-1deg);
  }

  h2 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--accent-red);
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  p {
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    font-family: var(--font-body);
    font-weight: 700;
  }
</style>
