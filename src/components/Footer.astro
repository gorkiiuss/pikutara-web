---

<footer
  class="main-footer"
  style="background-color: var(--bg-color); color: var(--text-color); border-top: 8px solid var(--accent-red); padding-bottom: 3rem;"
>
  <div
    class="footer-content"
    style="padding: 2rem 1rem; display: flex; flex-direction: column; align-items: center; gap: 1.5rem; max-width: 1200px; margin: 0 auto;"
  >
    <!-- Section Title -->
    <div
      style="font-family: var(--font-heading); font-size: 1.1rem; color: var(--accent-yellow); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 0.5rem;"
    >
      Manifestuaren sinatzaileak:
    </div>

    <!-- Cards Flex Container -->
    <div
      style="display: flex; flex-wrap: wrap; justify-content: center; gap: 1.2rem; width: 100%;"
    >
      <!-- Pikutara Card -->
      <div
        class="foot-card pikutara-card-style"
        style="width: 200px; height: 110px; display: flex; flex-direction: column; align-items: center; justify-content: space-between; padding: 0.6rem; border: 3px solid var(--accent-red); background: #1a1a1a; box-shadow: 4px 4px 0px var(--accent-yellow); transform: rotate(-2deg); transition: transform 0.2s, box-shadow 0.2s;"
      >
        <img
          src="/assets/konpartsa_piktograma.svg"
          alt="Pikutara"
          style="height: 2.3rem; width: auto;"
        />
        <a
          href="https://www.instagram.com/pikutaragztkn"
          target="_blank"
          rel="noopener noreferrer"
          class="foot-social-link"
          style="font-family: var(--font-body); font-size: 0.72rem; color: var(--text-color); text-decoration: none; font-weight: 700; border-top: 1px dashed var(--accent-red); width: 100%; text-align: center; padding-top: 0.4rem;"
        >
          @pikutaragztkn
        </a>
      </div>

      <!-- Txabarri Card -->
      <div
        class="foot-card txabarri-card-style"
        style="width: 200px; height: 110px; display: flex; flex-direction: column; align-items: center; justify-content: space-between; padding: 0.6rem; border: 3px solid var(--accent-purple); background: #1a1a1a; box-shadow: 4px 4px 0px var(--accent-red); transform: rotate(1.5deg); transition: transform 0.2s, box-shadow 0.2s;"
      >
        <img
          src="/assets/txabarri_elkarlanean.svg"
          alt="Txabarri Elkarlanean"
          style="height: 2.3rem; width: auto;"
        />
        <a
          href="https://www.instagram.com/txabarrielkarlanean"
          target="_blank"
          rel="noopener noreferrer"
          class="foot-social-link"
          style="font-family: var(--font-body); font-size: 0.72rem; color: var(--text-color); text-decoration: none; font-weight: 700; border-top: 1px dashed var(--accent-purple); width: 100%; text-align: center; padding-top: 0.4rem;"
        >
          @txabarrielkarlanean
        </a>
      </div>

      <!-- Txorromorro Card -->
      <div
        class="foot-card txorromorro-card-style"
        style="width: 200px; height: 110px; display: flex; flex-direction: column; align-items: center; justify-content: space-between; padding: 0.6rem; border: 3px solid var(--accent-yellow); background: #1a1a1a; box-shadow: 4px 4px 0px var(--accent-purple); transform: rotate(-1deg); transition: transform 0.2s, box-shadow 0.2s;"
      >
        <img
          src="/assets/txorromorro.svg"
          alt="Txorromorro"
          style="height: 2.3rem; width: auto;"
        />
        <a
          href="https://www.instagram.com/askatasunahelburu"
          target="_blank"
          rel="noopener noreferrer"
          class="foot-social-link"
          style="font-family: var(--font-body); font-size: 0.72rem; color: var(--text-color); text-decoration: none; font-weight: 700; border-top: 1px dashed var(--accent-yellow); width: 100%; text-align: center; padding-top: 0.4rem;"
        >
          @askatasunahelburu
        </a>
      </div>

      <!-- Mendieta Card -->
      <div
        class="foot-card mendieta-card-style"
        style="width: 200px; height: 110px; display: flex; flex-direction: column; align-items: center; justify-content: space-between; padding: 0.6rem; border: 3px solid var(--text-color); background: #1a1a1a; box-shadow: 4px 4px 0px var(--accent-red); transform: rotate(2.5deg); transition: transform 0.2s, box-shadow 0.2s;"
      >
        <img
          src="/assets/mendieta.svg"
          alt="Mendieta"
          style="height: 1.5rem; width: auto; max-width: 90%;"
        />
        <a
          href="https://www.instagram.com/mendietakulturelkartea"
          target="_blank"
          rel="noopener noreferrer"
          class="foot-social-link"
          style="font-family: var(--font-body); font-size: 0.68rem; color: var(--text-color); text-decoration: none; font-weight: 700; border-top: 1px dashed var(--text-color); width: 100%; text-align: center; padding-top: 0.4rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"
        >
          @mendietakulturelkartea
        </a>
      </div>
    </div>
  </div>

  <!-- Marquee -->
  <div class="marquee">
    <div class="marquee-content">
      <span>EZ DUGU TXARTELARIK ONARTZEN!</span>
      <span>•</span>
      <span>ESKU-DIRUA BAKARRIK</span>
      <span>•</span>
      <span>AEBren INPERIALISMOA GELDITU!</span>
      <span>•</span>
      <span>EZ DUGU TXARTELARIK ONARTZEN!</span>
      <span>•</span>
      <span>ESKU-DIRUA BAKARRIK</span>
      <span>•</span>
      <span>AEBren INPERIALISMOA GELDITU!</span>
      <span>•</span>
      <span>EZ DUGU TXARTELARIK ONARTZEN!</span>
    </div>
  </div>
</footer>

<style>
  /* Interactions and fallbacks via CSS classes */
  .foot-card:hover {
    transform: scale(1.05) rotate(0deg) !important;
  }

  .pikutara-card-style:hover {
    box-shadow: 6px 6px 0px var(--accent-purple) !important;
  }

  .txabarri-card-style:hover {
    box-shadow: 6px 6px 0px var(--accent-yellow) !important;
  }

  .txorromorro-card-style:hover {
    box-shadow: 6px 6px 0px var(--accent-red) !important;
  }

  .mendieta-card-style:hover {
    box-shadow: 6px 6px 0px var(--accent-purple) !important;
  }

  .foot-social-link {
    transition: color 0.15s ease;
  }

  .foot-social-link:hover {
    color: var(--accent-yellow) !important;
  }

  .txorromorro-card-style .foot-social-link:hover {
    color: var(--accent-purple) !important;
  }

  .marquee {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background-color: var(--accent-yellow);
    color: var(--bg-color);
    padding: 0.5rem 0;
    overflow: hidden;
    white-space: nowrap;
    border-top: 4px solid var(--bg-color);
    font-family: var(--font-heading);
    font-size: 1.5rem;
  }

  .marquee-content {
    display: inline-block;
    animation: marquee 20s linear infinite;
  }

  .marquee-content span {
    margin: 0 2rem;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 768px) {
    .marquee {
      font-size: 1.2rem;
    }
  }
</style>
