// PUT /api/admin/settings
app.put('/api/admin/settings', authMiddleware, async (req, res) => {
  try {
    const newSettings = req.body;
    if (!newSettings) {
      return res.status(400).json({ error: 'Ezarpenak falta dira.' });
    }

    db.serialize(() => {
      const stmt = db.prepare("INSERT OR REPLACE INTO algorithm_settings (key, value) VALUES (?, ?)");
      if (Array.isArray(newSettings)) {
        newSettings.forEach(s => {
          if (s.key && s.value !== undefined) {
            stmt.run(s.key, String(s.value));
          }
        });
      } else {
        Object.entries(newSettings).forEach(([key, value]) => {
          stmt.run(key, String(value));
        });
      }
      stmt.finalize((err) => {
        if (err) {
          console.error("Error saving settings:", err);
          return res.status(500).json({ error: 'Errorea ezarpenak gordetzean.' });
        }
        res.json({ success: true });
      });
    });
  } catch (error) {
    console.error("Error updating algorithm settings:", error);
    res.status(500).json({ error: 'Errorea ezarpenak eguneratzean.' });
  }
});

