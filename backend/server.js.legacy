// Tinder Musikal: Get pending songs (ordered by algorithm)
app.get('/api/admin/songs/pending', authMiddleware, async (req, res) => {
  try {
    const [songs, artistGenders, settingsRows, statsData, mappingsMap, genreHierarchy] = await Promise.all([
      query("SELECT * FROM songs WHERE status = 'pending' AND genres != '[]' AND genres != '' AND genres IS NOT NULL"),
      query("SELECT artist, gender_type FROM artist_genders"),
      query("SELECT key, value FROM algorithm_settings"),
      getStatsData(),
      loadTagMappingsMap(),
      query("SELECT genre, parent_genre FROM genre_hierarchy")
    ]);

    const settings = {};
    settingsRows.forEach(s => settings[s.key] = parseFloat(s.value));

    const defaultWeights = {
      weight_lang_eu: 2.5,
      weight_lang_gl: 1.5,
      weight_lang_ca: 1.5,
      weight_lang_en: 1.0,
      weight_lang_es: 0.25,
      weight_lang_instrumental: 0.8,
      weight_lang_unknown: 1.0,
      weight_gender_female: 2.5,
      weight_gender_trans_female: 3.0,
      weight_gender_non_binary: 2.5,
      weight_gender_female_group: 2.5,
      weight_gender_dissident_group: 3.0,
      weight_gender_mixed_group: 1.5,
      weight_gender_male: 0.5,
      weight_gender_male_group: 0.5,
      weight_gender_unknown: 1.0,
      weight_rarity_factor: 1.0,
      weight_age_boost: 0.05
    };

    const getWeight = (key) => {
      return settings[key] !== undefined ? settings[key] : (defaultWeights[key] || 1.0);
    };

    const artistGenderMap = new Map();
    artistGenders.forEach(ag => {
      if (ag.artist) {
        artistGenderMap.set(ag.artist.toLowerCase().trim(), ag.gender_type);
      }
    });

    const hierarchyMap = new Map();
    genreHierarchy.forEach(h => {
      hierarchyMap.set(h.genre.trim().toLowerCase(), h.parent_genre.trim());
    });

    function getRootParentGenre(genre) {
      let current = genre.trim();
      let depth = 0;
      const maxDepth = 10;
      while (hierarchyMap.has(current.toLowerCase()) && depth < maxDepth) {
        current = hierarchyMap.get(current.toLowerCase()).trim();
        depth++;
      }
      return current;
    }

    const N = Math.max(1, statsData.songsCount);
    const currentTime = Date.now();

    songs.forEach(s => {
      // Parse list fields
      s.genres = applyTagMappings(safeParseArray(s.genres), mappingsMap);
      s.proposed_titles = safeParseArray(s.proposed_titles);
      s.proposed_artists = safeParseArray(s.proposed_artists);
      s.submitters = safeParseArray(s.submitters);
      s.comments = safeParseArray(s.comments);
      s.ips = safeParseArray(s.ips);

      // 1. Genre Rarity Score
      let rarityScore = 0;
      if (s.genres.length > 0) {
        let totalRarity = 0;
        s.genres.forEach(g => {
          const specificCount = statsData.counts[g] || 0.1;
          const rootGen = getRootParentGenre(g);
          const parentCount = statsData.parentCounts[rootGen] || statsData.counts[rootGen] || 0.1;
          
          let rarity = (specificCount <= 0.1 || parentCount <= 0.1) ? 9999 : (N / parentCount) * (N / specificCount);
          totalRarity += rarity;
        });
        rarityScore = totalRarity / s.genres.length;
      }
      const baseScore = 1.0 + (rarityScore - 1.0) * getWeight('weight_rarity_factor');

      // 2. Language Multiplier
      const songLangs = safeParseArray(s.language);
      let langMult = 1.0;
      if (songLangs.length > 0) {
        const weights = songLangs.map(l => getWeight(`weight_lang_${l}`));
        langMult = Math.max(...weights);
      } else {
        langMult = getWeight('weight_lang_unknown');
      }

      // 3. Gender Multiplier
      const songArtists = splitArtists(s.real_artist);
      let genderMult = 1.0;
      if (songArtists.length > 0) {
        const weights = songArtists.map(a => {
          const type = artistGenderMap.get(a.toLowerCase().trim()) || 'unknown';
          return getWeight(`weight_gender_${type}`);
        });
        genderMult = Math.max(...weights);
      } else {
        genderMult = getWeight('weight_gender_unknown');
      }

      // 4. Age Boost (avoid starvation)
      const createdTime = s.created_at ? new Date(s.created_at).getTime() : currentTime;
      const ageInMs = Math.max(0, currentTime - createdTime);
      const ageInDays = ageInMs / (1000 * 60 * 60 * 24);
      const ageBoost = ageInDays * getWeight('weight_age_boost');

      s._priorityScore = (baseScore * langMult * genderMult) + ageBoost;
    });

    // Sort descending by calculated priority score
    songs.sort((a, b) => b._priorityScore - a._priorityScore);

    res.json(songs);
  } catch (error) {
    console.error("Error fetching and scoring pending songs:", error);
    res.status(500).json({ error: 'Errorea kantuak lortzean eta sailkatzean' });
  }
});

