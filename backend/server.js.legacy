// Helper para separar múltiples artistas en un array limpio
function splitArtists(artistString) {
  if (!artistString || artistString === 'Ezezaguna') return [];
  // Separa por: coma, &, +, y, ft., feat. (insensible a mayúsculas)
  return artistString.split(/\s*(?:,|&|\+|\by\b|\bft\.?\b|\bfeat\.?\b)\s*/i)
    .map(a => a.trim())
    .filter(a => a.length > 0);
}

function safeParseArray(jsonStr) {
  try {
    const parsed = JSON.parse(jsonStr);
    return Array.isArray(parsed) ? parsed : [];
  } catch (e) {
    return [];
  }
}

async function loadTagMappingsMap() {
  try {
    const mappings = await query('SELECT original_tag, canonical_tag FROM tag_mappings');
    const mappingsMap = new Map();
    mappings.forEach(m => {
      mappingsMap.set(m.original_tag.trim().toLowerCase(), m.canonical_tag.trim());
    });
    return mappingsMap;
  } catch (e) {
    console.error("Error loading tag mappings:", e);
    return new Map();
  }
}

function applyTagMappings(genres, mappingsMap) {
  if (!Array.isArray(genres)) return [];
  const mapped = genres.map(g => {
    if (typeof g !== 'string') return g;
    const trimmed = g.trim();
    const lower = trimmed.toLowerCase();
    if (mappingsMap && mappingsMap.has(lower)) {
      return mappingsMap.get(lower);
    }
    return trimmed;
  }).filter(Boolean);

  // Remove duplicates and preserve case
  const seen = new Set();
  const unique = [];
  mapped.forEach(g => {
    const lower = g.toLowerCase();
    if (!seen.has(lower)) {
      seen.add(lower);
      unique.push(g);
    }
  });
  return unique;
}

