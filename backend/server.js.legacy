app.get('/api/spotify-metadata', async (req, res) => {
  try {
    const { url } = req.query;
    if (!url) return res.status(400).json({ error: 'URL falta da.' });

    let title = '';
    let artist = '';
    let thumbnail_url = '';
    let preview_url = '';

    // 1. Try parsing Embed page HTML for __NEXT_DATA__
    const trackIdMatch = url.match(/\/track\/([^/?#]+)/);
    if (trackIdMatch) {
      const trackId = trackIdMatch[1];
      try {
        const embedUrl = `https://open.spotify.com/embed/track/${trackId}`;
        const embedRes = await fetch(embedUrl, {
          headers: {
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/110.0.0.0 Safari/537.36',
            'Accept-Language': 'en-US,en;q=0.9'
          }
        });
        if (embedRes.ok) {
          const html = await embedRes.text();
          const nextDataMatch = html.match(/<script id="__NEXT_DATA__" type="application\/json">([\s\S]*?)<\/script>/);
          if (nextDataMatch) {
            const data = JSON.parse(nextDataMatch[1]);
            const entity = data.props?.pageProps?.state?.data?.entity;
            if (entity) {
              title = entity.name || entity.title || '';
              artist = entity.artists ? entity.artists.map(a => a.name).join(', ') : '';
              preview_url = entity.audioPreview?.url || '';

              const images = entity.visualIdentity?.image || [];
              if (images.length > 0) {
                const bestImage = images.find(img => img.maxWidth === 640) || images[0];
                thumbnail_url = bestImage.url || '';
              }
            }
          }
        }
      } catch (embedErr) {
        console.error("Error scraping Spotify embed in api metadata:", embedErr);
      }
    }

    // 2. Fallback to oEmbed + scrape if main fields are missing
    if (!title || !artist) {
      try {
        const oEmbedUrl = `https://open.spotify.com/oembed?url=${encodeURIComponent(url)}`;
        const response = await fetch(oEmbedUrl);
        if (response.ok) {
          const data = await response.json();
          title = title || data.title || '';
          thumbnail_url = thumbnail_url || data.thumbnail_url || '';
        }

        const htmlRes = await fetch(url, {
          headers: {
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/110.0.0.0 Safari/537.36',
            'Accept-Language': 'eu,es;q=0.9,en;q=0.8'
          }
        });
        if (htmlRes.ok) {
          const html = await htmlRes.text();
          const twitterMatch = html.match(/<meta name="twitter:description" content="([^"·]+) ·/);
          if (twitterMatch) {
            artist = artist || twitterMatch[1].trim();
          } else {
            const musicianMatch = html.match(/<meta name="music:musician_description" content="([^"]+)"/);
            if (musicianMatch) {
              artist = artist || musicianMatch[1].trim();
            } else {
              const descMatch = html.match(/Song · ([^·]+) ·/);
              if (descMatch) {
                artist = artist || descMatch[1].trim();
              }
            }
          }
        }
      } catch (fbErr) {
        console.error("Error in Spotify metadata fallback:", fbErr);
      }
    }

    res.json({
      thumbnail_url,
      title,
      artist,
      preview_url
    });
  } catch (error) {
    console.error('Error fetching Spotify metadata:', error);
    res.status(500).json({ error: 'Errorea zerbitzarian.' });
  }
});



// ==========================================
// LAST.FM GENRE AUTO-RESOLVER (MUZPESIL)
// ==========================================

function generateSearchQueries(title) {
  const queries = new Set();
  const rawTitle = title;

  // Clean junk text (official, visualizer, live, etc.)
  const junkRegex = /(official video|videoclip|visualizer|lyric video|official music video|video oficial|oficial video|bideoa|bideoklipa|bideoklip ofiziala|lyric|audio|hd|4k|remastered)/gi;
  const cleanTitle = rawTitle.replace(junkRegex, "").trim();
  if (cleanTitle) queries.add(cleanTitle);

  // Remove brackets content
  const noBrackets = cleanTitle.replace(/[\(\[【].*?[\)\]】]/g, "").trim();
  if (noBrackets.length > 3) queries.add(noBrackets);

  // Split by separators
  const chunks = cleanTitle.split(/[-|/:~]+/);
  chunks.forEach(chunk => {
    const trimmed = chunk.trim();
    if (trimmed.length > 3 && !["remix", "feat", "ft", "prod"].includes(trimmed.toLowerCase())) {
      queries.add(trimmed);
    }
  });

  return Array.from(queries).sort((a, b) => b.length - a.length);
}

async function resolveSongGenres(title, artist) {
  const queries = generateSearchQueries(title);
  const apiKey = '00fd0a69ecb0b8da72beae351a1268ad';

  let bestMatch = null;
  for (const query of queries) {
    try {
      // Use both track and artist params for better accuracy
      let searchUrl = `https://ws.audioscrobbler.com/2.0/?method=track.search&track=${encodeURIComponent(query)}&api_key=${apiKey}&format=json&limit=1`;
      if (artist && artist !== 'Ezezaguna') {
        searchUrl += `&artist=${encodeURIComponent(artist.trim())}`;
      }

      const res = await fetch(searchUrl);
      const data = await res.json();
      const tracks = data.results?.trackmatches?.track;
      if (tracks) {
        const trackArray = Array.isArray(tracks) ? tracks : [tracks];
        if (trackArray.length > 0) {
          bestMatch = trackArray[0];
          break;
        }
      }
    } catch (e) {
      console.error("Last.fm search error for query", query, ":", e);
    }
  }

  // Fallback: If no match with artist, try just the track
  if (!bestMatch && artist && artist !== 'Ezezaguna') {
    for (const query of queries) {
      try {
        const searchUrl = `https://ws.audioscrobbler.com/2.0/?method=track.search&track=${encodeURIComponent(query)}&api_key=${apiKey}&format=json&limit=1`;
        const res = await fetch(searchUrl);
        const data = await res.json();
        const tracks = data.results?.trackmatches?.track;
        if (tracks) {
          const trackArray = Array.isArray(tracks) ? tracks : [tracks];
          if (trackArray.length > 0) {
            bestMatch = trackArray[0];
            break;
          }
        }
      } catch (e) {
        console.error("Last.fm fallback search error for query", query, ":", e);
      }
    }
  }

  if (!bestMatch) return [];

  const extractTagNames = (toptags) => {
    if (!toptags || !toptags.tag) return [];
    const tags = Array.isArray(toptags.tag) ? toptags.tag : [toptags.tag];
    return tags.slice(0, 5).map(t => t.name.trim());
  };

  let tags = [];
  const originalArtist = bestMatch.artist.trim();
  try {
    const trackTagsUrl = `https://ws.audioscrobbler.com/2.0/?method=track.gettoptags&artist=${encodeURIComponent(originalArtist)}&track=${encodeURIComponent(bestMatch.name)}&api_key=${apiKey}&format=json`;
    const res = await fetch(trackTagsUrl);
    const data = await res.json();
    tags = extractTagNames(data.toptags);
  } catch (e) {
    console.error("Error fetching track tags (unsplit):", e);
  }

  if (tags.length === 0) {
    try {
      const artistTagsUrl = `https://ws.audioscrobbler.com/2.0/?method=artist.gettoptags&artist=${encodeURIComponent(originalArtist)}&api_key=${apiKey}&format=json`;
      const res = await fetch(artistTagsUrl);
      const data = await res.json();
      tags = extractTagNames(data.toptags);
    } catch (e) {
      console.error("Error fetching artist tags (unsplit):", e);
    }
  }

  // Fallback: If still no tags found, try by splitting collaborators (feat, &, and, etc.)
  if (tags.length === 0) {
    const queryArtist = originalArtist.split(/[,&]|\b(?:feat|ft|and|y|with)\b/i)[0].trim();
    if (queryArtist !== originalArtist) {
      try {
        const trackTagsUrl = `https://ws.audioscrobbler.com/2.0/?method=track.gettoptags&artist=${encodeURIComponent(queryArtist)}&track=${encodeURIComponent(bestMatch.name)}&api_key=${apiKey}&format=json`;
        const res = await fetch(trackTagsUrl);
        const data = await res.json();
        tags = extractTagNames(data.toptags);
      } catch (e) {
        console.error("Error fetching track tags (split):", e);
      }

      if (tags.length === 0) {
        try {
          const artistTagsUrl = `https://ws.audioscrobbler.com/2.0/?method=artist.gettoptags&artist=${encodeURIComponent(queryArtist)}&api_key=${apiKey}&format=json`;
          const res = await fetch(artistTagsUrl);
          const data = await res.json();
          tags = extractTagNames(data.toptags);
        } catch (e) {
          console.error("Error fetching artist tags (split):", e);
        }
      }
    }
  }

  const artistList = splitArtists(artist);
  if (artistList.length > 0) {
    try {
      let combinedGenres = new Set();
      let foundAny = false;

      for (const a of artistList) {
        const localCache = await get("SELECT genres FROM artist_genres WHERE LOWER(artist) = LOWER(?)", [a.trim()]);
        if (localCache && localCache.genres) {
          const parsedCache = JSON.parse(localCache.genres);
          if (Array.isArray(parsedCache) && parsedCache.length > 0) {
            console.log(`[Cache Match] "${a}" taldearen generoak gure datu-basetik zuzenean berreskuratu dira! ✅`);
            parsedCache.forEach(g => combinedGenres.add(g));
            foundAny = true;
          }
        }
      }

      if (foundAny) {
        console.log(`[Cache Match] "${artist}" artisten generoak gure datu-basetik zuzenean berreskuratu dira! ✅`);
        const garbageRows = await query("SELECT tag FROM garbage_tags");
        const garbageSet = new Set(garbageRows.map(r => r.tag.toLowerCase()));
        return Array.from(combinedGenres).filter(t => !garbageSet.has(t.toLowerCase()));
      }
    } catch (cacheErr) {
      console.error("Error reading artist_genres local cache:", cacheErr);
    }
  }

  const formattedTags = tags.map(t =>
    t.split(' ')
      .map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase())
      .join(' ')
  );

  try {
    const garbageRows = await query("SELECT tag FROM garbage_tags");
    const garbageSet = new Set(garbageRows.map(r => r.tag.toLowerCase()));
    return formattedTags.filter(t => !garbageSet.has(t.toLowerCase()));
  } catch (e) {
    console.error("Error reading garbage tags:", e);
    return formattedTags;
  }
}

// ==========================================
// AUTOMATIC LANGUAGE DETECTOR (STOPWORDS)
// ==========================================
// Helper functions to clean artist and track names for search
function cleanArtistForSearch(artist) {
  if (!artist) return '';
  // Split by feat, ft, &, and, with, vs, y, etc. and take the first one
  let clean = artist.split(/\s*(?:feat\.?|ft\.?|&|\band\b|with|vs|y|,)\s*/i)[0];
  return clean.trim();
}

function cleanTrackForSearch(track) {
  if (!track) return '';
  let clean = track;
  // Remove (feat...) or [feat...]
  clean = clean.replace(/\s*[([].*?(?:feat|ft|with|prod|edit|remix|version|live).*?[)]]/gi, '');
  // Remove " - Remix", " - Live", etc.
  clean = clean.replace(/\s*-\s*(?:remix|live|edit|radio|acoustic|version|cover).*$/i, '');
  // Remove trailing dashes or extra spaces
  clean = clean.replace(/\s*-\s*$/, '');
  return clean.trim() || track;
}

function detectSongLanguage(text) {
  if (!text || text.trim().length === 0) return ['unknown'];

  // Normalize text: lowercase and remove accents/diacritics for stopword matching
  const normalize = (str) => {
    return str
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '') // remove diacritics
      .toLowerCase()
      .replace(/[.,\/#!$%\^&\*;:{}=\-_`~()?"'\n\r]/g, " ");
  };

  const cleanText = normalize(text);
  const words = cleanText.split(/\s+/).filter(w => w.length > 0);
  
  if (words.length === 0) return ['unknown'];

  const stopwords = {
    eu: ['eta', 'ez', 'du', 'ere', 'bat', 'dira', 'zait', 'zen', 'naiz', 'duzu', 'baino', 'nire', 'zure', 'dago', 'dute', 'ditut', 'dela', 'edo', 'arte', 'izan', 'nahi', 'hori', 'hau'],
    es: ['el', 'la', 'en', 'los', 'las', 'un', 'una', 'del', 'al', 'por', 'para', 'con', 'se', 'mi', 'tu', 'su', 'yo', 'te', 'me', 'lo', 'nosotros', 'ellos', 'ella', 'ellas', 'muy', 'bien', 'todo', 'todos', 'esta', 'este', 'esto', 'siempre', 'ahora', 'cuando', 'tengo', 'tienes', 'tiene'],
    ca: ['els', 'les', 'amb', 'perque', 'teu', 'seva', 'meu', 'meva', 'teva', 'seves', 'meus', 'teus', 'seus', 'això', 'diferent', 'segons', 'aquest', 'aquesta', 'aquells', 'aquelles', 'molt', 'molts', 'sense', 'sobre', 'també', 'mateix', 'mateixa', 'començar'],
    en: ['the', 'and', 'you', 'to', 'of', 'that', 'it', 'was', 'for', 'on', 'are', 'with', 'they', 'have', 'this', 'from', 'but', 'not'],
    gl: ['non', 'unha', 'mais', 'polo', 'pola', 'polos', 'polas', 'na', 'nas', 'nos', 'dun', 'dunha', 'duns', 'dunhas', 'co', 'ca', 'cos', 'cas', 'tamén', 'cando', 'onde', 'mentres', 'oxalá', 'grazas', 'onte', 'hoxe', 'aquí', 'alí']
  };

  const scores = { eu: 0, es: 0, ca: 0, en: 0, gl: 0 };

  for (const word of words) {
    if (stopwords.eu.includes(word)) scores.eu++;
    if (stopwords.es.includes(word)) scores.es++;
    if (stopwords.ca.includes(word)) scores.ca++;
    if (stopwords.en.includes(word)) scores.en++;
    if (stopwords.gl.includes(word)) scores.gl++;
  }

  // Adjustments/disambiguation for Catalan and Galician/Spanish/Portuguese overlaps
  if (words.includes('i') && scores.ca > 0) {
    scores.ca += 2;
  }
  if (words.includes('non') || words.includes('unha') || words.includes('mais') || words.includes('tamén')) {
    scores.gl += 2;
  }

  const sorted = Object.entries(scores).sort((a, b) => b[1] - a[1]);
  
  if (sorted[0][1] < 2) return ['unknown'];

  const detected = [sorted[0][0]];
  const secondary = sorted[1];
  if (secondary && secondary[1] >= 3 && (secondary[1] / sorted[0][1]) > 0.35) {
    detected.push(secondary[0]);
  }

  return detected;
}

// Background resolver for lyrics and language with multiple fallback search methods
async function autoResolveLyricsAndLanguage(songId, title, artist) {
  try {
    const cleanTitle = cleanTrackForSearch(title);
    const cleanArtist = cleanArtistForSearch(artist);
    
    // Define queries to try in order
    const queries = [
      // 1. Structured search with original title and artist
      { type: 'structured_original', url: `https://lrclib.net/api/search?track_name=${encodeURIComponent(title)}&artist_name=${encodeURIComponent(artist)}` },
      // 2. Structured search with cleaned title and cleaned artist
      { type: 'structured_clean', url: `https://lrclib.net/api/search?track_name=${encodeURIComponent(cleanTitle)}&artist_name=${encodeURIComponent(cleanArtist)}` },
      // 3. Simple query search with Cleaned Artist + Cleaned Title
      { type: 'query_clean', url: `https://lrclib.net/api/search?q=${encodeURIComponent(cleanArtist + ' ' + cleanTitle)}` },
      // 4. Simple query search with Original Artist + Original Title
      { type: 'query_original', url: `https://lrclib.net/api/search?q=${encodeURIComponent(artist + ' ' + title)}` }
    ];

    // Deduplicate queries to avoid redundant slow requests
    const uniqueQueries = [];
    const seenUrls = new Set();
    for (const q of queries) {
      if (!seenUrls.has(q.url)) {
        seenUrls.add(q.url);
        uniqueQueries.push(q);
      }
    }

    let lyricsText = null;

    for (const q of uniqueQueries) {
      try {
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), 12000); // 12 seconds timeout per attempt

        const res = await fetch(q.url, {
          signal: controller.signal,
          headers: {
            'User-Agent': 'Pikutara-TinderMusikal/1.0 (https://github.com/txartelari)'
          }
        });
        clearTimeout(timeoutId);

        if (res.ok) {
          const data = await res.json();
          if (data && data.length > 0) {
            for (const item of data) {
              if (item.plainLyrics || item.syncedLyrics) {
                lyricsText = item.plainLyrics || item.syncedLyrics;
                break;
              }
            }
          }
        }
      } catch (e) {
        console.error(`[Auto Resolve Lyrics] Attempt ${q.type} failed for "${title}" - "${artist}":`, e.message);
      }
      if (lyricsText) break;
      // Small delay between fetches to avoid rate limiting
    }

    if (!lyricsText) {
      const ovhQueries = [
        { type: 'ovh_original', url: `https://api.lyrics.ovh/v1/${encodeURIComponent(artist)}/${encodeURIComponent(title)}` },
        { type: 'ovh_clean', url: `https://api.lyrics.ovh/v1/${encodeURIComponent(cleanArtist)}/${encodeURIComponent(cleanTitle)}` }
      ];
      for (const q of ovhQueries) {
        try {
          const controller = new AbortController();
          const timeoutId = setTimeout(() => controller.abort(), 8000);
          const res = await fetch(q.url, {
            signal: controller.signal,
            headers: { 'User-Agent': 'Pikutara-TinderMusikal/1.0' }
          });
          clearTimeout(timeoutId);
          if (res.ok) {
            const data = await res.json();
            if (data && data.lyrics) {
              lyricsText = data.lyrics;
              console.log(`[Auto Resolve] Found lyrics via lyrics.ovh for "${title}" - "${artist}"`);
              break;
            }
          }
        } catch (e) {
          // ignore
        }
        await new Promise(r => setTimeout(r, 200));
      }
    }

    let detectedLang = ['unknown'];
    if (lyricsText) {
      detectedLang = detectSongLanguage(lyricsText);
      await run("UPDATE songs SET lyrics = ?, language = ? WHERE id = ?", [
        lyricsText,
        JSON.stringify(detectedLang),
        songId
      ]);
      console.log(`[Auto Resolve] Song ID ${songId} lyrics found, language detected as [${detectedLang.join(', ')}]`);
    } else {
      // Heuristic guess for instrumentals
      const lowerTitle = title.toLowerCase();
      const lowerArtist = artist.toLowerCase();
      if (lowerTitle.includes('remix') || lowerTitle.includes('edit') || lowerArtist.includes('dj')) {
        detectedLang = ['instrumental'];
      }
      await run("UPDATE songs SET language = ? WHERE id = ?", [
        JSON.stringify(detectedLang),
        songId
      ]);
      console.log(`[Auto Resolve] Song ID ${songId} no lyrics, resolved language as [${detectedLang.join(', ')}]`);
    }
  } catch (err) {
    console.error(`Error resolving language for Song ID ${songId}:`, err.message);
  }
}

// Background resolver for artist gender (from Wikidata)
// A list of common group subclass item IDs on Wikidata
const GROUP_CLASS_IDS = new Set([
  'Q482994',    // musical group
  'Q215380',    // band
  'Q2088357',   // musical ensemble
  'Q105740417', // all-female band
  'Q115740417', // all-female group
  'Q1782294',   // duettist
  'Q106855146'  // musical duo
]);

// Helper: Guess gender from first name of an artist using a common name database
function guessGenderFromFirstName(name) {
  if (!name) return null;
  const parts = name.trim().split(/\s+/);
  const firstName = parts[0].toLowerCase();
  
  const femaleNames = new Set([
    'josune', 'ainhoa', 'maite', 'nerea', 'izaro', 'irati', 'ane', 'uxue', 'leire', 
    'olaia', 'oihana', 'amaia', 'miren', 'itziar', 'garazi', 'itsaso', 'june', 
    'malen', 'maddi', 'nahia', 'saioa', 'eneritz', 'sarai', 'esti', 'estibaliz', 
    'nagore', 'haizea', 'yaiza', 'paula', 'maria', 'laura', 'marta', 'sara', 
    'andrea', 'ana', 'sofia', 'elena', 'lucia', 'carmen', 'silvia', 'bea', 
    'beatriz', 'clara', 'natalia', 'julia', 'alba', 'laida', 'nekane', 'nora', 
    'idurre', 'alaitz', 'irati', 'araia', 'elixabete', 'elena', 'lola', 'emilia', 
    'luna', 'alba', 'rosalia', 'rozalen', 'zuriñe', 'amaia', 'oihana', 'izaskun', 
    'itziar', 'arantza', 'arantxa', 'jone', 'karmele', 'edurne', 'sara', 'irene', 
    'cristina', 'sandra', 'raquel', 'silvia', 'patricia', 'mónica', 'monica', 
    'alicia', 'pilar', 'dolores', 'teresa', 'isabel', 'angela', 'belen', 'conchi', 
    'lourdes', 'gema', 'yolanda', 'susana', 'eva', 'marta', 'olga', 'esther', 
    'sonia', 'rocio', 'mercedes', 'carmen', 'ana', 'maria', 'josefa', 'francisca'
  ]);
  
  const maleNames = new Set([
    'aitor', 'asier', 'xabier', 'iker', 'gorka', 'ander', 'jon', 'julen', 'eneko', 
    'oier', 'beñat', 'unai', 'mikel', 'ibai', 'markel', 'koldo', 'haritz', 'kepa', 
    'gaizka', 'igor', 'jokin', 'egoitz', 'andoni', 'jose', 'juan', 'carlos', 
    'david', 'pablo', 'javi', 'javier', 'alex', 'alejandro', 'marc', 'joan', 
    'jordi', 'gerard', 'pau', 'joseba', 'imanol', 'txomin', 'peio', 'peru', 
    'gotzon', 'arkaitz', 'ekaitz', 'urgi', 'oihan', 'manex', 'adan', 'alvaro', 
    'antonio', 'manuel', 'francisco', 'carlos', 'luis', 'miguel', 'angel', 
    'fernando', 'daniel', 'pedro', 'raúl', 'raul', 'enrique', 'alberto', 
    'roberto', 'ramón', 'ramon', 'vicente', 'diego', 'rubén', 'ruben', 'adrian', 
    'sergio', 'jorge', 'marcos', 'ignacio', 'oscar', 'eduardo', 'victor', 
    'felipe', 'albert', 'toni', 'manolo', 'paco', 'pepe', 'rafa', 'rafael'
  ]);

  if (femaleNames.has(firstName)) return 'female';
  if (maleNames.has(firstName)) return 'male';
  return null;
}

// Helper: Retrieve summary of English/Spanish Wikipedia page to resolve gender pronouns/descriptions
async function resolveGenderFromWikipedia(sitelinks) {
  if (!sitelinks) return 'unknown';

  // Try Spanish Wikipedia first (highly gendered language)
  if (sitelinks.eswiki && sitelinks.eswiki.title) {
    try {
      const url = `https://es.wikipedia.org/api/rest_v1/page/summary/${encodeURIComponent(sitelinks.eswiki.title)}`;
      const res = await fetch(url, { headers: { 'User-Agent': 'Pikutara-TinderMusikal/1.0' } });
      if (res.ok) {
        const data = await res.json();
        const text = (data.extract || '').toLowerCase();
        
        const femaleKeywords = ['cantautora', 'nacida', 'compositora', 'rapera', 'productora', 'cantante española', 'es una', 'hija', 'hermana', 'directora', 'actriz'];
        const maleKeywords = ['cantautor', 'nacido', 'compositor', 'rapero', 'productor', 'cantante español', 'es un', 'hijo', 'hermano', 'director', 'actor'];
        
        let femaleScore = 0;
        let maleScore = 0;
        
        for (const kw of femaleKeywords) {
          if (text.includes(kw)) femaleScore++;
        }
        for (const kw of maleKeywords) {
          if (text.includes(kw)) maleScore++;
        }
        
        if (femaleScore > maleScore) return 'female';
        if (maleScore > femaleScore) return 'male';
      }
    } catch (e) {
      // ignore
    }
  }

  // Try English Wikipedia (also very clean pronouns)
  if (sitelinks.enwiki && sitelinks.enwiki.title) {
    try {
      const url = `https://en.wikipedia.org/api/rest_v1/page/summary/${encodeURIComponent(sitelinks.enwiki.title)}`;
      const res = await fetch(url, { headers: { 'User-Agent': 'Pikutara-TinderMusikal/1.0' } });
      if (res.ok) {
        const data = await res.json();
        const text = (data.extract || '').toLowerCase();
        
        // Count occurrences of pronouns
        const sheCount = (text.match(/\bshe\b/g) || []).length + (text.match(/\bher\b/g) || []).length;
        const heCount = (text.match(/\bhe\b/g) || []).length + (text.match(/\bhim\b/g) || []).length + (text.match(/\bhis\b/g) || []).length;
        const theyCount = (text.match(/\bthey\b/g) || []).length + (text.match(/\bthem\b/g) || []).length;
        
        if (sheCount > heCount && sheCount > theyCount) return 'female';
        if (heCount > sheCount && heCount > theyCount) return 'male';
        if (theyCount > sheCount && theyCount > heCount) return 'non_binary';
      }
    } catch (e) {
      // ignore
    }
  }

  return 'unknown';
}

// Helper: Query Wikipedia search to find page, extract wikibase_item (QID)
async function searchWikipediaForQID(name) {
  const languages = ['eu', 'es', 'en'];
  for (const lang of languages) {
    try {
      const searchUrl = `https://${lang}.wikipedia.org/w/api.php?action=query&list=search&srsearch=${encodeURIComponent(name)}&format=json&limit=3`;
      const res = await fetch(searchUrl, { headers: { 'User-Agent': 'Pikutara-TinderMusikal/1.0' } });
      if (res.ok) {
        const data = await res.json();
        if (data.query?.search && data.query.search.length > 0) {
          const topResult = data.query.search[0];
          const snippet = (topResult.snippet || '').toLowerCase();
          const title = (topResult.title || '').toLowerCase();
          const nameLower = name.toLowerCase();
          if (title.includes(nameLower) || snippet.includes(nameLower)) {
            const propsUrl = `https://${lang}.wikipedia.org/w/api.php?action=query&prop=pageprops&titles=${encodeURIComponent(topResult.title)}&format=json`;
            const propsRes = await fetch(propsUrl, { headers: { 'User-Agent': 'Pikutara-TinderMusikal/1.0' } });
            if (propsRes.ok) {
              const propsData = await propsRes.json();
              const pageId = Object.keys(propsData.query?.pages || {})[0];
              if (pageId && propsData.query.pages[pageId].pageprops?.wikibase_item) {
                return propsData.query.pages[pageId].pageprops.wikibase_item;
              }
            }
          }
        }
      }
    } catch (e) {
      // ignore
    }
  }
  return null;
}

// Background resolver for artist gender (from Wikidata & Wikipedia)
async function autoResolveArtistGender(artistName) {
  const cleanName = artistName.trim();
  if (!cleanName || cleanName === 'Ezezaguna') return;

  try {
    const exists = await get("SELECT 1 FROM artist_genders WHERE LOWER(artist) = LOWER(?)", [cleanName]);
    if (exists) return; // already classified

    // Check override dictionary first
    const localMatch = LOCAL_ARTIST_GENDERS[cleanName.toLowerCase()];
    if (localMatch) {
      await run("INSERT OR IGNORE INTO artist_genders (artist, gender_type, verified) VALUES (?, ?, 0)", [cleanName, localMatch]);
      console.log(`[Gender Resolve] Resolved local artist "${cleanName}" as [${localMatch}] via override dictionary`);
      return;
    }

    // 1. Search Wikidata. We search with language=eu (or fallback)
    let searchUrl = `https://www.wikidata.org/w/api.php?action=wbsearchentities&search=${encodeURIComponent(cleanName)}&language=eu&format=json&limit=5`;
    let res = await fetch(searchUrl, {
      headers: { 'User-Agent': 'Pikutara-TinderMusikal/1.0 (https://github.com/txartelari)' }
    });
    let searchData = await res.json();

    // If empty in Basque search, try English search just in case
    if (!searchData.search || searchData.search.length === 0) {
      searchUrl = `https://www.wikidata.org/w/api.php?action=wbsearchentities&search=${encodeURIComponent(cleanName)}&language=en&format=json&limit=5`;
      res = await fetch(searchUrl, {
        headers: { 'User-Agent': 'Pikutara-TinderMusikal/1.0 (https://github.com/txartelari)' }
      });
      searchData = await res.json();
    }

    // If still empty, try Wikipedia search fallback!
    if (!searchData.search || searchData.search.length === 0) {
      const qid = await searchWikipediaForQID(cleanName);
      if (qid) {
        searchData.search = [{ id: qid }];
      }
    }

    if (!searchData.search || searchData.search.length === 0) {
      await run("INSERT OR IGNORE INTO artist_genders (artist, gender_type, verified) VALUES (?, 'unknown', 0)", [cleanName]);
      console.log(`[Gender Resolve] Artist "${cleanName}": not found anywhere, set to 'unknown'`);
      return;
    }

    // Iterate through the search results (up to 5) and find the first one that is a human or group!
    let foundEntity = null;
    let foundEntityDetails = null;

    for (const searchResult of searchData.search) {
      const entityId = searchResult.id;
      const entityUrl = `https://www.wikidata.org/w/api.php?action=wbgetentities&ids=${entityId}&format=json`;
      const entityRes = await fetch(entityUrl, {
        headers: { 'User-Agent': 'Pikutara-TinderMusikal/1.0 (https://github.com/txartelari)' }
      });
      const entityData = await entityRes.json();
      const entity = entityData.entities[entityId];

      if (!entity) continue;

      const claims = entity.claims || {};
      let isHuman = false;
      let isGroup = false;

      if (claims.P31) {
        for (const claim of claims.P31) {
          const id = claim.mainsnak?.datavalue?.value?.id;
          if (id === 'Q5') {
            isHuman = true;
          }
          if (GROUP_CLASS_IDS.has(id)) {
            isGroup = true;
          }
        }
      }

      // Check description keywords
      const descEu = (entity.descriptions?.eu?.value || '').toLowerCase();
      const descEs = (entity.descriptions?.es?.value || '').toLowerCase();
      const descEn = (entity.descriptions?.en?.value || '').toLowerCase();
      const isMusicalDesc = [descEu, descEs, descEn].some(desc => 
        desc.includes('cantante') || desc.includes('singer') || desc.includes('musician') || 
        desc.includes('musikari') || desc.includes('abeslari') || desc.includes('banda') || 
        desc.includes('grupo') || desc.includes('taldea') || desc.includes('rapper') || 
        desc.includes('rapero') || desc.includes('composit') || desc.includes('music')
      );

      // Check occupations (P106)
      let hasMusicalOccupation = false;
      if (claims.P106) {
        const OCCUPATION_IDS = new Set(['Q177220', 'Q639669', 'Q488205', 'Q110595304', 'Q2252262', 'Q385557']);
        for (const claim of claims.P106) {
          const id = claim.mainsnak?.datavalue?.value?.id;
          if (OCCUPATION_IDS.has(id)) {
            hasMusicalOccupation = true;
          }
        }
      }

      if (isHuman || isGroup || isMusicalDesc || hasMusicalOccupation) {
        foundEntity = entity;
        foundEntityDetails = { isHuman, isGroup, claims };
        break;
      }
    }

    if (!foundEntity) {
      // Fallback: if none of the entities matched, just use the first search result
      const firstResultId = searchData.search[0].id;
      const res = await fetch(`https://www.wikidata.org/w/api.php?action=wbgetentities&ids=${firstResultId}&format=json`, {
        headers: { 'User-Agent': 'Pikutara-TinderMusikal/1.0' }
      });
      const data = await res.json();
      foundEntity = data.entities[firstResultId];
      if (foundEntity) {
        const claims = foundEntity.claims || {};
        let isHuman = false;
        let isGroup = false;
        if (claims.P31) {
          for (const claim of claims.P31) {
            const id = claim.mainsnak?.datavalue?.value?.id;
            if (id === 'Q5') isHuman = true;
            if (GROUP_CLASS_IDS.has(id)) isGroup = true;
          }
        }
        foundEntityDetails = { isHuman, isGroup, claims };
      }
    }

    if (!foundEntity) {
      await run("INSERT OR IGNORE INTO artist_genders (artist, gender_type, verified) VALUES (?, 'unknown', 0)", [cleanName]);
      return;
    }

    const { isHuman: isHumanFinal, isGroup: isGroupFinal, claims: claimsFinal } = foundEntityDetails;

    const GENDER_FEMALE = 'Q6581072';
    const GENDER_MALE = 'Q6581097';
    const NON_BINARY_GENDERS = new Set([
      'Q48270',    // non-binary
      'Q5125925',   // genderqueer
      'Q189125',    // transgender
      'Q10976337'   // trans identity
    ]);
    const GENDER_TRANS_FEMALE = 'Q1052224'; // trans woman

    if (isHumanFinal) {
      let type = 'unknown';
      if (claimsFinal.P21) {
        const genderId = claimsFinal.P21[0]?.mainsnak?.datavalue?.value?.id;
        if (genderId === GENDER_FEMALE) {
          type = 'female';
        } else if (genderId === GENDER_MALE) {
          type = 'male';
        } else if (genderId === GENDER_TRANS_FEMALE) {
          type = 'trans_female';
        } else if (NON_BINARY_GENDERS.has(genderId)) {
          type = 'non_binary';
        }
      }

      // Sitelinks Wikipedia summary checks
      if (type === 'unknown') {
        const wikiGender = await resolveGenderFromWikipedia(foundEntity.sitelinks);
        if (wikiGender !== 'unknown') {
          type = wikiGender;
        }
      }

      // Heuristic first name check
      if (type === 'unknown') {
        const labelsToCheck = [
          foundEntity.labels?.eu?.value,
          foundEntity.labels?.es?.value,
          foundEntity.labels?.en?.value,
          foundEntity.aliases?.eu?.[0]?.value,
          foundEntity.aliases?.es?.[0]?.value,
          foundEntity.aliases?.en?.[0]?.value
        ].filter(Boolean);

        for (const nameVal of labelsToCheck) {
          const guess = guessGenderFromFirstName(nameVal);
          if (guess) {
            type = guess;
            break;
          }
        }
      }

      // Check artist name itself
      if (type === 'unknown') {
        const guess = guessGenderFromFirstName(cleanName);
        if (guess) type = guess;
      }

      await run("INSERT OR IGNORE INTO artist_genders (artist, gender_type, verified) VALUES (?, ?, 0)", [cleanName, type]);
      console.log(`[Gender Resolve] Resolved human "${cleanName}" as [${type}]`);
      return;
    }

    if (isGroupFinal) {
      const memberClaims = claimsFinal.P527 || claimsFinal.P1912 || [];
      if (memberClaims.length > 0) {
        const memberIds = memberClaims.map(c => c.mainsnak?.datavalue?.value?.id).filter(Boolean);
        let femaleCount = 0;
        let maleCount = 0;
        let transFemaleCount = 0;
        let nonBinaryCount = 0;

        for (const mId of memberIds) {
          try {
            const mUrl = `https://www.wikidata.org/w/api.php?action=wbgetentities&ids=${mId}&props=claims&format=json`;
            const mRes = await fetch(mUrl, { headers: { 'User-Agent': 'Pikutara-TinderMusikal/1.0' } });
            const mData = await mRes.json();
            const mClaims = mData.entities[mId]?.claims || {};
            if (mClaims.P21) {
              const gId = mClaims.P21[0]?.mainsnak?.datavalue?.value?.id;
              if (gId === GENDER_FEMALE) femaleCount++;
              else if (gId === GENDER_MALE) maleCount++;
              else if (gId === GENDER_TRANS_FEMALE) transFemaleCount++;
              else if (NON_BINARY_GENDERS.has(gId)) nonBinaryCount++;
            }
          } catch (e) {
            // ignore member resolution errors
          }
        }

        let type = 'unknown_group';
        if (femaleCount > 0 && maleCount === 0 && transFemaleCount === 0 && nonBinaryCount === 0) {
          type = 'female_group';
        } else if (maleCount > 0 && femaleCount === 0 && transFemaleCount === 0 && nonBinaryCount === 0) {
          type = 'male_group';
        } else if (transFemaleCount > 0 || nonBinaryCount > 0) {
          type = 'dissident_group';
        } else if (femaleCount > 0 && maleCount > 0) {
          type = 'mixed_group';
        }

        await run("INSERT OR IGNORE INTO artist_genders (artist, gender_type, verified) VALUES (?, ?, 0)", [cleanName, type]);
        console.log(`[Gender Resolve] Resolved group "${cleanName}" as [${type}] (${femaleCount}F, ${maleCount}M, ${transFemaleCount}TF, ${nonBinaryCount}NB)`);
        return;
      }

      // Memberless group checking
      const descEu = (foundEntity.descriptions?.eu?.value || '').toLowerCase();
      const descEs = (foundEntity.descriptions?.es?.value || '').toLowerCase();
      const descEn = (foundEntity.descriptions?.en?.value || '').toLowerCase();

      let type = 'unknown_group';
      const allDescs = [descEu, descEs, descEn].join(' ');
      if (allDescs.includes('all-female') || allDescs.includes('grupo femenino') || allDescs.includes('banda femenina') || allDescs.includes('girl group') || allDescs.includes('girl band')) {
        type = 'female_group';
      } else if (allDescs.includes('queer') || allDescs.includes('trans') || allDescs.includes('feminist') || allDescs.includes('disident')) {
        type = 'dissident_group';
      } else {
        const wikiGender = await resolveGenderFromWikipedia(foundEntity.sitelinks);
        if (wikiGender === 'female') {
          type = 'female_group';
        } else if (wikiGender === 'non_binary') {
          type = 'dissident_group';
        }
      }

      await run("INSERT OR IGNORE INTO artist_genders (artist, gender_type, verified) VALUES (?, ?, 0)", [cleanName, type]);
      console.log(`[Gender Resolve] Resolved memberless group "${cleanName}" as [${type}] (via descriptions/sitelinks)`);
      return;
    }

    await run("INSERT OR IGNORE INTO artist_genders (artist, gender_type, verified) VALUES (?, 'unknown', 0)", [cleanName]);
    console.log(`[Gender Resolve] Resolved "${cleanName}" as [unknown]`);
  } catch (err) {
    console.error(`Error in autoResolveArtistGender for "${cleanName}":`, err.message);
  }
}

app.post('/api/views', async (req, res) => {
  try {
    const { path } = req.body;
    if (!path) return res.status(400).json({ error: 'Bidea falta da' });

    // Normalize path (remove trailing slash, except for root)
    let normPath = path;
    if (normPath.length > 1 && normPath.endsWith('/')) {
      normPath = normPath.slice(0, -1);
    }

    // Increment or insert
    const row = await get('SELECT views FROM page_views WHERE path = ?', [normPath]);
    if (row) {
      await run('UPDATE page_views SET views = views + 1 WHERE path = ?', [normPath]);
    } else {
      await run('INSERT INTO page_views (path, views) VALUES (?, 1)', [normPath]);
    }
    res.json({ success: true });
  } catch (error) {
    console.error('Error incrementing views:', error);
    res.status(500).json({ error: 'Errorea bisita gordetzean' });
  }
});

app.get('/api/memes', async (req, res) => {
  try {
    const memes = await query('SELECT id, title, image_path, votes, created_at FROM memes WHERE is_approved = 1 ORDER BY created_at DESC');
    res.json(memes);
  } catch (error) {
    res.status(500).json({ error: 'Errorea' });
  }
});

app.post('/api/memes', uploadMeme.single('memeFile'), async (req, res) => {
  try {
    if (!req.file || !req.body.memeTitle || !req.body.memeContact) return res.status(400).json({ error: 'Datu falta' });
    const imagePath = '/uploads/memes/' + req.file.filename;
    await run('INSERT INTO memes (title, contact, image_path, is_approved) VALUES (?, ?, ?, 0)', [req.body.memeTitle, req.body.memeContact, imagePath]);
    res.status(201).json({ success: true });
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
});

app.post('/api/memes/:id/vote', voteLimiter, async (req, res) => {
  try {
    await run('UPDATE memes SET votes = votes + 1 WHERE id = ? AND is_approved = 1', [req.params.id]);
    res.json({ success: true });
  } catch (error) {
    res.status(500).json({ error: 'Errorea' });
  }
});

app.post('/api/memes/:id/unvote', voteLimiter, async (req, res) => {
  try {
    await run('UPDATE memes SET votes = CASE WHEN votes > 0 THEN votes - 1 ELSE 0 END WHERE id = ? AND is_approved = 1', [req.params.id]);
    res.json({ success: true });
  } catch (error) {
    res.status(500).json({ error: 'Errorea botoa kentzean' });
  }
});

app.get('/api/posters', async (req, res) => {
  try {
    const posters = await query('SELECT * FROM posters ORDER BY created_at DESC');
    // Parse JSON bands back to array
    posters.forEach(p => { p.bands = p.bands ? JSON.parse(p.bands) : []; });
    res.json(posters);
  } catch (error) {
    res.status(500).json({ error: 'Errorea datu-basean' });
  }
});

app.get('/api/playlist/has-voted', async (req, res) => {
  try {
    const ip = req.ip || req.headers['x-forwarded-for'] || req.socket.remoteAddress;
    const hasReviewed = await get('SELECT id FROM playlist_reviews WHERE ip_address = ?', [ip]);
    res.json({ hasVoted: !!hasReviewed });
  } catch (error) {
    console.error('Error checking vote status:', error);
    res.status(500).json({ error: 'Errorea zerbitzarian balorazioa egiaztatzean.' });
  }
});

app.post('/api/playlist/reviews', async (req, res) => {
  try {
    const { rating, comment } = req.body;
    const score = parseInt(rating);

    if (!score || score < 1 || score > 5 || !comment || !comment.trim()) {
      return res.status(400).json({ error: 'Balorazioa (1-5) eta iruzkina beharrezkoak dira.' });
    }

    const ip = req.ip || req.headers['x-forwarded-for'] || req.socket.remoteAddress;

    try {
      await run(
        'INSERT INTO playlist_reviews (rating, comment, ip_address) VALUES (?, ?, ?)',
        [score, comment.trim(), ip]
      );
      res.status(201).json({ success: true });
    } catch (dbErr) {
      if (dbErr.message.includes('UNIQUE constraint failed')) {
        return res.status(400).json({ error: 'Dagoeneko baloratu duzu musika zerrenda hau!' });
      }
      throw dbErr;
    }
  } catch (error) {
    console.error('Error saving review:', error);
    res.status(500).json({ error: 'Errorea balorazioa zerbitzarian gordetzean.' });
  }
});
// ==========================================
// SONGS PROPOSALS (MUSIKA)
// ==========================================

function extractYouTubeId(url) {
  if (!url) return null;
  const shortsMatch = url.match(/\/shorts\/([^&?]+)/);
  if (shortsMatch) return shortsMatch[1];
  const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|watch\?.+&v=))([^&?]+)/);
  return match ? match[1] : null;
}

function normalizeSongUrl(url) {
  if (!url) return '';
  const trimmed = url.trim();
  
  const videoId = extractYouTubeId(trimmed);
  if (videoId) {
    return `https://www.youtube.com/watch?v=${videoId}`;
  }
  
  const spotifyTrackMatch = trimmed.match(/\/track\/([^/?#]+)/);
  if (spotifyTrackMatch) {
    return `https://open.spotify.com/track/${spotifyTrackMatch[1]}`;
  }
  
  return trimmed;
}

function cleanTextForDuplicateCheck(text) {
  if (!text) return '';
  return text
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '') // remove accents
    .replace(/[^a-z0-9]/g, ''); // remove non-alphanumeric characters
}

function normalizeArtistForDuplicateCheck(artist) {
  if (!artist) return '';
  return artist
    .split(/,|\s+feat\.?\s+|\s+ft\.?\s+|\s+&\s+/i)
    .map(a => cleanTextForDuplicateCheck(a))
    .filter(Boolean)
    .sort()
    .join('');
}

function normalizeTitleForDuplicateCheck(title) {
  if (!title) return '';
  let cleaned = title.toLowerCase()
    .replace(/\b(official video|video oficial|lyrics|letra|hitzak|audio|official audio|videoclip|bideoklipa)\b/g, '')
    .replace(/[\(\[\{].*?[\)\]\}]/g, ''); // Remove text inside parentheses/brackets
  return cleanTextForDuplicateCheck(cleaned);
}

function shouldUpdateUrl(existing, incoming) {
  const existingReviewed = existing.status === 'accepted' || existing.status === 'rejected';
  const incomingReviewed = incoming.status === 'accepted' || incoming.status === 'rejected';
  
  if (existingReviewed && !incomingReviewed) {
    return false; // keep existing (reviewed beats pending)
  }
  if (!existingReviewed && incomingReviewed) {
    return true; // update to incoming (reviewed beats pending)
  }
  
  // If both are reviewed or both are pending, check platform
  const existingIsSpotify = existing.url.includes('spotify.com');
  const incomingIsSpotify = incoming.url.includes('spotify.com');
  
  if (incomingIsSpotify && !existingIsSpotify) {
    return true; // update (Spotify beats YouTube)
  }
  if (!incomingIsSpotify && existingIsSpotify) {
    return false; // keep existing (Spotify beats YouTube)
  }
  
  // Same platform, incoming is newer, so update URL
  return true;
}

async function findDuplicateSong(normalizedUrl, realTitle, realArtist) {
  const allSongs = await query("SELECT * FROM songs");
  const cleanNewArt = normalizeArtistForDuplicateCheck(realArtist);
  const cleanNewTit = normalizeTitleForDuplicateCheck(realTitle);
  const newKey = `${cleanNewArt}::${cleanNewTit}`;

  for (const song of allSongs) {
    if (song.url === normalizedUrl) {
      return song;
    }
    if (song.real_title && song.real_artist) {
      const cleanArt = normalizeArtistForDuplicateCheck(song.real_artist);
      const cleanTit = normalizeTitleForDuplicateCheck(song.real_title);
      const key = `${cleanArt}::${cleanTit}`;
      if (key === newKey) {
        return song;
      }
    }
  }
  return null;
}

async function checkYouTubeVideoType(videoId) {
  const url = `https://www.youtube.com/watch?v=${videoId}`;

  try {
    // Usamos el yt-dlp blindado que ya sabemos que funciona en Oracle Cloud
    const { stdout } = await execFilePromise('/usr/bin/yt-dlp', [
      '--cookies', '/app/data/cookies.txt',  // La llave maestra
      '--js-runtimes', 'node',               // Para descifrar firmas
      '--ignore-no-formats-error',           // Chaleco antibalas
      '-4',                                  // Forzar IPv4
      '--dump-json',                         // Devolver solo metadatos
      url
    ], { timeout: 30000 });

    const data = JSON.parse(stdout);

    // Si YouTube lo clasifica en la categoría "Music" o tiene metadatos de pista/artista, es válido
    const categories = data.categories || [];
    const isMusicCategory = categories.includes('Music') || categories.includes('Música');
    const hasMusicMetadata = !!data.track || !!data.artist;

    const isValid = isMusicCategory || hasMusicMetadata;

    return {
      isValid,
      musicVideoType: isValid ? 'MUSIC_VIDEO' : 'UNKNOWN',
      title: data.title || '',
      author: data.uploader || data.channel || ''
    };
  } catch (err) {
    console.error(`Error querying yt-dlp for ${videoId}:`, err.message);
    return {
      isValid: false,
      error: `Ezin izan da bideoa egiaztatu: ${err.message}`,
      musicVideoType: 'ERROR'
    };
  }
}

async function tryResolveOfficialVideoId(videoId) {
  const watchUrl = `https://www.youtube.com/watch?v=${videoId}`;
  try {
    const res = await fetch(watchUrl, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/110.0.0.0 Safari/537.36',
        'Accept-Language': 'en-US,en;q=0.9'
      }
    });

    if (!res.ok) {
      return null;
    }

    const html = await res.text();
    const match = html.match(/ytInitialData\s*=\s*(\{[\s\S]*?\});/);
    if (!match) {
      return null;
    }

    const initialData = JSON.parse(match[1]);
    let foundId = null;

    function recurse(obj) {
      if (!obj || foundId) return;
      if (typeof obj === 'object') {
        if (obj.videoAttributeViewModel && obj.videoAttributeViewModel.onTap) {
          const cmd = obj.videoAttributeViewModel.onTap.innertubeCommand;
          if (cmd && cmd.watchEndpoint && cmd.watchEndpoint.videoId) {
            foundId = cmd.watchEndpoint.videoId;
            return;
          }
        }
        for (const k in obj) {
          recurse(obj[k]);
        }
      }
    }

    if (initialData && initialData.engagementPanels) {
      recurse(initialData.engagementPanels);
    }

    return foundId;
  } catch (err) {
    console.error(`Error resolving official release for ${videoId}:`, err.message);
    return null;
  }
}

async function resolveRealMetadata(url) {
  let realTitle = '';
  let realArtist = '';

  try {
    if (url.includes('spotify.com')) {
      // 1. Try parsing Embed page HTML for __NEXT_DATA__ first
      const trackIdMatch = url.match(/\/track\/([^/?#]+)/);
      if (trackIdMatch) {
        const trackId = trackIdMatch[1];
        try {
          const embedUrl = `https://open.spotify.com/embed/track/${trackId}`;
          const response = await fetch(embedUrl, {
            headers: {
              'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/110.0.0.0 Safari/537.36',
              'Accept-Language': 'en-US,en;q=0.9'
            }
          });
          if (response.ok) {
            const html = await response.text();
            const nextDataMatch = html.match(/<script id="__NEXT_DATA__" type="application\/json">([\s\S]*?)<\/script>/);
            if (nextDataMatch) {
              const data = JSON.parse(nextDataMatch[1]);
              const entity = data.props?.pageProps?.state?.data?.entity;
              if (entity) {
                // Check if track is explicitly unplayable (deleted or region restricted)
                if (entity.isPlayable === false) {
                  throw new Error("Spotify abesti hau ez dago erabilgarri (katalogotik kendu da edo eskualde honetan blokeatuta dago)");
                }
                realTitle = entity.name || entity.title || '';
                realArtist = entity.artists ? entity.artists.map(a => a.name).join(', ') : '';
              }
            }
          }
        } catch (embedErr) {
          console.error("Error parsing Spotify embed in resolveRealMetadata:", embedErr);
          if (embedErr.message && embedErr.message.includes("ez dago erabilgarri")) {
            throw embedErr;
          }
        }
      }

      // 2. Fallback to oEmbed + scraper
      if (!realTitle || !realArtist) {
        const oEmbedUrl = `https://open.spotify.com/oembed?url=${encodeURIComponent(url)}`;
        const response = await fetch(oEmbedUrl);
        if (response.ok) {
          const data = await response.json();
          realTitle = data.title || '';
        }

        const htmlRes = await fetch(url, {
          headers: {
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/110.0.0.0 Safari/537.36',
            'Accept-Language': 'eu,es;q=0.9,en;q=0.8'
          }
        });
        if (htmlRes.ok) {
          const html = await htmlRes.text();
          const twitterMatch = html.match(/<meta name="twitter:description" content="([^"·]+) ·/);
          if (twitterMatch) {
            realArtist = twitterMatch[1].trim();
          } else {
            const musicianMatch = html.match(/<meta name="music:musician_description" content="([^"]+)"/);
            if (musicianMatch) {
              realArtist = musicianMatch[1].trim();
            } else {
              const descMatch = html.match(/Song · ([^·]+) ·/);
              if (descMatch) {
                realArtist = descMatch[1].trim();
              }
            }
          }
        }
      }
    } else if (url.includes('youtube.com/') || url.includes('youtu.be/')) {
      // LOGIKA BERRIA: YouTube-ko testu bidezko widgeten detekzioa (Gordiscos / Yogurinha Borova kasuak)
      let foundWidget = false;
      try {
        const ytRes = await fetch(url, {
          headers: {
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/110.0.0.0 Safari/537.36',
            'Accept-Language': 'en-US,en;q=0.9'
          }
        });

        if (ytRes.ok) {
          const html = await ytRes.text();
          const match = html.match(/ytInitialData\s*=\s*(\{[\s\S]*?\});/);
          if (match) {
            const initialData = JSON.parse(match[1]);
            let wTitle = null;
            let wArtist = null;

            function extractFromYT(obj) {
              if (!obj || foundWidget) return;
              if (typeof obj === 'object') {

                // Estrategia A: Diseinu berriaren widgeta (videoAttributeViewModel)
                // Diskoari/Albumari dagokion "secondarySubtitle" badu, badakigu ez dela kanalaren widgeta, baizik eta abestiarena.
                if (obj.videoAttributeViewModel && obj.videoAttributeViewModel.title && obj.videoAttributeViewModel.subtitle) {
                  if (obj.videoAttributeViewModel.secondarySubtitle) {
                    wTitle = obj.videoAttributeViewModel.title;
                    wArtist = obj.videoAttributeViewModel.subtitle;
                    foundWidget = true;
                    return;
                  }
                }

                // Estrategia B: Diseinu klasikoaren errenkadak (metadataRowRenderer)
                if (obj.metadataRowRenderer) {
                  const titleText = obj.metadataRowRenderer.title?.simpleText || obj.metadataRowRenderer.title?.runs?.[0]?.text;
                  const contentText = obj.metadataRowRenderer.contents?.[0]?.simpleText || obj.metadataRowRenderer.contents?.[0]?.runs?.[0]?.text;
                  if (titleText && contentText) {
                    const tLower = titleText.toLowerCase();
                    if (tLower.includes('song') || tLower.includes('canción') || tLower.includes('abestia')) {
                      wTitle = contentText;
                    } else if (tLower.includes('artist') || tLower.includes('artista')) {
                      wArtist = contentText;
                    }
                  }
                }

                // Biak aurkitu baditugu errenkaden bidez, eten bilaketa
                if (wTitle && wArtist) {
                  foundWidget = true;
                  return;
                }

                for (const k in obj) {
                  extractFromYT(obj[k]);
                  if (foundWidget) return;
                }
              }
            }

            extractFromYT(initialData);

            if (foundWidget && wTitle && wArtist) {
              realTitle = wTitle;
              realArtist = wArtist;
              // LOGA: Kasu hau noiz gertatzen den ikusteko
              console.log(`[Music Widget Fallback] Testu bidezko widgeta detektatu da! Artista: "${wArtist}", Abestia: "${wTitle}"`);
            }
          }
        }
      } catch (e) {
        console.error("Error extracting text widget from YouTube:", e);
      }

      // Widgeta ez badugu aurkitu, Noembed tradizionalera jotzen dugu (Kanalaren izena ateratzeko)
      if (!foundWidget) {
        const response = await fetch(`https://noembed.com/embed?url=${encodeURIComponent(url)}`);
        if (response.ok) {
          const data = await response.json();
          realTitle = data.title || '';
          realArtist = data.author_name || '';

          if (realTitle.includes(' - ')) {
            const parts = realTitle.split(' - ');
            const possibleArtist = parts[0].trim();
            const possibleTitle = parts[1].replace(/(official video|videoclip|visualizer|lyric video|official music video|video oficial|oficial video|bideoa|bideoklipa|bideoklip ofiziala|lyric|audio|hd|4k|remastered)/gi, "").replace(/[\(\[【].*?[\)\]】]/g, "").trim();
            realArtist = possibleArtist;
            realTitle = possibleTitle;
          }
        }
      }
    } else {
      // YouTube edo Spotify ez diren estekentzat jatorrizko Noembed portaera mantentzen da
      const response = await fetch(`https://noembed.com/embed?url=${encodeURIComponent(url)}`);
      if (response.ok) {
        const data = await response.json();
        realTitle = data.title || '';
        realArtist = data.author_name || '';

        if (realTitle.includes(' - ')) {
          const parts = realTitle.split(' - ');
          const possibleArtist = parts[0].trim();
          const possibleTitle = parts[1].replace(/(official video|videoclip|visualizer|lyric video|official music video|video oficial|oficial video|bideoa|bideoklipa|bideoklip ofiziala|lyric|audio|hd|4k|remastered)/gi, "").replace(/[\(\[【].*?[\)\]】]/g, "").trim();
          realArtist = possibleArtist;
          realTitle = possibleTitle;
        }
      }
    }
  } catch (e) {
    console.error("Error resolving real metadata:", e);
    if (e.message && e.message.includes("ez dago erabilgarri")) {
      throw e;
    }
  }

  if (realArtist) {
    // Clean "- Topic" suffix case-sensitively
    realArtist = realArtist.replace(/\s*-\s*Topic\s*$/gi, '').trim();

    // Validate that the artist is not generic
    const lowerArtist = realArtist.toLowerCase();
    if (lowerArtist === 'release' || lowerArtist === 'various artists' || lowerArtist === 'various artist' || lowerArtist === 'artistas varios' || lowerArtist === 'varios artistas') {
      throw new Error('Ezin da abesti hau onartu: artista ezezaguna edo generikoa da ("Release" edo "Various Artists").');
    }
  }

  return {
    title: realTitle || 'Ezezaguna',
    artist: realArtist || 'Ezezaguna'
  };
}

app.get('/api/musika/songs', async (req, res) => {
  try {
    const songs = await query("SELECT * FROM songs WHERE status = 'accepted' ORDER BY created_at DESC");
    const mappingsMap = await loadTagMappingsMap();
    songs.forEach(s => {
      s.genres = applyTagMappings(safeParseArray(s.genres), mappingsMap);
      s.proposed_titles = safeParseArray(s.proposed_titles);
      s.proposed_artists = safeParseArray(s.proposed_artists);
      s.submitters = safeParseArray(s.submitters);
      s.comments = safeParseArray(s.comments);
      s.ips = safeParseArray(s.ips);
    });
    res.json(songs);
  } catch (error) {
    console.error('Error fetching songs:', error);
    res.status(500).json({ error: 'Errorea datu-basean' });
  }
});

app.post('/api/musika/songs', songProposalLimiter, async (req, res) => {
  try {
    const { url, title, artist, submittedBy, comment } = req.body;

    if (!url || !title || !artist || !submittedBy) {
      return res.status(400).json({ error: 'Beharrezko datuak falta dira.' });
    }

    const ip = req.ip || req.headers['x-forwarded-for'] || req.socket.remoteAddress;

    /* Temporarily disabled for testing:
    const hasReviewed = await get('SELECT id FROM playlist_reviews WHERE ip_address = ?', [ip]);
    if (!hasReviewed) {
       return res.status(403).json({ error: 'Abesti bat proposatzeko, aurretik playlist-a baloratu behar duzu.' });
    }
    */

    // Rate Limit Check: Max 10 songs per IP (check across all ips list arrays)
    const allSongs = await query("SELECT ips FROM songs");
    let userSongsCount = 0;
    allSongs.forEach(s => {
      try {
        const parsedIps = JSON.parse(s.ips);
        if (Array.isArray(parsedIps) && parsedIps.includes(ip)) {
          userSongsCount++;
        }
      } catch (e) { }
    });

    /* Temporarily disabled for testing:
    if (userSongsCount >= 10) {
       return res.status(429).json({ error: 'Muga gainditu duzu. Gehienez 10 abesti proposatu ditzakezu.' });
    }
    */

    const videoId = extractYouTubeId(url);
    let finalVideoId = videoId;

    if (videoId) {
      let ytCheck = await checkYouTubeVideoType(videoId);
      if (!ytCheck.isValid) {
        // Fallback: try resolving from the watch page's description cards
        const officialId = await tryResolveOfficialVideoId(videoId);
        if (officialId) {
          const officialCheck = await checkYouTubeVideoType(officialId);
          if (officialCheck.isValid) {
            finalVideoId = officialId;
            ytCheck = officialCheck;
          }
        }
      }

      if (!ytCheck.isValid) {
        return res.status(400).json({
          error: 'Bideo hau ezin da onartu. Musika-bideo ofizialak (Art Track edo Bideoklip Ofizialak) bakarrik onartzen dira. Mesedez, ziurtatu igotako esteka jatorrizko bideo ofizial batena edo Youtube Music-eko abesti batena dela.'
        });
      }
    }

    const normalizedUrl = normalizeSongUrl(finalVideoId ? `https://www.youtube.com/watch?v=${finalVideoId}` : url);

    // Resolve real metadata from link first so we can check cross-platform duplicates by metadata
    let realMeta = { title: '', artist: '' };
    try {
      realMeta = await resolveRealMetadata(normalizedUrl);
    } catch (metaErr) {
      console.warn("Could not resolve real metadata on submit:", metaErr.message);
    }

    // Fallback to submitted titles/artists if resolution returned empty/Ezezaguna
    const checkTitle = realMeta.title && realMeta.title !== 'Ezezaguna' ? realMeta.title : title.trim();
    const checkArtist = realMeta.artist && realMeta.artist !== 'Ezezaguna' ? realMeta.artist : artist.trim();

    // Check if it already exists (pending, accepted or rejected) by URL or metadata
    const existingSong = await findDuplicateSong(normalizedUrl, checkTitle, checkArtist);
    if (existingSong) {
      // Append the new proposal details to list fields
      const proposedTitles = safeParseArray(existingSong.proposed_titles);
      const proposedArtists = safeParseArray(existingSong.proposed_artists);
      const submitters = safeParseArray(existingSong.submitters);
      const comments = safeParseArray(existingSong.comments);
      const ips = safeParseArray(existingSong.ips);

      const trimmedTitle = title.trim();
      const trimmedArtist = artist.trim();
      const trimmedSubmitter = submittedBy.trim();
      const trimmedComment = comment ? comment.trim() : '';

      if (!proposedTitles.includes(trimmedTitle)) proposedTitles.push(trimmedTitle);
      if (!proposedArtists.includes(trimmedArtist)) proposedArtists.push(trimmedArtist);
      if (!submitters.includes(trimmedSubmitter)) submitters.push(trimmedSubmitter);
      if (trimmedComment && !comments.includes(trimmedComment)) comments.push(trimmedComment);
      if (!ips.includes(ip)) ips.push(ip);

      let updateQuery = 'UPDATE songs SET proposed_titles = ?, proposed_artists = ?, submitters = ?, comments = ?, ips = ?';
      const params = [
        JSON.stringify(proposedTitles),
        JSON.stringify(proposedArtists),
        JSON.stringify(submitters),
        JSON.stringify(comments),
        JSON.stringify(ips)
      ];

      // If the incoming song takes priority (e.g. incoming is Spotify, existing is YouTube pending), update the DB record's URL
      if (shouldUpdateUrl(existingSong, { url: normalizedUrl, status: 'pending' })) {
        updateQuery += ', url = ?, real_title = ?, real_artist = ?';
        params.push(normalizedUrl, checkTitle, checkArtist);
      }

      updateQuery += ' WHERE id = ?';
      params.push(existingSong.id);

      await run(updateQuery, params);

      return res.status(201).json({ success: true, message: 'Dagoeneko proposatuta zegoen. Proposamena gehitu da!' });
    }

    // Resolve genres automatically using Last.fm (Muzpesil logic)
    let genres = [];
    try {
      genres = await resolveSongGenres(checkTitle, checkArtist);
    } catch (e) {
      console.error("Auto genre resolution failed on submit:", e);
    }

    const commentsList = comment && comment.trim() ? [comment.trim()] : [];

    // Insert new song with resolved genres and arrays
    const result = await run(
      `INSERT INTO songs (url, real_title, real_artist, proposed_titles, proposed_artists, submitters, comments, ips, genres, status) 
       VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, 'pending')`,
      [
        normalizedUrl,
        checkTitle,
        checkArtist,
        JSON.stringify([title.trim()]),
        JSON.stringify([artist.trim()]),
        JSON.stringify([submittedBy.trim()]),
        JSON.stringify(commentsList),
        JSON.stringify([ip]),
        JSON.stringify(genres)
      ]
    );

    const songId = result ? result.lastID : null;
    if (songId) {
      // Trigger background auto-resolvers asynchronously (without blocking response)
      autoResolveLyricsAndLanguage(songId, checkTitle, checkArtist).catch(err => {
        console.error(`[Background Error] autoResolveLyricsAndLanguage for song ${songId} failed:`, err);
      });

      const artists = splitArtists(checkArtist);
      artists.forEach(art => {
        autoResolveArtistGender(art).catch(err => {
          console.error(`[Background Error] autoResolveArtistGender for "${art}" failed:`, err);
        });
      });
    }

    res.status(201).json({ success: true });
  } catch (error) {
    console.error('Error saving song:', error);
    if (error.message && (error.message.includes('ez dago erabilgarri') || error.message.includes('artista ezezaguna edo generikoa'))) {
      return res.status(400).json({ error: error.message });
    }
    res.status(500).json({ error: 'Errorea abestia gordetzean.' });
  }
});

// Webhook for external Tinder App to update status and genres
app.put('/api/webhook/songs/:id', async (req, res) => {
  try {
    const { status, genres } = req.body;

    if (!status) {
      return res.status(400).json({ error: 'Estatusa falta da.' });
    }

    let genresStr = '[]';
    if (genres && Array.isArray(genres)) {
      genresStr = JSON.stringify(genres);
    }

    await run('UPDATE songs SET status = ?, genres = ? WHERE id = ?', [status, genresStr, req.params.id]);
    res.json({ success: true });
  } catch (error) {
    console.error('Error in webhook update:', error);
    res.status(500).json({ error: 'Errorea eguneratzean.' });
  }
});
