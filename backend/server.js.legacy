// Bulk import tag mappings
app.post('/api/admin/tag-mappings/bulk', authMiddleware, async (req, res) => {
  try {
    const mappings = req.body;
    if (!Array.isArray(mappings)) {
      return res.status(400).json({ error: 'Array bat espero zen.' });
    }

    await new Promise((resolve, reject) => {
      db.serialize(() => {
        db.run("BEGIN TRANSACTION", (err) => {
          if (err) return reject(err);
        });
        const stmt = db.prepare("INSERT OR REPLACE INTO tag_mappings (original_tag, canonical_tag) VALUES (?, ?)");
        let hasError = false;
        let lastErr = null;

        for (const m of mappings) {
          const orig = m.original_tag || m.original;
          const canon = m.canonical_tag || m.canonical;
          if (orig && typeof orig === 'string' && canon && typeof canon === 'string') {
            const cleanOrig = orig.trim();
            const cleanCanon = canon.trim();
            if (cleanOrig.toLowerCase() !== cleanCanon.toLowerCase()) {
              stmt.run(cleanOrig, cleanCanon, (err) => {
                if (err) {
                  hasError = true;
                  lastErr = err;
                }
              });
            }
          }
        }

        stmt.finalize((err) => {
          if (err || hasError) {
            db.run("ROLLBACK", () => {
              reject(err || lastErr || new Error("Error during bulk insert"));
            });
          } else {
            db.run("COMMIT", (commitErr) => {
              if (commitErr) {
                db.run("ROLLBACK", () => reject(commitErr));
              } else {
                resolve();
              }
            });
          }
        });
      });
    });

    res.json({ success: true, count: mappings.length });
  } catch (error) {
    console.error("Error bulk importing tag mappings:", error);
    res.status(500).json({ error: 'Errorea etiketa taldekatzeak inportatzean: ' + error.message });
  }
});

// Get all genre hierarchy mappings (admin)
app.get('/api/admin/genre-hierarchy', authMiddleware, async (req, res) => {
  try {
    const rows = await query("SELECT genre, parent_genre FROM genre_hierarchy ORDER BY genre ASC");
    res.json(rows);
  } catch (error) {
    res.status(500).json({ error: 'Errorea generoen zuhaitza kargatzean.' });
  }
});

// Add/Update a genre hierarchy parent
app.post('/api/admin/genre-hierarchy', authMiddleware, async (req, res) => {
  try {
    const { genre, parent_genre } = req.body;
    if (!genre || typeof genre !== 'string' || !genre.trim() ||
      !parent_genre || typeof parent_genre !== 'string' || !parent_genre.trim()) {
      return res.status(400).json({ error: 'Datu baliogabeak.' });
    }

    const cleanGenre = genre.trim();
    const cleanParent = parent_genre.trim();

    if (cleanGenre.toLowerCase() === cleanParent.toLowerCase()) {
      return res.status(400).json({ error: 'Ezin da genero bat bere buruaren azpiko genero izendatu.' });
    }

    await run("INSERT OR REPLACE INTO genre_hierarchy (genre, parent_genre) VALUES (?, ?)", [cleanGenre, cleanParent]);
    res.json({ success: true });
  } catch (error) {
    console.error("Error adding genre hierarchy:", error);
    res.status(500).json({ error: 'Errorea genero zuhaitza gehitzean.' });
  }
});

// Delete a genre hierarchy parent mapping
app.delete('/api/admin/genre-hierarchy/:genre', authMiddleware, async (req, res) => {
  try {
    await run("DELETE FROM genre_hierarchy WHERE genre = ?", [req.params.genre]);
    res.json({ success: true });
  } catch (error) {
    res.status(500).json({ error: 'Errorea genero zuhaitza ezabatzean.' });
  }
});

// Bulk import genre hierarchy
app.post('/api/admin/genre-hierarchy/bulk', authMiddleware, async (req, res) => {
  try {
    const hierarchy = req.body;
    if (!Array.isArray(hierarchy)) {
      return res.status(400).json({ error: 'Array bat espero zen.' });
    }

    await new Promise((resolve, reject) => {
      db.serialize(() => {
        db.run("BEGIN TRANSACTION", (err) => {
          if (err) return reject(err);
        });
        const stmt = db.prepare("INSERT OR REPLACE INTO genre_hierarchy (genre, parent_genre) VALUES (?, ?)");
        let hasError = false;
        let lastErr = null;

        for (const h of hierarchy) {
          const gen = h.genre;
          const parent = h.parent_genre || h.parent;
          if (gen && typeof gen === 'string' && parent && typeof parent === 'string') {
            const cleanGenre = gen.trim();
            const cleanParent = parent.trim();
            if (cleanGenre.toLowerCase() !== cleanParent.toLowerCase()) {
              stmt.run(cleanGenre, cleanParent, (err) => {
                if (err) {
                  hasError = true;
                  lastErr = err;
                }
              });
            }
          }
        }

        stmt.finalize((err) => {
          if (err || hasError) {
            db.run("ROLLBACK", () => {
              reject(err || lastErr || new Error("Error during bulk insert"));
            });
          } else {
            db.run("COMMIT", (commitErr) => {
              if (commitErr) {
                db.run("ROLLBACK", () => reject(commitErr));
              } else {
                resolve();
              }
            });
          }
        });
      });
    });

    res.json({ success: true, count: hierarchy.length });
  } catch (error) {
    console.error("Error bulk importing genre hierarchy:", error);
    res.status(500).json({ error: 'Errorea genero zuhaitza inportatzean: ' + error.message });
  }
});

// Public GET endpoint for frontend chart rollup
app.get('/api/musika/genre-hierarchy', async (req, res) => {
  try {
