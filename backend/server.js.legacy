// Add a tag to the garbage list
app.post('/api/admin/garbage-tags', authMiddleware, async (req, res) => {
  try {
    const { tag } = req.body;
    if (!tag || typeof tag !== 'string' || !tag.trim()) {
      return res.status(400).json({ error: 'Etiketa baliogabea.' });
    }
    const cleanTag = tag.trim().toLowerCase();
    await run("INSERT OR IGNORE INTO garbage_tags (tag) VALUES (?)", [tag.trim()]);

    // Synchronize: remove the newly added garbage tag from all songs in database
    const songs = await query("SELECT id, genres FROM songs");
    for (const song of songs) {
      let genres = [];
      try {
        genres = JSON.parse(song.genres || '[]');
      } catch (e) { }

      if (Array.isArray(genres)) {
        const filtered = genres.filter(g => g.toLowerCase() !== cleanTag);
        if (filtered.length !== genres.length) {
          await run("UPDATE songs SET genres = ? WHERE id = ?", [JSON.stringify(filtered), song.id]);
        }
      }
    }

    res.json({ success: true });
  } catch (error) {
    console.error("Error adding garbage tag and sync:", error);
    res.status(500).json({ error: 'Errorea etiketa gehitzean.' });
  }
});

