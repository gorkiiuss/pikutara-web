// Update song metadata (title, artist, genres list, submitters, comments)
app.put('/api/admin/songs/:id/metadata', authMiddleware, async (req, res) => {
  try {
    const { title, artist, genres, submitters, comments, language } = req.body;
    if (!title || !artist || !genres || !Array.isArray(genres) || !submitters || !Array.isArray(submitters) || !comments || !Array.isArray(comments)) {
      return res.status(400).json({ error: 'Datu baliogabeak.' });
    }

    const existing = await get("SELECT language FROM songs WHERE id = ?", [req.params.id]);
    let languageStr = existing ? existing.language : '[]';
    if (language !== undefined) {
      if (Array.isArray(language)) {
        languageStr = JSON.stringify(language);
      } else if (typeof language === 'string') {
        try {
          const parsed = JSON.parse(language);
          languageStr = Array.isArray(parsed) ? JSON.stringify(parsed) : JSON.stringify([language.trim()]);
        } catch (e) {
          const splitLangs = language.split(',').map(l => l.trim().toLowerCase()).filter(Boolean);
          languageStr = JSON.stringify(splitLangs);
        }
      }
    }

    // 1. Actualizamos la canción actual
    await run("UPDATE songs SET real_title = ?, real_artist = ?, genres = ?, submitters = ?, comments = ?, language = ? WHERE id = ?", [
      title.trim(),
      artist.trim(),
      JSON.stringify(genres),
      JSON.stringify(submitters),
      JSON.stringify(comments),
      languageStr,
      req.params.id
    ]);

    // LÓGICA DE OPTIMIZACIÓN MULTI-ARTISTA
    const artistList = splitArtists(artist);
    let affectedCount = 0;

    if (genres.length > 0 && artistList.length > 0) {
      let anyTagged = false;

      // Salvaguarda: comprobamos si de casualidad alguno ya estaba etiquetado
      for (const a of artistList) {
        const exists = await get("SELECT 1 FROM artist_genres WHERE LOWER(artist) = LOWER(?)", [a]);
        if (exists) {
          anyTagged = true;
          break;
        }
      }

      // CASO 1: Ninguno está etiquetado. Guardamos al PRIMERO de la lista.
      if (!anyTagged) {
        const firstArtist = artistList[0];

        await run("INSERT OR REPLACE INTO artist_genres (artist, genres, updated_at) VALUES (?, ?, CURRENT_TIMESTAMP)", [
          firstArtist,
          JSON.stringify(genres)
        ]);

        // Propagación retroactiva inteligente (troceamos a los durmientes para evitar falsos positivos)
        const untaggedSongs = await query("SELECT id, real_artist FROM songs WHERE genres = '[]' OR genres = '' OR genres IS NULL");
        for (const uSong of untaggedSongs) {
          const uArtistList = splitArtists(uSong.real_artist);
          // Si la canción durmiente incluye a nuestro firstArtist exacto, la actualizamos
          if (uArtistList.some(a => a.toLowerCase() === firstArtist.toLowerCase())) {
            await run("UPDATE songs SET genres = ? WHERE id = ?", [JSON.stringify(genres), uSong.id]);
            affectedCount++;
          }
        }

        if (affectedCount > 0) {
          console.log(`[Optimizazioa - Metadata] ${affectedCount} kantu automatikoki sailkatu dira "${firstArtist}" artistarentzat.`);
        }
      }
    }

    res.json({ success: true, affectedCount });
  } catch (error) {
    console.error("Metadata update error:", error);
    res.status(500).json({ error: 'Errorea eguneratzean.' });
  }
});

// Tinder Musikal: Fast route to ONLY save tags from the "Etiketatu" view
app.put('/api/admin/songs/:id/tag', authMiddleware, async (req, res) => {
  try {
    const { genres, artist } = req.body;
    if (!genres || !Array.isArray(genres) || genres.length === 0) {
      return res.status(400).json({ error: 'Gutxienez genero bat behar da.' });
    }

    const song = await get("SELECT real_artist FROM songs WHERE id = ?", [req.params.id]);
    if (!song) return res.status(404).json({ error: 'Ez da abestia aurkitu.' });

    await run("UPDATE songs SET genres = ? WHERE id = ?", [JSON.stringify(genres), req.params.id]);

    // ...después de hacer el UPDATE a la canción actual...
    const targetArtist = artist || song.real_artist;
    const artistList = splitArtists(targetArtist);
    let affectedCount = 0;

    if (artistList.length > 0) {
      let anyTagged = false;
      for (const a of artistList) {
        const exists = await get("SELECT 1 FROM artist_genres WHERE LOWER(artist) = LOWER(?)", [a]);
        if (exists) {
          anyTagged = true;
          break;
        }
      }

      if (!anyTagged) {
        const firstArtist = artistList[0];
        await run("INSERT OR REPLACE INTO artist_genres (artist, genres, updated_at) VALUES (?, ?, CURRENT_TIMESTAMP)", [
          firstArtist,
          JSON.stringify(genres)
        ]);

        const untaggedSongs = await query("SELECT id, real_artist FROM songs WHERE genres = '[]' OR genres = '' OR genres IS NULL");
        for (const uSong of untaggedSongs) {
          const uArtistList = splitArtists(uSong.real_artist);
          if (uArtistList.some(a => a.toLowerCase() === firstArtist.toLowerCase())) {
            await run("UPDATE songs SET genres = ? WHERE id = ?", [JSON.stringify(genres), uSong.id]);
            affectedCount++;
          }
        }

        if (affectedCount > 0) {
          console.log(`[Optimizazioa - Tag] ${affectedCount} kantu automatikoki sailkatu dira "${firstArtist}" artistarentzat.`);
        }
      }
    }

    res.json({ success: true, affectedCount });
  } catch (error) {
    console.error(error);
    res.status(500).json({ error: 'Errorea generoak gordetzean.' });
  }
});

