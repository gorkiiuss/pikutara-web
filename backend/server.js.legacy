      return res.status(400).json({ error: 'Ezin da etiketa bat bere buruarekin lotu.' });
    }

    await run("INSERT OR REPLACE INTO tag_mappings (original_tag, canonical_tag) VALUES (?, ?)", [cleanOrig, cleanCanon]);
    res.json({ success: true });
  } catch (error) {
    console.error("Error adding tag mapping:", error);
