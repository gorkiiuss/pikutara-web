// Helper to get official Spotify access token using Client Credentials
async function getSpotifyAccessToken() {
  const clientId = process.env.SPOTIFY_CLIENT_ID;
  const clientSecret = process.env.SPOTIFY_CLIENT_SECRET;
  if (!clientId || !clientSecret) return null;

  try {
    const creds = Buffer.from(clientId + ':' + clientSecret).toString('base64');
    const res = await fetch('https://accounts.spotify.com/api/token', {
      method: 'POST',
      headers: {
        'Authorization': 'Basic ' + creds,
        'Content-Type': 'application/x-www-form-urlencoded'
      },
      body: 'grant_type=client_credentials'
    });
    if (res.ok) {
      const data = await res.json();
      return data.access_token;
    } else {
      console.error("Spotify token request failed with status:", res.status, await res.text());
    }
  } catch (err) {
    console.error("Error getting Spotify client credentials token:", err);
  }
  return null;
}

// Helper to fetch Spotify playlist tracks using Client Credentials with pagination
async function fetchSpotifyPlaylistTracks(playlistId, accessToken) {
  const trackUrls = [];
  let nextUrl = 'https://api.spotify.com/v1/playlists/' + playlistId + '/tracks?limit=100';

  while (nextUrl) {
    try {
      const res = await fetch(nextUrl, {
        headers: {
          'Authorization': 'Bearer ' + accessToken
        }
      });
      if (!res.ok) {
        console.error('Spotify API error ' + res.status + ' fetching tracks:', await res.text());
        break;
      }
      const data = await res.json();
      if (data.items && Array.isArray(data.items)) {
        for (const item of data.items) {
          if (item.track && item.track.id) {
            trackUrls.push('https://open.spotify.com/track/' + item.track.id);
          }
        }
      }
      nextUrl = data.next;
    } catch (err) {
      console.error("Error fetching page from Spotify API:", err);
      break;
    }
  }
  return trackUrls;
}

// Helper function to extract individual song URLs from Spotify/YouTube playlists
async function parsePlaylist(url) {
  const urls = [];

  if (url.includes('spotify.com/playlist/') || url.includes('spotify.com/embed/playlist/')) {
    const playlistIdMatch = url.match(/\/playlist\/([^/?#]+)/);
    if (playlistIdMatch) {
      const playlistId = playlistIdMatch[1];

      // Try official API with Client Credentials first if credentials are configured
      const token = await getSpotifyAccessToken();
      if (token) {
        try {
          const apiTracks = await fetchSpotifyPlaylistTracks(playlistId, token);
          if (apiTracks.length > 0) {
            console.log('Successfully retrieved ' + apiTracks.length + ' tracks from Spotify API for playlist ' + playlistId);
            return apiTracks;
          }
        } catch (apiErr) {
          console.warn("Spotify API retrieval failed, falling back to scraper:", apiErr.message);
        }
      } else {
        console.log("No SPOTIFY_CLIENT_ID and SPOTIFY_CLIENT_SECRET configured. Falling back to public embed scraper (limited to 100 tracks).");
      }

      // Fallback: scrape public embed page (limited to first 100 tracks)
      try {
        const embedUrl = 'https://open.spotify.com/embed/playlist/' + playlistId;
        const response = await fetch(embedUrl, {
          headers: {
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/110.0.0.0 Safari/537.36',
            'Accept-Language': 'en-US,en;q=0.9'
          }
        });
        if (response.ok) {
          const html = await response.text();
          const nextDataMatch = html.match(/<script id="__NEXT_DATA__" type="application\/json">([\s\S]*?)<\/script>/);
          if (nextDataMatch) {
            const data = JSON.parse(nextDataMatch[1]);
            const trackList = data.props?.pageProps?.state?.data?.entity?.trackList;
            if (Array.isArray(trackList)) {
              trackList.forEach(item => {
                if (item.uri && item.uri.startsWith('spotify:track:')) {
                  const trackId = item.uri.split(':')[2];
                  urls.push('https://open.spotify.com/track/' + trackId);
                }
              });
            }
          }
        }
      } catch (e) {
        console.error("Error parsing Spotify playlist scraper:", e);
      }
    }
  } else if (url.includes('youtube.com/') || url.includes('youtu.be/')) {
    // Check if there is a list parameter
    const playlistIdMatch = url.match(/[&?]list=([^&]+)/);
    if (playlistIdMatch) {
      const playlistId = playlistIdMatch[1];
      const playlistUrl = 'https://www.youtube.com/playlist?list=' + playlistId;

      // Try yt-dlp first for full playlist support (no 100 limit)
      try {
        const { stdout } = await execFilePromise('/usr/bin/yt-dlp', [
          '--cookies', '/app/data/cookies.txt',
          '--js-runtimes', 'node',               // 2. Resuelve las firmas de YouTube
          '--ignore-no-formats-error',           // 3. Garantiza que el JSON siempre se devuelva
          '-4',
          '--flat-playlist',
          '--print', 'id',
          playlistUrl
        ], { timeout: 30000 });

        const ids = stdout.split('\n').map(id => id.trim()).filter(Boolean);
        if (ids.length > 0) {
          ids.forEach(id => {
            urls.push('https://www.youtube.com/watch?v=' + id);
          });
          console.log('yt-dlp successfully parsed ' + urls.length + ' tracks from YouTube playlist.');
          return urls;
        }
      } catch (yterr) {
        console.warn("yt-dlp failed, falling back to YouTube HTML scraper:", yterr.message);
      }

      // Fallback: original HTML scraper (only returns up to 100 tracks)
      try {
        const response = await fetch(playlistUrl, {
          headers: {
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/110.0.0.0 Safari/537.36',
            'Accept-Language': 'en-US,en;q=0.9',
            'Cookie': 'SOCS=CAESEwgDEgk0ODE3Nzk3MjQaAmVuIAEaBgiA_LyaBg'
          }
        });
        if (response.ok) {
          const html = await response.text();
          const match = html.match(/var ytInitialData = (\{[\s\S]*?\});/);
          if (match) {
            const data = JSON.parse(match[1]);
            const videoIds = [];
            function searchVideoIds(obj) {
              if (!obj) return;
              if (typeof obj === 'object') {
                if (obj.videoId) {
                  videoIds.push(obj.videoId);
                }
                for (const k in obj) {
                  searchVideoIds(obj[k]);
                }
              }
            }
            searchVideoIds(data);
            const uniqueIds = Array.from(new Set(videoIds));
            uniqueIds.forEach(id => {
              urls.push('https://www.youtube.com/watch?v=' + id);
            });
          }
        }
      } catch (e) {
        console.error("Error parsing YouTube playlist fallback:", e);
      }
    }
  }

  return urls;
}


// Tinder Musikal: Direct add song bypassing Tinder filter (supports single track or playlist)
app.post('/api/admin/songs/direct-add', authMiddleware, async (req, res) => {
  try {
    const { url, mode, submitter, comment } = req.body;
    if (!url) {
      return res.status(400).json({ error: 'URL beharrezkoa da.' });
    }

    // Set headers for chunked streaming
    res.setHeader('Content-Type', 'application/x-ndjson');
    res.setHeader('Transfer-Encoding', 'chunked');

    // Split input by newlines, spaces, or commas to support multiple URLs at once
    const rawUrls = url.split(/[\n\r\s,]+/).map(item => item.trim()).filter(Boolean);
    if (rawUrls.length === 0) {
      res.write(JSON.stringify({ status: 'error', message: 'Ez da URL-rik aurkitu.' }) + '\n');
      return res.end();
    }

    const gatheredSongUrls = [];

    // Resolve playlists to track URLs, or keep single song URLs
    for (const rawUrl of rawUrls) {
      const playlistUrls = await parsePlaylist(rawUrl);
      if (playlistUrls && playlistUrls.length > 0) {
        gatheredSongUrls.push(...playlistUrls);
      } else {
        // If not a playlist (or parsePlaylist returned empty), treat as a single song URL
        gatheredSongUrls.push(rawUrl);
      }
    }

    // Deduplicate songs to process
    const uniqueSongUrls = Array.from(new Set(gatheredSongUrls));
    if (uniqueSongUrls.length === 0) {
      res.write(JSON.stringify({ status: 'error', message: 'Ez da abesti-estekarik aurkitu prozesatzeko.' }) + '\n');
      return res.end();
    }

    const totalCount = uniqueSongUrls.length;
    res.write(JSON.stringify({ status: 'init', total: totalCount }) + '\n');

    let addedCount = 0;
    let existingCount = 0;
    let processedCount = 0;
    const failedSongs = [];
    const adminUser = req.user ? req.user.username : 'admin';

    for (const trackUrl of uniqueSongUrls) {
      processedCount++;
      // Send progress to client
      res.write(JSON.stringify({
        status: 'progress',
        current: processedCount,
        total: totalCount,
        url: trackUrl
      }) + '\n');

      try {
        const videoId = extractYouTubeId(trackUrl);
        let finalVideoId = videoId;

        // 1. YouTube Music Official Release Validation
        if (videoId) {
          let ytCheck = await checkYouTubeVideoType(videoId);
          if (!ytCheck.isValid) {
            // Fallback: try resolving from watch page description
            const officialId = await tryResolveOfficialVideoId(videoId);
            if (officialId) {
              const officialCheck = await checkYouTubeVideoType(officialId);
              if (officialCheck.isValid) {
                finalVideoId = officialId;
                ytCheck = officialCheck;
              }
            }
          }
          if (!ytCheck.isValid) {
            throw new Error('Bideo hau ez da musika-bideo ofiziala (Art Track edo Bideoklip Ofiziala izan behar du)');
          }
        }

        const normalizedUrl = normalizeSongUrl(finalVideoId ? 'https://www.youtube.com/watch?v=' + finalVideoId : trackUrl);

        const targetStatus = mode === 'filter' ? 'pending' : 'accepted';

        const finalSubmitter = submitter && submitter.trim() ? submitter.trim() : "Administratzailea";
        const finalComment = comment && comment.trim() ? comment.trim() : (targetStatus === 'accepted' ? 'Zerrendatik zuzenean gehituta' : 'Administratzaileak iragazkirako gehituta');

        // Fetch metadata first for duplicate checking
        const realMeta = await resolveRealMetadata(normalizedUrl);
        if (!realMeta.title || realMeta.title === 'Ezezaguna') {
          throw new Error('Ezin izan dira abestiaren metadatuak kargatu. Egiaztatu esteka zuzena den.');
        }

        // Check if it already exists in the database
        const existingSong = await findDuplicateSong(normalizedUrl, realMeta.title, realMeta.artist);
        if (existingSong) {
          const submitters = safeParseArray(existingSong.submitters);
          const comments = safeParseArray(existingSong.comments);
          const ips = safeParseArray(existingSong.ips);
          const proposedTitles = safeParseArray(existingSong.proposed_titles);
          const proposedArtists = safeParseArray(existingSong.proposed_artists);

          if (!submitters.includes(finalSubmitter)) submitters.push(finalSubmitter);
          if (finalComment && !comments.includes(finalComment)) comments.push(finalComment);
          if (!ips.includes(req.ip)) ips.push(req.ip);
          if (!proposedTitles.includes(realMeta.title)) proposedTitles.push(realMeta.title);
          if (!proposedArtists.includes(realMeta.artist)) proposedArtists.push(realMeta.artist);

          let updateFields = [];
          let params = [];

          // Check if we should update URL
          if (shouldUpdateUrl(existingSong, { url: normalizedUrl, status: targetStatus })) {
            updateFields.push('url = ?', 'real_title = ?', 'real_artist = ?');
            params.push(normalizedUrl, realMeta.title, realMeta.artist);
          }

          // Update status and details
          if (targetStatus === 'accepted') {
            updateFields.push('status = ?', 'accepted_by = ?');
            params.push('accepted', adminUser);
          } else {
            if (existingSong.status !== 'accepted') {
              updateFields.push('status = ?', 'accepted_by = ?');
              params.push('pending', null);
            }
          }

          updateFields.push('proposed_titles = ?', 'proposed_artists = ?', 'submitters = ?', 'comments = ?', 'ips = ?');
          params.push(
            JSON.stringify(proposedTitles),
            JSON.stringify(proposedArtists),
            JSON.stringify(submitters),
            JSON.stringify(comments),
            JSON.stringify(ips)
          );

          params.push(existingSong.id);
          await run(`UPDATE songs SET ${updateFields.join(', ')} WHERE id = ?`, params);

          existingCount++;
          continue;
        }

        // Fetch genres
        let genres = [];
        try {
          genres = await resolveSongGenres(realMeta.title, realMeta.artist);
        } catch (e) {
          console.error("Genre resolution failed for", normalizedUrl, e.message);
        }

        // Insert into database
        await run(
          `INSERT INTO songs (url, real_title, real_artist, proposed_titles, proposed_artists, submitters, comments, ips, genres, status, accepted_by) 
           VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,
          [
            normalizedUrl,
            realMeta.title,
            realMeta.artist,
            JSON.stringify([realMeta.title]),
            JSON.stringify([realMeta.artist]),
            JSON.stringify([finalSubmitter]),
            JSON.stringify([finalComment]),
            JSON.stringify([req.ip]),
            JSON.stringify(genres),
            targetStatus,
            targetStatus === 'accepted' ? adminUser : null
          ]
        );
        addedCount++;
      } catch (err) {
        console.error("Error adding song in direct add:", trackUrl, err.message);
        failedSongs.push({
          url: trackUrl,
          error: err.message || 'Errore ezezaguna'
        });
        res.write(JSON.stringify({
          status: 'song_error',
          url: trackUrl,
          error: err.message || 'Errore ezezaguna'
        }) + '\n');
      }
    }

    // Complete response
    res.write(JSON.stringify({
      status: 'complete',
      added: addedCount,
      existing: existingCount,
      failed: failedSongs.length
    }) + '\n');
    res.end();
  } catch (error) {
    console.error('Error in direct add endpoint:', error);
    if (!res.headersSent) {
      res.status(500).json({ error: 'Errorea abestiak zuzenean gehitzean: ' + error.message });
    } else {
      res.write(JSON.stringify({ status: 'error', message: error.message }) + '\n');
      res.end();
    }
  }
});

// Tinder Musikal: Bulk re-resolve genres for all songs
app.post('/api/admin/songs/re-resolve-all', authMiddleware, async (req, res) => {
  try {
    // Set headers for chunked streaming
    res.setHeader('Content-Type', 'application/x-ndjson');
    res.setHeader('Transfer-Encoding', 'chunked');

    const songs = await query("SELECT id, real_title, real_artist, proposed_titles, proposed_artists FROM songs");
    const totalCount = songs.length;
    res.write(JSON.stringify({ status: 'init', total: totalCount }) + '\n');

    let processedCount = 0;
    for (const song of songs) {
      processedCount++;

      let title = song.real_title || '';
      let artist = song.real_artist || '';

      if (!title || !artist) {
        try {
          const proposedTitles = JSON.parse(song.proposed_titles || '[]');
          const proposedArtists = JSON.parse(song.proposed_artists || '[]');
          title = title || proposedTitles[0] || '';
          artist = artist || proposedArtists[0] || '';
        } catch (e) { }
      }

      const itemLabel = (title && artist) ? `${title} - ${artist}` : `Song #${song.id}`;
      res.write(JSON.stringify({
        status: 'progress',
        current: processedCount,
        total: totalCount,
        item: itemLabel
      }) + '\n');

      if (title && artist) {
        try {
          const newGenres = await resolveSongGenres(title, artist);
          await run("UPDATE songs SET genres = ? WHERE id = ?", [JSON.stringify(newGenres), song.id]);
        } catch (err) {
          console.error(`Error auto-resolving bulk genres for song ID ${song.id}:`, err.message);
        }
      }
    }

    res.write(JSON.stringify({ status: 'complete' }) + '\n');
    res.end();
  } catch (error) {
    console.error('Error in re-resolve-all endpoint:', error);
    if (!res.headersSent) {
      res.status(500).json({ error: 'Errorea generoak berriz eskuratzean: ' + error.message });
    } else {
      res.write(JSON.stringify({ status: 'error', message: error.message }) + '\n');
      res.end();
    }
  }
});

