// Admin Toggle Section
app.put('/admin/sections/:key/toggle', authMiddleware, async (req, res) => {
  try {
    const section = await get('SELECT is_active FROM sections WHERE key = ?', [req.params.key]);
    if (!section) return res.status(404).json({ error: 'Atala ez da aurkitu' });
    const newStatus = section.is_active === 1 ? 0 : 1;
    await run('UPDATE sections SET is_active = ? WHERE key = ?', [newStatus, req.params.key]);
    res.json({ success: true, is_active: newStatus });
  } catch (error) {
    res.status(500).json({ error: 'Errorea atala eguneratzean' });
  }
});

// ==========================================
// USER MANAGEMENT ENDPOINTS
// ==========================================

app.get('/api/admin/users', authMiddleware, async (req, res) => {
  try {
    const users = await query('SELECT id, username, role, created_at FROM users ORDER BY username ASC');
    res.json(users);
  } catch (error) {
    console.error(error);
    res.status(500).json({ error: 'Errorea erabiltzaileak lortzean.' });
  }
});

app.post('/api/admin/users', authMiddleware, async (req, res) => {
  try {
    const { username, password, role } = req.body;
    if (!username || !password) {
      return res.status(400).json({ error: 'Erabiltzaile izena eta pasahitza beharrezkoak dira.' });
    }
    const cleanUsername = username.trim().toLowerCase();
    if (cleanUsername.length < 3) {
      return res.status(400).json({ error: 'Erabiltzaile izenak gutxienez 3 karaktere izan behar ditu.' });
    }
    if (password.length < 6) {
      return res.status(400).json({ error: 'Pasahitzak gutxienez 6 karaktere izan behar ditu.' });
    }
    const userRole = role === 'admin' ? 'admin' : 'moderator';

    // Hash password
    const salt = crypto.randomBytes(16).toString('hex');
    const hash = crypto.scryptSync(password, salt, 64).toString('hex');

    try {
      await run('INSERT INTO users (username, password_hash, salt, role) VALUES (?, ?, ?, ?)', [cleanUsername, hash, salt, userRole]);
      res.status(201).json({ success: true });
    } catch (dbErr) {
      if (dbErr.message.includes('UNIQUE constraint failed')) {
        return res.status(400).json({ error: 'Erabiltzaile izen hori lehendik badago.' });
      }
      throw dbErr;
    }
  } catch (error) {
    console.error(error);
    res.status(500).json({ error: 'Errorea erabiltzailea sortzean.' });
  }
});

app.delete('/api/admin/users/:id', authMiddleware, async (req, res) => {
  try {
    const userId = req.params.id;
    // Check if the user is deleting themselves
    const userToDelete = await get('SELECT username FROM users WHERE id = ?', [userId]);
    if (!userToDelete) {
      return res.status(404).json({ error: 'Erabiltzailea ez da aurkitu.' });
    }

    if (userToDelete.username === req.user.username) {
      return res.status(400).json({ error: 'Ezin duzu zure erabiltzailea ezabatu.' });
    }

    // Check that we are not deleting the last admin
    const adminCountRow = await get("SELECT COUNT(*) as count FROM users WHERE role = 'admin'");
    const userRoleRow = await get("SELECT role FROM users WHERE id = ?", [userId]);
    if (userRoleRow.role === 'admin' && adminCountRow.count <= 1) {
      return res.status(400).json({ error: 'Ezin da ezabatu azken administratzailea.' });
    }

    await run('DELETE FROM users WHERE id = ?', [userId]);
    res.json({ success: true });
  } catch (error) {
    console.error(error);
    res.status(500).json({ error: 'Errorea erabiltzailea ezabatzean.' });
  }
});

// Rota para registrar uma pessoa no almoço (Gazte Eguna)
app.post('/api/bazkaria', async (req, res) => {
  const { izena, abizenak, email, menuType, ordainketaModua, konpartsakideId, oharrak, mote } = req.body;

  if (!izena || !abizenak || !email || !menuType || !ordainketaModua) {
    return res.status(400).json({ error: 'Datu guztiak bete behar dira (Faltan datos obligatorios).' });
  }

  try {
    const cleanEmail = email.trim().toLowerCase();
    const cleanIzena = izena.trim().toLowerCase();
    const cleanAbizenak = abizenak.trim().toLowerCase();

    const existingRegistration = await get(`
      SELECT id FROM bazkaria_registrations 
      WHERE LOWER(email) = ? AND LOWER(izena) = ? AND LOWER(abizenak) = ?
    `, [cleanEmail, cleanIzena, cleanAbizenak]);

    if (existingRegistration) {
      // Si existe el registro pero el usuario aún no ha rellenado el mote, le mandamos el aviso
      if (!mote || !mote.trim()) {
        return res.status(409).json({
          requiresMote: true,
          error: 'Dagoeneko badago izen-emate bat datu hauekin. Mesedez, jarri mote edo izenondo bat bereizteko (Aitona, Txiki, etab).'
        });
      }

      // Si ya viene con mote, aseguramos que no se duplique también el propio mote para ese mismo email
      const exactMoteDuplicate = await get(`
        SELECT id FROM bazkaria_registrations 
        WHERE LOWER(email) = ? AND LOWER(izena) = ? AND LOWER(abizenak) = ? AND LOWER(mote) = ?
      `, [cleanEmail, cleanIzena, cleanAbizenak, mote.trim().toLowerCase()]);

      if (exactMoteDuplicate) {
        return res.status(400).json({ error: 'Mote hau ere erregistratuta dago jada email honentzat.' });
      }
    }

    // 1. GORDE DATU BASEAN (Guardar en Base de Datos)
    await run(`
      INSERT INTO bazkaria_registrations (izena, abizenak, email, menu_type, ordainketa_modua, konpartsakide_id, oharrak, mote)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?)
    `, [izena, abizenak, email, menuType, ordainketaModua, konpartsakideId || null, oharrak || null, mote || null]);

    // 2. PREPARAR EL EMAIL (Lógica condicional)
    let ordainketaMezua = '';

    // CASO A: Konpartsakide bati eman
    if (ordainketaModua === 'aurretiaz' && konpartsakideId) {
      // Orain telefonoa eta instagrama ere eskatzen ditugu DB-tik
      const k = await get('SELECT izena, telefono, instagram FROM konpartsakideak WHERE id = ?', [konpartsakideId]);
      const konpartsakideIzena = k ? k.izena : 'konpartsakide bati';

      let kontaktuKutxa = '';
      if (k && (k.telefono || k.instagram)) {
        kontaktuKutxa += `<div style="background-color: #f9f9f9; padding: 15px; border-radius: 6px; margin: 15px 0; border: 1px solid #ddd;">`;
        kontaktuKutxa += `<p style="margin-top: 0; margin-bottom: 10px; color: #700070;"><strong>${konpartsakideIzena}-(r)en kontaktua:</strong></p>`;
        kontaktuKutxa += `<ul style="list-style: none; padding: 0; margin: 0; line-height: 1.8;">`;

        if (k.telefono) {
          // 'tel:' estekari esker, mugikorrean sakatzean zuzenean deitzeko edo gorde ahal izateko irekiko da
          kontaktuKutxa += `<li>📱 <strong>Telefonoa:</strong> <a href="tel:${k.telefono}" style="color: #ff0000; text-decoration: none; font-weight: bold;">${k.telefono}</a></li>`;
        }

        if (k.instagram) {
          // '@' ikurra kentzen dugu badaezpada URLan ondo sartzeko
          const cleanInsta = k.instagram.replace(/^@/, '');
          kontaktuKutxa += `<li>📸 <strong>Instagram:</strong> <a href="https://ig.me/m/${cleanInsta}" style="color: #ff0000; text-decoration: none; font-weight: bold;">@${cleanInsta}</a></li>`;
        }

        kontaktuKutxa += `<li>⚠️ <stron>Arazorik baldin baduzu</strong>, edo ordainketa egiteko zailtasunak badituzu, ez izan zalantzarik eta jarri gurekin harremanetan: <a href="mailto:pikutaragaztekonpartsa@gmail.com" style="color: #ff0000; text-decoration: none; font-weight: bold;">pikutaragaztekonpartsa@gmail.com</a></li>`;

        kontaktuKutxa += `</ul></div>`;
      }

      ordainketaMezua = `
        <p>Ordainketa egiteko <strong>${konpartsakideIzena}</strong>-(r)ekin geratu zara.</p>
        <p>Mesedez, jarri berarekin harremanetan ahalik eta lasterren 10€-ak emateko eta zure lekua 100% ziurtatzeko.</p>
        <p>Konpartsakideari ordainketa egitea zailtzen bazaizu, edo bestelako arazoak badituzu, ez izan zalantzarik eta jarri gurekin harremanetan.</p>
        ${kontaktuKutxa}
      `;
    }
    // CASO B: Pikutara zuzenean
    else if (ordainketaModua === 'pikutara_zuzenean') {
      ordainketaMezua = `
        <p>Ordainketa nola egin adosteko gurekin (Pikutara) harremanetan jarriko zinela adierazi duzu.</p>
        <p>Aukeratu bi bide hauetako bat ordainketa bidea ixteko:</p>
        <div style="background-color: #f9f9f9; padding: 15px; border-radius: 6px; margin: 15px 0; border: 1px solid #ddd;">
          <ul style="list-style: none; padding: 0; margin: 0; line-height: 1.8;">
            <li>📸 <strong>Instagram:</strong> <a href="https://ig.me/m/pikutaragaztekonpartsa" style="color: #ff0000; text-decoration: none; font-weight: bold;">@pikutaragaztekonpartsa</a></li>
            <li>📧 <strong>Emaila:</strong> <a href="mailto:pikutaragaztekonpartsa@gmail.com" style="color: #ff0000; text-decoration: none; font-weight: bold;">pikutaragaztekonpartsa@gmail.com (Bidali posta)</a></li>
          </ul>
        </div>
      `;
    }
    // CASO C: Egunean bertan (Ezkutuko aukera)
    else {
      ordainketaMezua = `
        <p>Ordainketa <strong>egunean bertan txosnan</strong> egingo duzula adierazi duzu.</p>
        <p>Gogoan izan 10€-ak justu ekartzea eskertuko dizugula txanpon-aldaketekin arazoak ekiditeko.</p>
      `;
    }

    const menuMezua = menuType === 'beganoa' ? '🌱 Menu Beganoa' : '🍖 Menu Haragijalea';

    // HTML del correo
    const mailOptions = {
      from: `"Pikutara Gazte Konpartsa" <${process.env.EMAIL_USER}>`,
      to: email,
      subject: `✅ Bazkarirako izen-ematea baieztatuta - Gazte Eguna`,
      html: `
        <div style="font-family: Arial, sans-serif; color: #333; max-width: 600px; margin: 0 auto; border: 1px solid #ddd; border-radius: 8px; overflow: hidden;">
          <div style="background-color: #700070; padding: 20px; text-align: center;">
            <h1 style="color: #fff; margin: 0; text-transform: uppercase;">Gazte Eguneko Bazkaria</h1>
          </div>
          <div style="padding: 30px;">
            <p>Kaixo <strong>${izena}</strong>,</p>
            <p>Zure izen-ematea ondo jaso dugu. Hau da zure erregistroaren laburpena:</p>
            
            <div style="background-color: #fff4f4; border-left: 4px solid #ff0000; padding: 15px; margin: 20px 0;">
              <ul style="list-style: none; padding: 0; margin: 0;">
                <li style="margin-bottom: 10px;"><strong>👤 Izena:</strong> ${izena} ${abizenak}${mote ? `<strong> ${mote}</strong>` : ""}</li>
                <li><strong>🍽️ Menua:</strong> ${menuMezua}</li>
                ${oharrak ? `<li style="color: #ff3366; font-weight: bold;"><strong>⚠️ Alergiak/Oharrak:</strong> ${oharrak}</li>` : ''}
              </ul>
            </div>

            <h3 style="color: #700070; border-bottom: 1px solid #ddd; padding-bottom: 5px; margin-top: 30px;">Ordainketa (Pago)</h3>
            ${ordainketaMezua}

            <p style="margin-top: 30px;">Eskerrik asko gazte egunean parte hartzeagatik.<br>Laster arte!</p>
            <p style="font-weight: bold; color: #ff0000;">SESTAO ASTINTZERA!</p>
          </div>
        </div>
      `
    };

    // 3. ENVIAR EL EMAIL
    transporter.sendMail(mailOptions, (error, info) => {
      if (error) {
        console.error('Errorea posta elektronikoa bidaltzean:', error);
      } else {
        console.log('Posta ondo bidali da:', info.response);
      }
    });

    res.status(201).json({ success: true, message: 'Izen ematea ondo burutu da.' });

  } catch (error) {
    console.error('Errorea bazkariko izen-ematea gordetzean:', error);
    res.status(500).json({ error: 'Zerbitzari errorea.' });
  }
});

app.get('/api/bazkaria/registrations', authMiddleware, async (req, res) => {
  try {
    const registrations = await query('SELECT * FROM bazkaria_registrations ORDER BY created_at DESC');
    res.json(registrations);
  } catch (error) {
    console.error('Erro ao buscar inscrições do almoço:', error);
    res.status(500).json({ error: 'Erro no servidor (Zerbitzari errorea).' });
  }
});

// Admin: Ezabatu bazkariko izen-ematea
app.delete('/api/bazkaria/:id', authMiddleware, async (req, res) => {
  try {
    await run('DELETE FROM bazkaria_registrations WHERE id = ?', [req.params.id]);
    res.json({ success: true });
  } catch (error) {
    console.error('Errorea bazkariko erregistroa ezabatzean:', error);
    res.status(500).json({ error: 'Errorea ezabatzean.' });
  }
});

// --- KONPARTSAKIDEAK ---

// Publikoa: Lortu dirua jasotzeko prest dauden konpartsakideak (formularirako)
app.get('/api/konpartsakideak/diru-jasotzaileak', async (req, res) => {
  try {
    const list = await query('SELECT id, izena, instagram, telefono FROM konpartsakideak WHERE dirua_jaso = 1 ORDER BY izena ASC');
    res.json(list);
  } catch (error) {
    console.error(error);
    res.status(500).json({ error: 'Zerbitzari errorea.' });
  }
});

// Admin: Lortu konpartsakide guztiak
app.get('/api/konpartsakideak', authMiddleware, async (req, res) => {
  try {
    const list = await query('SELECT * FROM konpartsakideak ORDER BY izena ASC');
    res.json(list);
  } catch (error) {
    res.status(500).json({ error: 'Zerbitzari errorea.' });
  }
});

// Admin: Gehitu konpartsakide berria
app.post('/api/konpartsakideak', authMiddleware, async (req, res) => {
  const { izena, dirua_jaso, instagram, telefono } = req.body;
  if (!izena) return res.status(400).json({ error: 'Izena beharrezkoa da.' });
  try {
    await run('INSERT INTO konpartsakideak (izena, dirua_jaso, instagram, telefono) VALUES (?, ?, ?, ?)', [izena, dirua_jaso ? 1 : 0, instagram || '', telefono || '']);
    res.status(201).json({ success: true });
  } catch (error) {
    res.status(500).json({ error: 'Errorea gordetzean.' });
  }
});

// 4. Admin: Eguneratu konpartsakide baten datuak (PUT - EDRESIO INLINE-rako)
app.put('/api/konpartsakideak/:id', authMiddleware, async (req, res) => {
  const { id } = req.params;
  const { izena, dirua_jaso, instagram, telefono } = req.body;
  if (!izena) return res.status(400).json({ error: 'Izena beharrezkoa da.' });
  try {
    await run(
      'UPDATE konpartsakideak SET izena = ?, dirua_jaso = ?, instagram = ?, telefono = ? WHERE id = ?',
      [izena, dirua_jaso ? 1 : 0, instagram || '', telefono || '', id]
    );
    res.json({ success: true });
  } catch (error) {
    console.error(error);
    res.status(500).json({ error: 'Errorea eguneratzean.' });
  }
});

// Admin: Ezabatu konpartsakide
app.delete('/api/konpartsakideak/:id', authMiddleware, async (req, res) => {
  try {
    await run('DELETE FROM konpartsakideak WHERE id = ?', [req.params.id]);
    res.json({ success: true });
  } catch (error) {
    res.status(500).json({ error: 'Errorea ezabatzean.' });
  }
});

// Global Express error handler middleware
app.use((err, req, res, next) => {
  console.error('Global Express error handler:', err);
  res.status(err.status || 500).json({
    error: err.message || 'Zerbitzari errorea.'
  });
});

// Start the server and handle EADDRINUSE gracefully
const server = app.listen(PORT, () => {
  console.log(`Pikutara API running on http://localhost:${PORT}`);
});

server.on('error', (error) => {
  if (error.code === 'EADDRINUSE') {
    console.error(`Error: Port ${PORT} is already in use by another process. Please stop that process and try again.`);
  } else {
    console.error('Server error event:', error);
  }
});

// Prevent Node process from crashing due to unhandled promise rejections
process.on('unhandledRejection', (reason, promise) => {
  console.error('Unhandled Rejection at:', promise, 'reason:', reason);
});

// Prevent Node process from crashing due to uncaught exceptions
process.on('uncaughtException', (error) => {
  console.error('Uncaught Exception thrown:', error);
});
