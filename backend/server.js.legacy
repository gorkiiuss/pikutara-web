// Import garbage tags list from JSON array
app.post('/api/admin/garbage-tags/import', authMiddleware, async (req, res) => {
  try {
    const { tags } = req.body;
    if (!tags || !Array.isArray(tags)) {
      return res.status(400).json({ error: 'Etiketa zerrenda okerra.' });
    }

    let importedCount = 0;
    for (const tag of tags) {
      if (tag && typeof tag === 'string' && tag.trim()) {
        const cleanTag = tag.trim().toLowerCase();
        await run("INSERT OR IGNORE INTO garbage_tags (tag) VALUES (?)", [tag.trim()]);

        // Clean existing songs
        const songs = await query("SELECT id, genres FROM songs");
        for (const song of songs) {
          let genres = [];
          try {
            genres = JSON.parse(song.genres || '[]');
          } catch (e) { }

          if (Array.isArray(genres)) {
            const filtered = genres.filter(g => g.toLowerCase() !== cleanTag);
            if (filtered.length !== genres.length) {
              await run("UPDATE songs SET genres = ? WHERE id = ?", [JSON.stringify(filtered), song.id]);
            }
          }
        }
        importedCount++;
      }
    }
    res.json({ success: true, count: importedCount });
  } catch (error) {
    console.error("Error importing garbage tags:", error);
    res.status(500).json({ error: 'Errorea zabor etiketak inportatzean.' });
  }
});

