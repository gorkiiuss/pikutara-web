// ADMIN ENDPOINTS & PANEL
// ==========================================

// Obtener letra de una canción (Bajo demanda + Caché en BBDD via LRCLIB)
app.get('/api/admin/songs/:id/lyrics', authMiddleware, async (req, res) => {
  try {
    const song = await get("SELECT real_artist, real_title, lyrics FROM songs WHERE id = ?", [req.params.id]);
    if (!song) return res.status(404).json({ error: 'Ez da abestia aurkitu.' });

    // Si ya la tenemos en caché (SQLite), la devolvemos al instante
    if (song.lyrics) {
      return res.json({ lyrics: song.lyrics, source: 'cache' });
    }

    // Buscamos en la API de LRCLIB
    const trackQuery = encodeURIComponent(song.real_title);
    const artistQuery = encodeURIComponent(song.real_artist);
    const url = `https://lrclib.net/api/search?track_name=${trackQuery}&artist_name=${artistQuery}`;

    // LRCLIB agradece que pongamos un User-Agent descriptivo
    const lrcRes = await fetch(url, {
      headers: {
        'User-Agent': 'Pikutara-TinderMusikal/1.0 (https://github.com/txartelari)'
      }
    });

    if (!lrcRes.ok) {
      return res.json({ lyrics: null, error: 'API errorea letrak bilatzean.' });
    }

    const data = await lrcRes.json();

    // Comprobamos si nos ha devuelto resultados y si tiene texto plano
    if (!data || data.length === 0 || !data[0].plainLyrics) {
      return res.json({ lyrics: null, error: 'Ez da letrarik aurkitu LRCLIB-en.' });
    }

    // Extraemos la letra del primer resultado
    const lyricsText = data[0].plainLyrics;

    // Guardamos en base de datos para no volver a preguntar nunca más
    await run("UPDATE songs SET lyrics = ? WHERE id = ?", [lyricsText, req.params.id]);

    res.json({ lyrics: lyricsText, source: 'lrclib' });

  } catch (error) {
    console.error("Error fetching lyrics from LRCLIB:", error);
    res.status(500).json({ error: 'Errorea letrak kargatzean.' });
  }
});

