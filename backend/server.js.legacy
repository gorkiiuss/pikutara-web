              }
            } catch (e) {
              alert('Sareko errorea');
            }
          }

          function filterSongs(status, btn) {
            document.querySelectorAll('.btn-filter').forEach(b => b.classList.remove('active'));
            if (btn) btn.classList.add('active');
            var select = document.getElementById('filter-status');
            if (select) {
              select.value = status;
              applyFiltersAndSort();
            }
          }

          function applyFiltersAndSort() {
            var searchVal = document.getElementById('search-songs').value.toLowerCase().trim();
            var statusVal = document.getElementById('filter-status').value;
            var adminVal = document.getElementById('filter-admin').value;
            var genreVal = document.getElementById('filter-genre').value;
            var sortVal = document.getElementById('sort-songs').value;

            var groups = Array.from(document.querySelectorAll('.song-group'));
            var visibleGroups = [];

            groups.forEach(function(group) {
              var id = group.getAttribute('data-id');
              var status = group.getAttribute('data-status') || '';
              var admin = group.getAttribute('data-accepted-by') || '';
              var searchable = (group.getAttribute('data-searchable') || '').toLowerCase();
              
              var genres = [];
              try {
                genres = JSON.parse(group.getAttribute('data-genres') || '[]');
              } catch(e) {}

              // 1. Text search
              var matchSearch = true;
              if (searchVal !== '') {
                matchSearch = (searchable.indexOf(searchVal) !== -1);
              }

              // 2. Status
              var matchStatus = true;
              if (statusVal !== 'all') {
                matchStatus = (status === statusVal);
              }

              // 3. Admin
              var matchAdmin = true;
              if (adminVal !== 'all') {
                matchAdmin = (admin === adminVal);
              }

              // 4. Genre
              var matchGenre = true;
              if (genreVal !== 'all') {
                if (genreVal === 'none') {
                  matchGenre = (genres.length === 0);
                } else {
                  matchGenre = (genres.indexOf(genreVal) !== -1);
                }
              }

              var show = matchSearch && matchStatus && matchAdmin && matchGenre;
              if (show) {
                group.style.display = '';
                visibleGroups.push(group);
              } else {
                group.style.display = 'none';
                // Also hide edit form if active
                var editRow = document.getElementById('edit-row-' + id);
                if (editRow) {
                  editRow.style.display = 'none';
                }
              }
            });

            // Sort
            visibleGroups.sort(function(a, b) {
              var idA = parseInt(a.getAttribute('data-id'), 10);
              var idB = parseInt(b.getAttribute('data-id'), 10);
              var titleA = (a.getAttribute('data-title') || '').toLowerCase();
              var titleB = (b.getAttribute('data-title') || '').toLowerCase();
              var artistA = (a.getAttribute('data-artist') || '').toLowerCase();
              var artistB = (b.getAttribute('data-artist') || '').toLowerCase();
              var adminA = (a.getAttribute('data-accepted-by') || '').toLowerCase();
              var adminB = (b.getAttribute('data-accepted-by') || '').toLowerCase();
              var statusA = (a.getAttribute('data-status') || '').toLowerCase();
              var statusB = (b.getAttribute('data-status') || '').toLowerCase();

              if (sortVal === 'id-desc') {
                return idB - idA;
              } else if (sortVal === 'id-asc') {
                return idA - idB;
              } else if (sortVal === 'title-asc') {
                return titleA.localeCompare(titleB);
              } else if (sortVal === 'title-desc') {
                return titleB.localeCompare(titleA);
              } else if (sortVal === 'artist-asc') {
                return artistA.localeCompare(artistB);
              } else if (sortVal === 'artist-desc') {
                return artistB.localeCompare(artistA);
              } else if (sortVal === 'admin-asc') {
                return adminA.localeCompare(adminB);
              } else if (sortVal === 'status-asc') {
                return statusA.localeCompare(statusB);
              }
              return 0;
            });

            // Re-order in DOM
            var container = document.getElementById('songs-table');
            if (container) {
              visibleGroups.forEach(function(group) {
                container.appendChild(group);
              });
            }

            // Update counter
            var counterEl = document.getElementById('songs-counter');
            if (counterEl) {
              counterEl.innerText = 'Erakusten: ' + visibleGroups.length + ' / ' + groups.length + ' abesti';
            }
          }

