  }
});

// Get master list of ALL defined genres in the system (Hierarchy + History + Cache + Mappings)
app.get('/api/admin/genres/all', authMiddleware, async (req, res) => {
  try {
    const genreSet = new Set();

    // 1. Cargamos las sinonimias con los nombres de columna reales de database.js
    const mappingsRows = await query("SELECT original_tag, canonical_tag FROM tag_mappings");
    const mappingsMap = {};     // Mapa para traducir: sinonimo -> canonico
    const synonymsSet = new Set(); // Set rápido para identificar qué etiquetas son sinónimos

    mappingsRows.forEach(m => {
      if (m.original_tag && m.canonical_tag) {
        const origLower = m.original_tag.trim().toLowerCase();
        mappingsMap[origLower] = m.canonical_tag.trim();
        synonymsSet.add(origLower); // Guardamos el sinónimo para excluirlo al final
      }
    });

    // Helper interno para resolver sinónimos en caliente
    const toCanonical = (g) => {
      if (!g) return '';
      const clean = g.trim();
      const lower = clean.toLowerCase();
      return mappingsMap[lower] || clean; // Si es sinónimo lo traduce, si no lo deja igual
    };

    // 2. Del árbol de jerarquías (parent_genre, genre)
    const hierarchyRows = await query("SELECT parent_genre, genre FROM genre_hierarchy");
    hierarchyRows.forEach(r => {
      if (r.parent_genre) genreSet.add(toCanonical(r.parent_genre));
      if (r.genre) genreSet.add(toCanonical(r.genre));
    });

    // 3. De los propios destinos canónicos mapeados
    mappingsRows.forEach(m => {
      if (m.canonical_tag) genreSet.add(m.canonical_tag.trim());
    });

    // 4. De las canciones ya etiquetadas históricamente (Normalizando datos antiguos)
    const songRows = await query("SELECT genres FROM songs WHERE genres != '[]' AND genres IS NOT NULL");
    songRows.forEach(s => {
      try {
        const parsed = JSON.parse(s.genres);
        if (Array.isArray(parsed)) {
          parsed.forEach(g => genreSet.add(toCanonical(g)));
        }
      } catch (e) { }
    });

    // 5. De la caché de optimización de artistas
    const artistRows = await query("SELECT genres FROM artist_genres");
    artistRows.forEach(a => {
      try {
        const parsed = JSON.parse(a.genres);
        if (Array.isArray(parsed)) {
          parsed.forEach(g => genreSet.add(toCanonical(g)));
        }
      } catch (e) { }
    });

    // FILTRADO CRÍTICO: Eliminamos vacíos Y prohibimos estrictamente la entrada de sinónimos (original_tags)
    const finalGenres = Array.from(genreSet)
      .filter(g => g && g.length > 0 && !synonymsSet.has(g.toLowerCase()))
      .sort((a, b) => a.localeCompare(b));

    res.json(finalGenres);
  } catch (error) {
    console.error("Error obteniendo master list de géneros:", error);
    res.status(500).json({ error: 'Errorea genero zerrenda osoa eskuratzean.' });
  }
});

