  }
});

// Tres nuevas rutas para la gestión y I/O de los artistas clasificados por la konpartsa

// 1. Obtener la lista completa de artistas y sus géneros en formato JSON limpio (para exportar/ver)
app.get('/api/admin/artist-genres', authMiddleware, async (req, res) => {
  try {
    const rows = await query("SELECT artist, genres FROM artist_genres ORDER BY artist ASC");
    rows.forEach(r => {
      try {
        r.genres = JSON.parse(r.genres || '[]');
      } catch (e) {
        r.genres = [];
      }
    });
    res.json(rows);
  } catch (error) {
    res.status(500).json({ error: 'Errorea artisten generoak kargatzean.' });
  }
});

// 2. Eliminar un registro de la caché de un artista por si os habéis equivocado
app.delete('/api/admin/artist-genres/:artist', authMiddleware, async (req, res) => {
  try {
    await run("DELETE FROM artist_genres WHERE artist = ?", [req.params.artist]);
    res.json({ success: true });
  } catch (error) {
    res.status(500).json({ error: 'Errorea artista ezabatzean.' });
  }
});

// 3. Importación masiva por lotes (Bulk Import) mediante transacciones seguras de SQLite
app.post('/api/admin/artist-genres/bulk', authMiddleware, async (req, res) => {
  try {
    const mappings = req.body;
    if (!Array.isArray(mappings)) {
      return res.status(400).json({ error: 'Array bat espero zen.' });
    }

    await new Promise((resolve, reject) => {
      db.serialize(() => {
        db.run("BEGIN TRANSACTION", (err) => {
          if (err) return reject(err);
        });
        const stmt = db.prepare("INSERT OR REPLACE INTO artist_genres (artist, genres, updated_at) VALUES (?, ?, CURRENT_TIMESTAMP)");
        let hasError = false;
        let lastErr = null;

        for (const m of mappings) {
          const artist = m.artist;
          const genres = m.genres;
          // Validamos que el formato importado coincida con lo esperado
          if (artist && typeof artist === 'string' && Array.isArray(genres)) {
            stmt.run(artist.trim(), JSON.stringify(genres), (err) => {
              if (err) {
                hasError = true;
                lastErr = err;
              }
            });
          }
        }

        stmt.finalize((err) => {
          if (err || hasError) {
            db.run("ROLLBACK", () => {
              reject(err || lastErr || new Error("Error masiboan inportatzean"));
            });
          } else {
            db.run("COMMIT", (commitErr) => {
              if (commitErr) {
                db.run("ROLLBACK", () => reject(commitErr));
              } else {
                resolve();
              }
            });
          }
        });
      });
    });

    res.json({ success: true, count: mappings.length });
  } catch (error) {
    console.error("Error bulk importing artist genres:", error);
    res.status(500).json({ error: 'Errorea artisten generoak inportatzean: ' + error.message });
  }
});

app.get('/admin', authMiddleware, async (req, res) => {
  try {
    const [
      pendingMemes,
      approvedMemes,
      allPosters,
      allReviews,
      sections,
      pageViews,
      allSongs,
      garbageTags,
      tagMappings,
      genreHierarchy,
      allUsers,
      algorithmSettings,
      artistGenders
    ] = await Promise.all([
      query('SELECT * FROM memes WHERE is_approved = 0 ORDER BY created_at DESC'),
      query('SELECT * FROM memes WHERE is_approved = 1 ORDER BY created_at DESC'),
      query('SELECT * FROM posters ORDER BY created_at DESC'),
      query('SELECT * FROM playlist_reviews ORDER BY created_at DESC'),
      query('SELECT * FROM sections'),
      query('SELECT * FROM page_views ORDER BY views DESC'),
      query('SELECT * FROM songs ORDER BY created_at DESC'),
      query("SELECT tag FROM garbage_tags ORDER BY tag ASC"),
      query("SELECT original_tag, canonical_tag FROM tag_mappings ORDER BY original_tag ASC"),
      query("SELECT genre, parent_genre FROM genre_hierarchy ORDER BY genre ASC"),
      query("SELECT id, username, role, created_at FROM users ORDER BY username ASC"),
      query("SELECT key, value FROM algorithm_settings"),
      query("SELECT artist, gender_type, verified FROM artist_genders ORDER BY artist ASC")
    ]);
    let bazkariRegistrations = [];
    try {
      bazkariRegistrations = await query(`
        SELECT r.*, k.izena as konpartsakide_izena 
        FROM bazkaria_registrations r 
        LEFT JOIN konpartsakideak k ON r.konpartsakide_id = k.id 
        ORDER BY r.created_at DESC
      `);
    } catch (err) {
      console.error("⚠️ KONTUZ: Bazkari taula ez dago ondo (Agian pikutara.sqlite ezabatu behar duzu):", err.message);
      // Datu-basea gaizki badago, hutsik utziko dugu panela kargatu dadin.
      bazkariRegistrations = [];
    }
    const settingsMap = {};
    algorithmSettings.forEach(s => settingsMap[s.key] = s.value);

    const mappingsMap = new Map();
    tagMappings.forEach(m => {
      mappingsMap.set(m.original_tag.trim().toLowerCase(), m.canonical_tag.trim());
    });

    allSongs.forEach(s => {
      s.genres = applyTagMappings(safeParseArray(s.genres), mappingsMap);
      s.proposed_titles = safeParseArray(s.proposed_titles);
      s.proposed_artists = safeParseArray(s.proposed_artists);
      s.submitters = safeParseArray(s.submitters);
      s.comments = safeParseArray(s.comments);
    });

    // Build hierarchical genre tree HTML
    const parentMap = new Map(); // child -> parent
    const childrenMap = new Map(); // parent -> list of children
    const allUniqueGenresInHierarchy = new Set();

    genreHierarchy.forEach(h => {
      const g = h.genre.trim();
      const p = h.parent_genre.trim();
      parentMap.set(g.toLowerCase(), p);
      if (!childrenMap.has(p.toLowerCase())) {
        childrenMap.set(p.toLowerCase(), []);
      }
      childrenMap.get(p.toLowerCase()).push(g);
      allUniqueGenresInHierarchy.add(g);
      allUniqueGenresInHierarchy.add(p);
    });

    // Find roots of the hierarchy
    const roots = [];
    allUniqueGenresInHierarchy.forEach(g => {
      if (!parentMap.has(g.toLowerCase())) {
        roots.push(g);
      }
    });

    roots.sort((a, b) => a.localeCompare(b));

    function renderTreeNode(nodeName) {
      const children = childrenMap.get(nodeName.toLowerCase()) || [];
      children.sort((a, b) => a.localeCompare(b));

      const hasParent = parentMap.has(nodeName.toLowerCase());
      // Only show deletion button for subgenres (children)
      const deleteBtn = hasParent
        ? `<span class="tree-node-delete" onclick="deleteGenreHierarchy('${nodeName.replace(/'/g, "\\'")}')" title="Kendu lotura">×</span>`
        : '';

      const badgeClass = hasParent ? 'tree-node-child' : 'tree-node-root';
      const icon = hasParent ? '🏷️' : '🌳';
      const toggleBtn = children.length > 0
        ? `<span class="tree-node-toggle" onclick="toggleTreeNode(event, this)" style="cursor: pointer; margin-right: 6px; user-select: none; font-size: 0.8rem; color: #ff3366;">▼</span>`
        : '';

      let nodeHtml = `
        <li>
          <span class="tree-node ${badgeClass}">
            ${toggleBtn}${icon} ${nodeName}${deleteBtn}
          </span>
      `;

      if (children.length > 0) {
        nodeHtml += `<ul>`;
        children.forEach(c => {
          nodeHtml += renderTreeNode(c);
        });
        nodeHtml += `</ul>`;
      }

      nodeHtml += `</li>`;
      return nodeHtml;
    }

    let genreTreeHtml = `<ul class="genre-tree-root">`;
    if (roots.length === 0) {
      genreTreeHtml += `<p style="font-style: italic; color: #888; margin: 0;">Ez dago genero hierarkiarik zehaztuta une honetan.</p>`;
    } else {
      roots.forEach(root => {
        genreTreeHtml += renderTreeNode(root);
      });
    }
    genreTreeHtml += `</ul>`;

    // Compute frequency of active tags not in the garbage list
    const garbageSet = new Set(garbageTags.map(g => g.tag.trim().toLowerCase()));
    const nonGarbageTagCounts = {};
    allSongs.forEach(s => {
      s.genres.forEach(g => {
        if (typeof g === 'string') {
          const trimmed = g.trim();
          const lower = trimmed.toLowerCase();
          if (!garbageSet.has(lower)) {
            nonGarbageTagCounts[trimmed] = (nonGarbageTagCounts[trimmed] || 0) + 1;
          }
        }
      });
    });

    const sortedNonGarbageTags = Object.entries(nonGarbageTagCounts)
      .map(([tag, count]) => ({ tag, count }))
      .sort((a, b) => a.count - b.count); // Ascending order (least occurrences first)

    let avgScore = 0;
    if (allReviews.length > 0) {
      const sum = allReviews.reduce((acc, r) => acc + r.rating, 0);
      avgScore = (sum / allReviews.length).toFixed(1);
    }

    const artistGenres = await query("SELECT artist, genres FROM artist_genres ORDER BY artist ASC");
    artistGenres.forEach(ag => {
      try {
        ag.genres = JSON.parse(ag.genres || '[]');
      } catch (e) {
        ag.genres = [];
      }
    });

    const uniqueAdmins = Array.from(new Set(allSongs.map(s => s.accepted_by).filter(Boolean))).sort();
    const genresFromHierarchy = genreHierarchy.map(h => h.genre.trim());
    const genresFromSongs = allSongs.flatMap(s => s.genres || []);
    const allUniqueGenres = Array.from(new Set([...genresFromHierarchy, ...genresFromSongs])).map(g => typeof g === 'string' ? g.trim() : g).filter(Boolean).sort((a, b) => a.localeCompare(b));

    let html = `
      <!DOCTYPE html>
      <html lang="eu">
      <head>
        <meta charset="UTF-8">
        <title>Pikutara Admin</title>
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <style>
          @import url('https://fonts.googleapis.com/css2?family=Anton&family=Outfit:wght@300;400;600;700&display=swap');
          body {
            font-family: 'Outfit', sans-serif;
            background-color: #0f0212;
            color: #f5f5f7;
            padding: 30px 20px;
            margin: 0;
            line-height: 1.5;
          }
          .container { max-width: 1200px; margin: 0 auto; }
          .card {
            background: rgba(30, 8, 38, 0.65);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 51, 102, 0.2);
            padding: 25px;
            margin-bottom: 30px;
            border-radius: 12px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
          }
          .flex { display: flex; gap: 20px; }
          img { max-width: 250px; max-height: 250px; object-fit: contain; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); }
          .btn {
            padding: 8px 16px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-family: inherit;
            font-size: 0.85rem;
            font-weight: 600;
            transition: all 0.2s ease-in-out;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
          }
          .btn:hover { transform: translateY(-1px); filter: brightness(1.1); }
          .btn-approve { background: linear-gradient(135deg, #2e7d32, #4caf50); color: white; box-shadow: 0 2px 8px rgba(76, 175, 80, 0.2); }
          .btn-unapprove { background: linear-gradient(135deg, #ef6c00, #ff9800); color: white; box-shadow: 0 2px 8px rgba(255, 152, 0, 0.2); }
          .btn-delete { background: linear-gradient(135deg, #c62828, #f44336); color: white; box-shadow: 0 2px 8px rgba(244, 67, 54, 0.2); }
          .btn-submit { background: linear-gradient(135deg, #e91e63, #ff3366); color: white; box-shadow: 0 2px 8px rgba(255, 51, 102, 0.2); margin-top: 10px; }
          .btn-edit { background: linear-gradient(135deg, #1565c0, #2196f3); color: white; box-shadow: 0 2px 8px rgba(33, 150, 243, 0.2); }
          .btn-filter { background: rgba(255, 255, 255, 0.05); color: #ccc; border: 1px solid rgba(255, 255, 255, 0.1); }
          .btn-filter:hover { background: rgba(255, 255, 255, 0.1); color: #fff; }
          .btn-filter.active { background: #ff3366; color: white; border-color: #ff3366; box-shadow: 0 0 10px rgba(255, 51, 102, 0.4); }
          
          h1, h2, h3, h4 { font-weight: 700; letter-spacing: -0.02em; margin-top: 0; }
          h1 { color: #ff3366; font-size: 2.2rem; text-shadow: 0 0 10px rgba(255, 51, 102, 0.3); margin-bottom: 25px; }
          h2 { color: #ffcc00; font-size: 1.5rem; margin-top: 40px; margin-bottom: 20px; border-bottom: 1px solid rgba(255, 204, 0, 0.2); padding-bottom: 8px; }
