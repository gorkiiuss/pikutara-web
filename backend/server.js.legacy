                  '<!-- Album cover black outline -->' +
                  '<rect x="' + coverX + '" y="' + coverY + '" width="' + coverSize + '" height="' + coverSize + '" rx="8" fill="none" stroke="#000000" stroke-width="5" />' +
                  '<!-- Metadata -->' +
                  '<text x="540" y="' + textTitleY + '" font-size="' + finalTitleFontSize + '" font-weight="900" fill="#5a00a8" text-anchor="middle" font-family="Anton, sans-serif">' + titleText.replace(/"/g, '&quot;') + '</text>' +
                  '<text x="540" y="' + textArtistY + '" font-size="' + finalArtistFontSize + '" font-weight="900" fill="#009900" text-anchor="middle" font-family="Anton, sans-serif">' + artistText.replace(/"/g, '&quot;') + '</text>' +
                  '<!-- Genre Badges -->' +
                  '<g>' + genreBadgesHtml + '</g>' +
                  commentsHtml +
                  submitterHtml +
                  '<!-- Watermark -->' +
                  '<text x="540" y="990" font-size="18" font-weight="900" letter-spacing="4" fill="#5a00a8" opacity="0.4" text-anchor="middle" font-family="Anton, sans-serif">2026KO TXOSNAGUNEKO MUSIKA ZERRENDA</text>';
              } else {
                contentSVG = '<!-- Glass Card -->' +
                  '<rect x="' + cardX + '" y="' + cardY + '" width="' + cardW + '" height="' + cardH + '" rx="36" fill="rgba(15, 4, 20, 0.72)" stroke="rgba(255, 51, 102, 0.25)" stroke-width="2" style="filter: drop-shadow(0 20px 40px rgba(0,0,0,0.6));" />' +
                  '<!-- Album Cover shadow glow -->' +
                  '<rect x="' + (coverX - 8) + '" y="' + (coverY - 8) + '" width="' + (coverSize + 16) + '" height="' + (coverSize + 16) + '" rx="24" fill="none" stroke="#ff3366" stroke-width="3" opacity="0.4" style="filter: blur(10px);" />' +
                  '<!-- Album Cover -->' +
                  '<defs>' +
                  '<clipPath id="square-cover-clip">' +
                  '<rect x="' + coverX + '" y="' + coverY + '" width="' + coverSize + '" height="' + coverSize + '" rx="18" />' +
                  '</clipPath>' +
                  '</defs>' +
                  '<image href="' + base64Image + '" x="' + coverX + '" y="' + coverY + '" width="' + coverSize + '" height="' + coverSize + '" clip-path="url(#square-cover-clip)" preserveAspectRatio="xMidYMid slice" />' +
                  '<!-- Metadata -->' +
                  '<text x="540" y="' + textTitleY + '" font-size="38" font-weight="900" fill="#ffffff" text-anchor="middle" font-family="Outfit">' + displayTitle.toUpperCase().replace(/"/g, '&quot;') + '</text>' +
                  '<text x="540" y="' + textArtistY + '" font-size="24" font-weight="700" fill="#ff3366" text-anchor="middle" font-family="Outfit">' + displayArtist.toUpperCase().replace(/"/g, '&quot;') + '</text>' +
                  '<!-- Genre Badges -->' +
                  '<g>' + genreBadgesHtml + '</g>' +
                  commentsHtml +
                  submitterHtml +
                  '<!-- Watermark -->' +
                  '<text x="540" y="930" font-size="14" font-weight="900" letter-spacing="4" fill="rgba(255, 255, 255, 0.18)" text-anchor="middle" font-family="Outfit">2026KO TXOSNAGUNEKO MUSIKA ZERRENDA</text>';
              }
            } else {
              const coverSize = 640;
              const coverX = 220;
              const coverY = 320;

              const textTitleY = 1070;
              const textArtistY = 1135;
              const genreY = 1190;
              const quoteBoxY = 1320;
              const submitterY = 1480;

              let commentsHtml = '';
              if (showComments && song.comments && song.comments.filter(Boolean).length > 0) {
                const comment = song.comments.filter(Boolean)[0];
                const displayComment = comment.length > 70 ? comment.substring(0, 67) + '...' : comment;
                if (isSestao) {
                  const commentFontSize = 36;
                  commentsHtml = '<g transform="translate(140, ' + quoteBoxY + ')">' +
                    '<rect x="0" y="0" width="800" height="110" rx="20" fill="#f8f9fa" stroke="#000000" stroke-width="3" />' +
                    '<text x="400" y="68" font-size="' + commentFontSize + '" fill="#1a1a1a" text-anchor="middle" font-family="Anton, sans-serif">"' + displayComment.replace(/"/g, '&quot;') + '"</text>' +
                    '<text x="40" y="55" font-size="50" font-family="Georgia, serif" fill="#5a00a8" opacity="0.2">“</text>' +
                    '</g>';
                } else {
                  commentsHtml = '<g transform="translate(140, ' + quoteBoxY + ')">' +
                    '<rect x="0" y="0" width="800" height="110" rx="20" fill="rgba(255, 51, 102, 0.05)" stroke="rgba(255, 51, 102, 0.15)" stroke-width="1.5" />' +
                    '<text x="400" y="50" font-size="22" font-style="italic" fill="#eeeeee" text-anchor="middle" font-family="Outfit">"' + displayComment.replace(/"/g, '&quot;') + '"</text>' +
                    '<text x="40" y="45" font-size="50" font-family="Georgia, serif" fill="#ff3366" opacity="0.3">“</text>' +
                    '</g>';
                }
              }

              let submitterHtml = '';
              if (showSubmitters && song.submitters && song.submitters.length > 0) {
                if (isSestao) {
                  const subText = 'PROPOSATZAILEA: ' + song.submitters.join(', ').toUpperCase();
                  const subFontSize = 32;
                  submitterHtml = '<text x="540" y="' + submitterY + '" font-size="' + subFontSize + '" fill="#555555" text-anchor="middle" font-family="Anton, sans-serif">' + subText.replace(/"/g, '&quot;') + '</text>';
                } else {
                  submitterHtml = '<text x="540" y="' + submitterY + '" font-size="18" font-weight="700" fill="#888888" letter-spacing="2" text-anchor="middle" font-family="Outfit">PROPOSATZAILEA: ' + song.submitters.join(', ').toUpperCase().replace(/"/g, '&quot;') + '</text>';
                }
              }

              let genreBadgesHtml = '';
              const listGenres = genres.slice(0, 3);
              const totalBadges = listGenres.length;
              const badgeH = isSestao ? 54 : 38;
              const badgeGap = 16;
              
              const badgeWidths = listGenres.map(function(g) { return isSestao ? (g.length * 14 + 44) : (g.length * 9 + 36); });
              const totalWidth = badgeWidths.reduce(function(a, b) { return a + b; }, 0) + (totalBadges - 1) * badgeGap;
              
              let currentX = 540 - totalWidth / 2;
              listGenres.forEach(function(g, idx) {
                const bW = badgeWidths[idx];
                const colorRaw = getGenreColorRaw(g);
                if (isSestao) {
                  genreBadgesHtml += '<g transform="translate(' + currentX + ', ' + genreY + ')">' +
                    '<rect x="0" y="0" width="' + bW + '" height="' + badgeH + '" rx="' + (badgeH/2) + '" fill="hsla(' + colorRaw + ', 0.12)" stroke="hsl(' + colorRaw + ')" stroke-width="3" />' +
                    '<text x="' + (bW/2) + '" y="34" font-size="20" font-weight="900" fill="hsl(' + colorRaw + ')" text-anchor="middle" font-family="Anton, sans-serif">' + g.toUpperCase().replace(/"/g, '&quot;') + '</text>' +
                    '</g>';
                } else {
                  genreBadgesHtml += '<g transform="translate(' + currentX + ', ' + genreY + ')">' +
                    '<rect x="0" y="0" width="' + bW + '" height="' + badgeH + '" rx="' + (badgeH/2) + '" fill="hsla(' + colorRaw + ', 0.12)" stroke="hsl(' + colorRaw + ')" stroke-width="1.5" />' +
                    '<text x="' + (bW/2) + '" y="24" font-size="14" font-weight="800" fill="hsl(' + colorRaw + ')" text-anchor="middle" font-family="Outfit">' + g.toUpperCase().replace(/"/g, '&quot;') + '</text>' +
                    '</g>';
                }
                currentX += bW + badgeGap;
              });

              if (isSestao) {
                const titleText = displayTitle.toUpperCase();
                const titleFontSize = 105;
                const estimatedCharWidth = titleFontSize * 0.42;
                let titleW = titleText.length * estimatedCharWidth;
                let finalTitleFontSize = titleFontSize;
                if (titleW > 900) {
                  titleW = 900;
                  finalTitleFontSize = Math.floor(900 / (titleText.length * 0.42));
                }

                const artistText = displayArtist.toUpperCase();
                const artistFontSize = 60;
                const estimatedArtistCharWidth = artistFontSize * 0.42;
                let artistW = artistText.length * estimatedArtistCharWidth;
                let finalArtistFontSize = artistFontSize;
                if (artistW > 900) {
                  artistW = 900;
                  finalArtistFontSize = Math.floor(900 / (artistText.length * 0.42));
                }

                contentSVG = '<!-- Sestao Outer Frame -->' +
                  '<rect x="25" y="25" width="1030" height="1870" fill="none" stroke="#000000" stroke-width="10" />' +
                  '<!-- Album Cover -->' +
                  '<defs>' +
                  '<clipPath id="story-cover-clip">' +
                  '<rect x="' + coverX + '" y="' + coverY + '" width="' + coverSize + '" height="' + coverSize + '" rx="12" />' +
                  '</clipPath>' +
                  '</defs>' +
                  '<image href="' + base64Image + '" x="' + coverX + '" y="' + coverY + '" width="' + coverSize + '" height="' + coverSize + '" clip-path="url(#story-cover-clip)" preserveAspectRatio="xMidYMid slice" />' +
                  '<!-- Album cover black outline -->' +
                  '<rect x="' + coverX + '" y="' + coverY + '" width="' + coverSize + '" height="' + coverSize + '" rx="12" fill="none" stroke="#000000" stroke-width="6" />' +
                  '<!-- Metadata -->' +
                  '<text x="540" y="' + textTitleY + '" font-size="' + finalTitleFontSize + '" font-weight="900" fill="#5a00a8" text-anchor="middle" font-family="Anton, sans-serif">' + titleText.replace(/"/g, '&quot;') + '</text>' +
                  '<text x="540" y="' + textArtistY + '" font-size="' + finalArtistFontSize + '" font-weight="900" fill="#009900" text-anchor="middle" font-family="Anton, sans-serif">' + artistText.replace(/"/g, '&quot;') + '</text>' +
                  '<!-- Genre Badges -->' +
                  '<g>' + genreBadgesHtml + '</g>' +
                  commentsHtml +
                  submitterHtml +
                  '<!-- Bottom CTA -->' +
                  '<g transform="translate(540, 1660)">' +
                  (function() {
                    const ctaText = 'ETORRI TXOSNAGUNERA ETA ENTZUN ZUEN MUSIKA! 🎧';
                    const ctaFontSize = 32;
                    const ctaW = 840;
                    const ctaH = 90;
                    return '<rect x="' + (-ctaW/2) + '" y="' + (-ctaH/2) + '" width="' + ctaW + '" height="' + ctaH + '" rx="45" fill="#ffffff" stroke="#5a00a8" stroke-width="4" />' +
                           '<text x="0" y="12" font-size="' + ctaFontSize + '" fill="#5a00a8" text-anchor="middle" font-family="Anton, sans-serif">' + ctaText + '</text>';
                  })() +
                  '</g>' +
                  '<!-- Watermark -->' +
                  '<text x="540" y="1810" font-size="28" font-weight="900" letter-spacing="5" fill="#5a00a8" opacity="0.4" text-anchor="middle" font-family="Anton, sans-serif">2026KO TXOSNAGUNEKO MUSIKA ZERRENDA</text>';
              } else {
                contentSVG = '<!-- Album Cover shadow glow -->' +
                  '<rect x="' + (coverX - 12) + '" y="' + (coverY - 12) + '" width="' + (coverSize + 24) + '" height="' + (coverSize + 24) + '" rx="36" fill="none" stroke="#ff3366" stroke-width="4" opacity="0.5" style="filter: drop-shadow(0 0 20px #ff3366);" />' +
                  '<!-- Album Cover -->' +
                  '<defs>' +
                  '<clipPath id="story-cover-clip">' +
                  '<rect x="' + coverX + '" y="' + coverY + '" width="' + coverSize + '" height="' + coverSize + '" rx="24" />' +
                  '</clipPath>' +
                  '</defs>' +
                  '<image href="' + base64Image + '" x="' + coverX + '" y="' + coverY + '" width="' + coverSize + '" height="' + coverSize + '" clip-path="url(#story-cover-clip)" preserveAspectRatio="xMidYMid slice" />' +
                  '<!-- Metadata -->' +
                  '<text x="540" y="' + textTitleY + '" font-size="48" font-weight="900" fill="#ffffff" text-anchor="middle" font-family="Outfit">' + displayTitle.toUpperCase().replace(/"/g, '&quot;') + '</text>' +
                  '<text x="540" y="' + textArtistY + '" font-size="28" font-weight="700" fill="#ff3366" text-anchor="middle" font-family="Outfit">' + displayArtist.toUpperCase().replace(/"/g, '&quot;') + '</text>' +
                  '<!-- Genre Badges -->' +
                  '<g>' + genreBadgesHtml + '</g>' +
                  commentsHtml +
                  submitterHtml +
                  '<!-- Bottom CTA -->' +
                  '<g transform="translate(540, 1660)">' +
                  '<rect x="-220" y="-25" width="440" height="50" rx="25" fill="rgba(255, 204, 0, 0.1)" stroke="#ffcc00" stroke-width="1.5" />' +
                  '<text x="0" y="7" font-size="16" font-weight="800" fill="#ffcc00" text-anchor="middle" font-family="Outfit">ETORRI TXOSNAGUNERA ETA ENTZUN ZUEN MUSIKA! 🎧</text>' +
                  '</g>' +
                  '<!-- Watermark -->' +
                  '<text x="540" y="1810" font-size="18" font-weight="900" letter-spacing="5" fill="rgba(255, 255, 255, 0.15)" text-anchor="middle" font-family="Outfit">2026KO TXOSNAGUNEKO MUSIKA ZERRENDA</text>';
              }
            }

            const fontStyles = isSestao
              ? '@import url("https://fonts.googleapis.com/css2?family=Anton&amp;display=swap"); text { font-family: "Anton", sans-serif; }'
              : '@import url("https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800;900&amp;display=swap"); text { font-family: "Outfit", sans-serif; }';

            const svgMarkup = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ' + width + ' ' + height + '" width="' + width + '" height="' + height + '">' +
              '<defs>' +
              '<style>' +
              fontStyles +
              '</style>' +
              '</defs>' +
              bgSVG +
              contentSVG +
              '</svg>';

            const previewContainer = document.getElementById('song-card-svg-preview-container');
            previewContainer.innerHTML = svgMarkup;
            
            const previewSvg = previewContainer.querySelector('svg');
            if (previewSvg) {
              previewSvg.style.width = '100%';
              previewSvg.style.height = 'auto';
              previewSvg.style.maxHeight = isSquare ? '340px' : '450px';
            }
          }

          window.downloadSongCardSVG = function() {
            const previewContainer = document.getElementById('song-card-svg-preview-container');
            const svgElement = previewContainer.querySelector('svg');
            if (!svgElement) {
              alert('Ez dago deskargatzeko txartelik prest!');
              return;
            }
            
            const select = document.getElementById('card-song-select');
            const songId = select.value;
            const song = adminSongs.find(function(s) { return s.id == songId; });
            const titleSlug = song ? (song.real_title || 'kantu').toLowerCase().replace(/[^a-z0-9]/g, '_') : 'karta';

            const serializer = new XMLSerializer();
            const svgString = serializer.serializeToString(svgElement);
            const blob = new Blob([svgString], { type: 'image/svg+xml;charset=utf-8' });
            const url = URL.createObjectURL(blob);
            
            const link = document.createElement('a');
            link.href = url;
            link.download = 'txosnagune_karta_' + titleSlug + '.svg';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            URL.revokeObjectURL(url);
          };

          window.generateGenreWheelSVG = async function() {
            const scope = document.getElementById('wheel-scope').value;
            const status = document.getElementById('wheel-status').value;
            const format = document.getElementById('wheel-format').value;
            const style = document.getElementById('wheel-style').value;

            const isSquare = format === 'square';
            const isSestao = style === 'sestao';

            if (isSestao && !sestaoLogoBase64) {
              const previewContainer = document.getElementById('genre-wheel-svg-preview-container');
              previewContainer.innerHTML = '<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 340px; color: #5a00a8; font-weight: bold; background: white; font-family: sans-serif; gap: 10px;">' +
                '<span class="animate-spin" style="font-size: 2rem;">🔄</span>' +
                '<span>Sestaoko Txosnen logoa kargatzen...</span>' +
                '</div>';
              try {
                sestaoLogoBase64 = await getBase64ImageFromUrl('/assets/sestaokotxosnak_logoa.svg');
              } catch (err) {
                console.error("Error loading Sestao logo:", err);
              }
            }

            const filteredSongs = adminSongs.filter(function(s) {
              if (s.status === 'accepted') return true;
              if (status === 'all' && s.status === 'pending') return true;
              return false;
            });

            const counts = {};
            filteredSongs.forEach(function(song) {
              if (song.genres && Array.isArray(song.genres)) {
                song.genres.forEach(function(g) {
                  let cat = g.trim();
                  if (scope === 'parents') {
                    const path = getGenrePath(g);
                    if (path.length > 0) {
                      cat = path[0];
                    }
                  }
                  counts[cat] = (counts[cat] || 0) + 1;
                });
              }
            });

            const sorted = Object.entries(counts).sort(function(a, b) { return b[1] - a[1]; });
            
            const maxCategories = scope === 'parents' ? 8 : 11;
            const mainCategories = sorted.slice(0, maxCategories);
            const otherCategories = sorted.slice(maxCategories);

            let finalSlices = mainCategories.map(function(item) { return { name: item[0], count: item[1] }; });
            if (otherCategories.length > 0) {
              const othersCount = otherCategories.reduce(function(acc, c) { return acc + c[1]; }, 0);
              finalSlices.push({ name: 'Bestelakoak', count: othersCount });
            }

            const totalOccurrences = finalSlices.reduce(function(acc, s) { return acc + s.count; }, 0);

            if (totalOccurrences === 0) {
              document.getElementById('genre-wheel-svg-preview-container').innerHTML = 
                '<div style="display: flex; align-items: center; justify-content: center; height: 100%; color: #ff3366; font-weight: bold;">' +
                'Ez dago daturik erabilgarri' +
                '</div>';
              return;
            }

            finalSlices.forEach(function(slice) {
              slice.percentage = (slice.count / totalOccurrences) * 100;
            });

            const width = 1080;
            const height = isSquare ? 1080 : 1920;
            
            let bgSVG = '';
            if (isSestao) {
              bgSVG = '<rect width="' + width + '" height="' + height + '" fill="#ffffff" />' +
                (sestaoLogoBase64 
                  ? (isSquare 
                      ? '<image href="' + sestaoLogoBase64 + '" x="660" y="660" width="450" height="450" />'
                      : '<image href="' + sestaoLogoBase64 + '" x="560" y="1400" width="560" height="560" />')
                  : '') +
                (isSquare 
                  ? '<rect x="20" y="20" width="1040" height="1040" fill="none" stroke="#000000" stroke-width="8" />'
                  : '<rect x="25" y="25" width="1030" height="1870" fill="none" stroke="#000000" stroke-width="10" />');
            } else if (style === 'neon') {
              bgSVG = '<defs>' +
                '<linearGradient id="wheel-bg-grad" x1="0%" y1="0%" x2="100%" y2="100%">' +
                  '<stop offset="0%" stop-color="#0f0212"/>' +
                  '<stop offset="100%" stop-color="#1c0724"/>' +
                '</linearGradient>' +
                '</defs>' +
                '<rect width="' + width + '" height="' + height + '" fill="url(#wheel-bg-grad)" />';
              if (!isSquare) {
                bgSVG += '<defs>' +
                  '<filter id="blur-large-wheel"><feGaussianBlur stdDeviation="120" /></filter>' +
                  '</defs>' +
                  '<circle cx="200" cy="400" r="300" fill="#ff3366" opacity="0.05" filter="url(#blur-large-wheel)" />' +
                  '<circle cx="900" cy="1400" r="400" fill="#9c27b0" opacity="0.07" filter="url(#blur-large-wheel)" />';
              }
            } else if (style === 'gradient') {
              bgSVG = '<defs>' +
                '<linearGradient id="wheel-bg-grad-colored" x1="0%" y1="0%" x2="100%" y2="100%">' +
                  '<stop offset="0%" stop-color="#1e0826"/>' +
                  '<stop offset="100%" stop-color="#3b0b45"/>' +
                '</linearGradient>' +
                '</defs>' +
                '<rect width="' + width + '" height="' + height + '" fill="url(#wheel-bg-grad-colored)" />';
            } else { // minimal
              bgSVG = '<rect width="' + width + '" height="' + height + '" fill="#0a0a0a" />';
            }

            const cx = 540;
            const cy = isSquare 
              ? (isSestao ? 530 : 480) 
              : (isSestao ? 780 : 690);
            const r = isSquare ? 250 : 280;
            const strokeWidth = isSquare ? 85 : 100;
            const circ = 2 * Math.PI * r;

            let slicesSVG = '';
            let accumulatedLength = 0;

            finalSlices.forEach(function(slice) {
              const sliceLength = (slice.percentage / 100) * circ;
              const colorRaw = getGenreColorRaw(slice.name);
              
              slicesSVG += '<circle cx="' + cx + '" cy="' + cy + '" r="' + r + '" fill="transparent" ' +
                'stroke="hsl(' + colorRaw + ')" stroke-width="' + strokeWidth + '" ' +
                'stroke-dasharray="' + sliceLength + ' ' + circ + '" ' +
                'stroke-dashoffset="-' + accumulatedLength + '" ' +
                'transform="rotate(-90 ' + cx + ' ' + cy + ')" ' +
                (isSestao ? '' : 'style="filter: drop-shadow(0 0 10px hsla(' + colorRaw + ', 0.5));"') + ' />';
              accumulatedLength += sliceLength;
            });

            let legendSVG = '';
            if (isSquare) {
              const colW = 280;
              const colGap = 40;
              const startX = 540 - (3 * colW + 2 * colGap) / 2;
              const startY = isSestao ? 850 : 820;

              finalSlices.forEach(function(slice, idx) {
                const col = idx % 3;
                const row = Math.floor(idx / 3);
                const x = startX + col * (colW + colGap);
                const y = startY + row * (isSestao ? 75 : 65);
                const colorRaw = getGenreColorRaw(slice.name);

                if (isSestao) {
                  legendSVG += '<g transform="translate(' + x + ', ' + y + ')">' +
                    '<rect x="0" y="0" width="270" height="64" rx="8" fill="#ffffff" stroke="#000000" stroke-width="2.5" />' +
                    '<rect x="12" y="19" width="26" height="26" rx="4" fill="hsl(' + colorRaw + ')" stroke="#000000" stroke-width="1.5" />' +
                    '<text x="48" y="28" font-size="22" fill="#5a00a8" font-family="Anton, sans-serif">' + slice.name.toUpperCase().replace(/"/g, '&quot;') + '</text>' +
                    '<text x="48" y="50" font-size="16" fill="#009900" font-family="Anton, sans-serif">' + slice.percentage.toFixed(1) + '% (' + slice.count + ' kantu)</text>' +
                    '</g>';
                } else {
                  legendSVG += '<g transform="translate(' + x + ', ' + y + ')">' +
                    '<rect x="0" y="0" width="18" height="18" rx="6" fill="hsl(' + colorRaw + ')" style="filter: drop-shadow(0 0 4px hsla(' + colorRaw + ', 0.5));" />' +
                    '<text x="28" y="14" font-size="15" font-weight="800" fill="#ffffff" font-family="Outfit">' + slice.name.toUpperCase().replace(/"/g, '&quot;') + '</text>' +
                    '<text x="28" y="32" font-size="12" font-weight="600" fill="#aaaaaa" font-family="Outfit">' + slice.percentage.toFixed(1) + '% (' + slice.count + ' kantu)</text>' +
                    '</g>';
                }
              });
            } else {
              const colW = 380;
              const colGap = 60;
              const startX = 130;
              const startY = isSestao ? 1200 : 1130;

              finalSlices.forEach(function(slice, idx) {
                const col = idx % 2;
                const row = Math.floor(idx / 2);
                const x = startX + col * (colW + colGap);
                const y = startY + row * (isSestao ? 85 : 70);
                const colorRaw = getGenreColorRaw(slice.name);

                if (isSestao) {
                  legendSVG += '<g transform="translate(' + x + ', ' + y + ')">' +
                    '<rect x="0" y="0" width="370" height="74" rx="10" fill="#ffffff" stroke="#000000" stroke-width="2.5" />' +
                    '<rect x="14" y="23" width="28" height="28" rx="4" fill="hsl(' + colorRaw + ')" stroke="#000000" stroke-width="1.5" />' +
                    '<text x="52" y="34" font-size="26" fill="#5a00a8" font-family="Anton, sans-serif">' + slice.name.toUpperCase().replace(/"/g, '&quot;') + '</text>' +
                    '<text x="52" y="58" font-size="18" fill="#009900" font-family="Anton, sans-serif">' + slice.percentage.toFixed(1) + '% (' + slice.count + ' kantu)</text>' +
                    '</g>';
                } else {
                  legendSVG += '<g transform="translate(' + x + ', ' + y + ')">' +
                    '<rect x="0" y="0" width="20" height="20" rx="6" fill="hsl(' + colorRaw + ')" style="filter: drop-shadow(0 0 4px hsla(' + colorRaw + ', 0.5));" />' +
                    '<text x="32" y="15" font-size="16" font-weight="800" fill="#ffffff" font-family="Outfit">' + slice.name.toUpperCase().replace(/"/g, '&quot;') + '</text>' +
                    '<text x="32" y="34" font-size="13" font-weight="600" fill="#aaaaaa" font-family="Outfit">' + slice.percentage.toFixed(1) + '% (' + slice.count + ' kantu)</text>' +
                    '</g>';
                }
              });
            }

            const totalUniqueSongs = new Set(filteredSongs.map(function(s) { return s.id; })).size;

            let titlesSVG = '';
            if (isSestao) {
              const titleFontSize = isSquare ? 84 : 105;
              const titleY = isSquare ? 180 : 300;
              const subFontSize = isSquare ? 24 : 30;
              const subY = isSquare ? 100 : 200;
              titlesSVG = 
                '<text x="540" y="' + subY + '" font-size="' + subFontSize + '" font-weight="900" letter-spacing="' + (isSquare ? 4 : 5) + '" fill="#5a00a8" opacity="0.4" text-anchor="middle" font-family="Anton, sans-serif">2026KO TXOSNAGUNEKO MUSIKA ZERRENDA</text>' +
                '<text x="540" y="' + titleY + '" font-size="' + titleFontSize + '" font-weight="900" fill="#5a00a8" text-anchor="middle" font-family="Anton, sans-serif">GENEROEN BANAKETA</text>';
            } else {
              if (isSquare) {
                titlesSVG = 
                  '<text x="540" y="100" font-size="20" font-weight="900" fill="#ff3366" letter-spacing="6" text-anchor="middle" font-family="Outfit">2026KO TXOSNAGUNEKO MUSIKA ZERRENDA</text>' +
                  '<text x="540" y="160" font-size="48" font-weight="900" fill="#ffffff" letter-spacing="2" text-anchor="middle" font-family="Outfit">GENEROEN BANAKETA</text>';
              } else {
                titlesSVG = 
                  '<text x="540" y="200" font-size="22" font-weight="900" fill="#ff3366" letter-spacing="6" text-anchor="middle" font-family="Outfit">2026KO TXOSNAGUNEKO MUSIKA ZERRENDA</text>' +
                  '<text x="540" y="270" font-size="56" font-weight="900" fill="#ffffff" letter-spacing="2" text-anchor="middle" font-family="Outfit">GENEROEN BANAKETA</text>';
              }
            }

            let innerCircleSVG = '';
            if (isSestao) {
              innerCircleSVG = 
                '<circle cx="' + cx + '" cy="' + cy + '" r="' + (r - strokeWidth/2 - 2) + '" fill="#f2f2f2" stroke="#000000" stroke-width="3" />' +
                '<text x="' + cx + '" y="' + (cy - (isSquare ? 45 : 50)) + '" font-size="' + (isSquare ? 26 : 30) + '" fill="#5a00a8" text-anchor="middle" font-family="Anton, sans-serif">GUZTIRA</text>' +
                '<text x="' + cx + '" y="' + (cy + (isSquare ? 30 : 35)) + '" font-size="' + (isSquare ? 90 : 100) + '" fill="#000000" text-anchor="middle" font-family="Anton, sans-serif">' + totalUniqueSongs + '</text>' +
                '<text x="' + cx + '" y="' + (cy + (isSquare ? 85 : 95)) + '" font-size="' + (isSquare ? 26 : 30) + '" fill="#009900" letter-spacing="1" text-anchor="middle" font-family="Anton, sans-serif">KANTU ONARTUTA</text>';
            } else {
              innerCircleSVG = 
                '<circle cx="' + cx + '" cy="' + cy + '" r="' + (r - strokeWidth/2 - 2) + '" fill="#0f0212" opacity="0.3" />' +
                '<text x="' + cx + '" y="' + (cy - (isSquare ? 35 : 40)) + '" font-size="' + (isSquare ? 20 : 22) + '" font-weight="800" fill="#888888" text-anchor="middle" font-family="Outfit">GUZTIRA</text>' +
                '<text x="' + cx + '" y="' + (cy + (isSquare ? 30 : 35)) + '" font-size="' + (isSquare ? 76 : 84) + '" font-weight="950" fill="#ffffff" text-anchor="middle" font-family="Outfit">' + totalUniqueSongs + '</text>' +
                '<text x="' + cx + '" y="' + (cy + (isSquare ? 75 : 85)) + '" font-size="' + (isSquare ? 20 : 22) + '" font-weight="800" fill="#ff3366" letter-spacing="1" text-anchor="middle" font-family="Outfit">KANTU ONARTUTA</text>';
            }

            let bottomCtaSVG = '';
            if (!isSquare) {
              if (isSestao) {
                bottomCtaSVG = '<!-- Bottom CTA -->' +
                  '<g transform="translate(540, 1660)">' +
                  (function() {
                    const ctaText = 'ETORRI TXOSNAGUNERA ETA ENTZUN ZUEN MUSIKA! 🎧';
                    const ctaFontSize = 32;
                    const ctaW = 840;
                    const ctaH = 90;
                    return '<rect x="' + (-ctaW/2) + '" y="' + (-ctaH/2) + '" width="' + ctaW + '" height="' + ctaH + '" rx="' + (ctaH/2) + '" fill="#ffffff" stroke="#5a00a8" stroke-width="4" />' +
                           '<text x="0" y="12" font-size="' + ctaFontSize + '" fill="#5a00a8" text-anchor="middle" font-family="Anton, sans-serif">' + ctaText + '</text>';
                  })() +
                  '</g>';
              } else {
                bottomCtaSVG = '<!-- Bottom CTA -->' +
                  '<g transform="translate(540, 1660)">' +
                  '<rect x="-260" y="-25" width="520" height="50" rx="25" fill="rgba(255, 204, 0, 0.1)" stroke="#ffcc00" stroke-width="1.5" />' +
                  '<text x="0" y="7" font-size="16" font-weight="800" fill="#ffcc00" text-anchor="middle" font-family="Outfit">ETORRI TXOSNAGUNERA ETA ENTZUN ZUEN MUSIKA! 🎧</text>' +
                  '</g>';
              }
            }

            const watermarkY = isSquare ? 1040 : 1840;
            const watermarkSize = isSquare ? (isSestao ? 22 : 18) : (isSestao ? 28 : 22);
            const watermarkSVG = isSestao
              ? '<text x="540" y="' + watermarkY + '" font-size="' + watermarkSize + '" font-weight="900" letter-spacing="5" fill="#5a00a8" opacity="0.4" text-anchor="middle" font-family="Anton, sans-serif">2026KO TXOSNAGUNEKO MUSIKA ZERRENDA</text>'
              : '<text x="540" y="' + watermarkY + '" font-size="' + watermarkSize + '" font-weight="900" letter-spacing="5" fill="rgba(255, 255, 255, 0.15)" text-anchor="middle" font-family="Outfit">2026KO TXOSNAGUNEKO MUSIKA ZERRENDA</text>';

            const fontStyles = isSestao
              ? '@import url("https://fonts.googleapis.com/css2?family=Anton&amp;display=swap"); text { font-family: "Anton", sans-serif; }'
              : '@import url("https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800;900&amp;display=swap"); text { font-family: "Outfit", sans-serif; }';

            const svgMarkup = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ' + width + ' ' + height + '" width="' + width + '" height="' + height + '">' +
              '<defs>' +
              '<style>' +
              fontStyles +
              '</style>' +
              '</defs>' +
              bgSVG +
              titlesSVG +
              '<g>' + slicesSVG + '</g>' +
              innerCircleSVG +
              '<g>' + legendSVG + '</g>' +
              bottomCtaSVG +
              watermarkSVG +
              '</svg>';

            const previewContainer = document.getElementById('genre-wheel-svg-preview-container');
            previewContainer.style.aspectRatio = isSquare ? '1/1' : '9/16';
            previewContainer.innerHTML = svgMarkup;

            const previewSvg = previewContainer.querySelector('svg');
            if (previewSvg) {
              previewSvg.style.width = '100%';
              previewSvg.style.height = 'auto';
              previewSvg.style.maxHeight = isSquare ? '380px' : '480px';
            }
          };

          window.downloadGenreWheelSVG = function() {
            const previewContainer = document.getElementById('genre-wheel-svg-preview-container');
            const svgElement = previewContainer.querySelector('svg');
            if (!svgElement) {
              alert('Ez dago estatistika gurpilik prest!');
              return;
            }
            
            const serializer = new XMLSerializer();
            const svgString = serializer.serializeToString(svgElement);
            const blob = new Blob([svgString], { type: 'image/svg+xml;charset=utf-8' });
            const url = URL.createObjectURL(blob);
            
            const link = document.createElement('a');
            link.href = url;
            link.download = 'txosnagune_generoak_gurpila.svg';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            URL.revokeObjectURL(url);
          };

        </script>
      </body>
      </html>
    `;
    res.send(html);
  } catch (error) { res.status(500).send('Errorea zerbitzarian'); }
});

app.put('/admin/memes/:id/approve', authMiddleware, async (req, res, next) => {
  try {
    await run('UPDATE memes SET is_approved = 1 WHERE id = ?', [req.params.id]);
    res.json({ success: true });
  } catch (error) {
    next(error);
  }
});

app.put('/admin/memes/:id/unapprove', authMiddleware, async (req, res, next) => {
  try {
    await run('UPDATE memes SET is_approved = 0 WHERE id = ?', [req.params.id]);
    res.json({ success: true });
  } catch (error) {
    next(error);
  }
});

app.delete('/admin/memes/:id', authMiddleware, async (req, res, next) => {
  try {
    const meme = await get('SELECT image_path FROM memes WHERE id = ?', [req.params.id]);
    if (meme) {
      const fPath = path.join(__dirname, meme.image_path);
      if (fs.existsSync(fPath)) fs.unlinkSync(fPath);
    }
    await run('DELETE FROM memes WHERE id = ?', [req.params.id]);
    res.json({ success: true });
  } catch (error) {
    next(error);
  }
});

// Admin Poster Upload
app.post('/admin/posters', authMiddleware, uploadPoster.single('posterFile'), async (req, res) => {
  try {
    const { posterTitle, posterDate, posterDesc, posterBands } = req.body;
    if (!req.file || !posterTitle || !posterDate) return res.status(400).send('Datu nagusiak falta dira');

    const bandsArray = posterBands ? posterBands.split(',').map(b => b.trim()) : [];
    const imagePath = '/uploads/posters/' + req.file.filename;

    await run('INSERT INTO posters (title, event_date, description, bands, file_path) VALUES (?, ?, ?, ?, ?)',
      [posterTitle, posterDate, posterDesc || '', JSON.stringify(bandsArray), imagePath]);
    res.redirect('/admin');
  } catch (error) {
    res.status(500).send('Errorea: ' + error.message);
  }
});

// Admin Edit Poster
app.post('/admin/posters/:id/edit', authMiddleware, uploadPoster.single('posterFile'), async (req, res) => {
  try {
    const { posterTitle, posterDate, posterDesc, posterBands } = req.body;
    if (!posterTitle || !posterDate) return res.status(400).send('Datu nagusiak falta dira');

    const bandsArray = posterBands ? posterBands.split(',').map(b => b.trim()) : [];

    if (req.file) {
      // New file uploaded: delete old file and update path
      const oldPoster = await get('SELECT file_path FROM posters WHERE id = ?', [req.params.id]);
      if (oldPoster && oldPoster.file_path) {
        const fPath = path.join(__dirname, oldPoster.file_path);
        if (fs.existsSync(fPath)) fs.unlinkSync(fPath);
      }
      const newImagePath = '/uploads/posters/' + req.file.filename;
      await run('UPDATE posters SET title = ?, event_date = ?, description = ?, bands = ?, file_path = ? WHERE id = ?',
        [posterTitle, posterDate, posterDesc || '', JSON.stringify(bandsArray), newImagePath, req.params.id]);
    } else {
      // Keep existing file path
      await run('UPDATE posters SET title = ?, event_date = ?, description = ?, bands = ? WHERE id = ?',
        [posterTitle, posterDate, posterDesc || '', JSON.stringify(bandsArray), req.params.id]);
    }
    res.redirect('/admin');
  } catch (error) {
    res.status(500).send('Errorea aldatzean: ' + error.message);
  }
});

