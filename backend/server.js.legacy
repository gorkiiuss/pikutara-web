          }
          
          .badge { padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 700; display: inline-block; text-transform: uppercase; letter-spacing: 0.05em; }
          .badge-pending { background: rgba(255, 152, 0, 0.15); color: #ffb74d; border: 1px solid rgba(255, 152, 0, 0.3); }
          .badge-accepted { background: rgba(76, 175, 80, 0.15); color: #81c784; border: 1px solid rgba(76, 175, 80, 0.3); }
          .badge-rejected { background: rgba(244, 67, 54, 0.15); color: #e57373; border: 1px solid rgba(244, 67, 54, 0.3); }
          
          table { width: 100%; border-collapse: separate; border-spacing: 0; text-align: left; }
          th { background: rgba(255, 51, 102, 0.1); color: #ffff00; font-weight: 600; padding: 12px 10px; border-bottom: 2px solid rgba(255, 51, 102, 0.3); }
          td { padding: 12px 10px; border-bottom: 1px solid rgba(255, 51, 102, 0.1); vertical-align: middle; }
          tr:hover td { background: rgba(255, 255, 255, 0.02); }

          /* Table scrollable wrapper and sticky headers */
          .table-scroll-wrapper {
            max-height: 600px;
